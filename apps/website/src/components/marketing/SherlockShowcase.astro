---
// Sherlock AI Agent showcase section
---

<section class="section overflow-hidden">
  <div class="container-forge">
    <div class="grid lg:grid-cols-2 gap-16 items-center">

      <!-- Left: UI mockup of Sherlock -->
      <div class="order-2 lg:order-1 appear">
        <div class="relative">
          <!-- Glow backdrop -->
          <div class="absolute inset-0 -m-8 rounded-3xl opacity-20"
               style="background: radial-gradient(ellipse, rgba(34,211,238,1), transparent 70%); filter: blur(40px);"></div>

          <!-- Sherlock panel -->
          <div class="card relative overflow-hidden shadow-modal">
            <!-- Panel header -->
            <div class="flex items-center gap-3 px-5 py-4 border-b border-forge-border bg-forge-surface2/50">
              <div class="w-8 h-8 rounded-full bg-forge-info-bg border border-forge-cyan/30 flex items-center justify-center">
                <svg class="w-4 h-4 text-forge-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
                </svg>
              </div>
              <div>
                <div class="text-sm font-medium text-forge-text">Sherlock</div>
                <div class="text-xs text-forge-text-3">AI Build Intelligence</div>
              </div>
              <div class="ml-auto badge-danger text-xs">Build #1839 failed</div>
            </div>

            <!-- Sherlock analysis -->
            <div class="p-5 space-y-4 font-mono text-sm">
              <!-- Context strip -->
              <div class="flex items-center gap-3 p-3 rounded-lg bg-forge-danger-bg border border-forge-danger/20 text-xs">
                <svg class="w-4 h-4 text-forge-danger flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
                </svg>
                <span class="text-forge-danger font-sans">Step <strong>test:unit</strong> exited with code 1 after 14.2s</span>
              </div>

              <!-- Sherlock narration -->
              <div class="space-y-3">
                <div class="flex gap-3">
                  <div class="w-6 h-6 rounded-full bg-forge-cyan/10 border border-forge-cyan/30 flex items-center justify-center flex-shrink-0 mt-0.5">
                    <span class="text-forge-cyan text-xs font-bold">S</span>
                  </div>
                  <div class="space-y-2 text-forge-text-2 text-xs font-sans leading-relaxed">
                    <p>I analyzed <strong class="text-forge-text">1,847 log lines</strong>, your <strong class="text-forge-text">package.json</strong>, and the git diff from <strong class="text-forge-text">feat/auth-refactor</strong>.</p>
                    <p>The failure is <strong class="text-forge-danger">deterministic</strong>, not flaky.</p>
                  </div>
                </div>

                <!-- Root cause -->
                <div class="rounded-lg border border-forge-border bg-forge-surface2 p-4 space-y-2">
                  <div class="text-2xs font-mono uppercase tracking-wider text-forge-text-3 mb-3">Root Cause</div>
                  <div class="flex gap-2 text-xs">
                    <span class="text-forge-danger font-mono">→</span>
                    <span class="text-forge-text-2 font-sans">
                      <code class="text-forge-accent bg-forge-surface3 px-1.5 py-0.5 rounded text-xs">jest.config.ts</code> line 14:
                      <strong class="text-forge-text"> moduleNameMapper</strong> missing alias for
                      <code class="text-forge-cyan bg-forge-surface3 px-1.5 py-0.5 rounded text-xs">@/lib/auth</code> added in commit
                      <code class="text-forge-text bg-forge-surface3 px-1.5 py-0.5 rounded text-xs">a4f9c2b</code>
                    </span>
                  </div>
                  <div class="flex gap-2 text-xs">
                    <span class="text-forge-warning font-mono">→</span>
                    <span class="text-forge-text-2 font-sans">
                      Affects <strong class="text-forge-text">23 test files</strong> importing from the new path
                    </span>
                  </div>
                </div>

                <!-- Fix suggestion -->
                <div class="rounded-lg border border-forge-success/30 bg-forge-success-bg p-4 space-y-3">
                  <div class="text-2xs font-mono uppercase tracking-wider text-forge-success mb-2">Suggested Fix</div>
                  <pre class="text-xs text-forge-text overflow-x-auto leading-relaxed"><code><span class="text-forge-text-3">// jest.config.ts</span>
moduleNameMapper: {{'{'}}
  <span class="text-forge-danger">- '^@/(.*)$': '&lt;rootDir&gt;/src/$1'</span>
  <span class="text-forge-success">+ '^@/(.*)$': '&lt;rootDir&gt;/src/$1',</span>
  <span class="text-forge-success">+ '^@/lib/(.*)$': '&lt;rootDir&gt;/src/lib/$1'</span>
{'}'}</code></pre>

                  <div class="flex gap-2">
                    <button class="btn-primary btn-sm text-xs">
                      <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                      </svg>
                      Apply fix & re-run
                    </button>
                    <button class="btn-ghost btn-sm text-xs">Open PR</button>
                    <button class="btn-ghost btn-sm text-xs">More context</button>
                  </div>
                </div>

                <!-- Confidence -->
                <div class="flex items-center gap-2 text-xs text-forge-text-3">
                  <div class="flex gap-0.5">
                    {Array.from({length:5}).map((_, i) => (
                      <div class={`w-4 h-1.5 rounded-full ${i < 5 ? 'bg-forge-success' : 'bg-forge-border'}`}></div>
                    ))}
                  </div>
                  <span>97% confidence · Analyzed in 8.2s</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: copy -->
      <div class="order-1 lg:order-2 appear">
        <div class="inline-flex items-center gap-2 section-label mb-6">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
          </svg>
          Sherlock AI Agent
        </div>

        <h2 class="font-display font-bold text-4xl sm:text-5xl tracking-tight leading-[1.08] mb-6">
          Your build failed.
          <span class="text-forge-cyan"> Sherlock knows why.</span>
        </h2>

        <p class="text-lg text-forge-text-2 leading-relaxed mb-6">
          Stop scrolling through 2,000 log lines. One click and Sherlock reads
          your logs, your config, and your Git diff — then hands you the exact
          file, line, and fix. In seconds.
        </p>

        <ul class="space-y-4 mb-8">
          {[
            { title: 'Instant root-cause analysis', desc: 'Traces failures through logs, env vars, and config changes simultaneously.' },
            { title: 'Code-level fix suggestions', desc: 'Shows the exact diff needed to resolve the issue, not vague advice.' },
            { title: 'One-click PR creation', desc: 'Sherlock can open a pull request with the fix applied, ready for review.' },
            { title: 'Flaky test detection', desc: 'Distinguishes intermittent failures from real regressions automatically.' },
          ].map(({ title, desc }) => (
            <li class="flex gap-3">
              <div class="w-5 h-5 rounded-full bg-forge-info-bg border border-forge-cyan/30 flex items-center justify-center flex-shrink-0 mt-0.5">
                <div class="w-1.5 h-1.5 rounded-full bg-forge-cyan"></div>
              </div>
              <div>
                <div class="text-sm font-medium text-forge-text mb-0.5">{title}</div>
                <div class="text-sm text-forge-text-3">{desc}</div>
              </div>
            </li>
          ))}
        </ul>

        <div class="flex gap-3">
          <a href="/features#sherlock" class="btn-secondary btn-lg">
            Learn about Sherlock
          </a>
          <a href="/auth/signup" class="btn-ghost btn-lg text-forge-cyan hover:text-forge-cyan">
            Try it free →
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
