---

<footer class="border-t border-forge-border mt-auto" role="contentinfo">
  <!-- Main footer -->
  <div class="container-forge py-16">
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-8 lg:gap-6">

      <!-- Brand column -->
      <div class="col-span-2 md:col-span-3 lg:col-span-1 space-y-5">
        <a href="/" class="flex items-center gap-2.5 group w-fit">
          <svg width="28" height="28" viewBox="0 0 32 32" fill="none">
            <rect width="32" height="32" rx="8" fill="#C8FF00"/>
            <path d="M8 24L14 8H18L20 14L24 8H28L22 24H18L16 17L12 24H8Z" fill="#07090E"/>
            <circle cx="24" cy="8" r="2.5" fill="#07090E"/>
          </svg>
          <span class="font-display font-bold text-lg text-forge-text">
            Forge<span class="text-forge-accent">CI</span>
          </span>
        </a>

        <p class="text-sm text-forge-text-3 leading-relaxed max-w-xs">
          The fastest CI/CD platform for modern engineering teams. Build at the speed of thought.
        </p>

        <!-- Newsletter -->
        <div class="space-y-2">
          <p class="text-xs font-medium text-forge-text-2">Stay up to date</p>
          <form class="flex gap-2" onsubmit="return false;">
            <input
              type="email"
              placeholder="you@company.com"
              class="input flex-1 !py-2 !text-xs"
              aria-label="Email address"
            />
            <button type="submit" class="btn-primary btn-sm flex-shrink-0">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
              </svg>
            </button>
          </form>
          <p class="text-2xs text-forge-text-3">No spam. Unsubscribe anytime.</p>
        </div>

        <!-- Social links -->
        <div class="flex items-center gap-2">
          {social.map((s) => (
            <a
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={s.label}
              class="w-8 h-8 rounded-lg border border-forge-border bg-forge-surface flex items-center justify-center
                     text-forge-text-3 hover:text-forge-text hover:border-forge-border-2 hover:bg-forge-surface2
                     transition-all duration-150"
            >
              <Fragment set:html={s.icon} />
            </a>
          ))}
        </div>
      </div>

      <!-- Nav columns -->
      {footerNav.map((col) => (
        <div class="space-y-4">
          <h3 class="text-2xs font-mono font-medium uppercase tracking-widest text-forge-text-3">
            {col.title}
          </h3>
          <ul class="space-y-2.5">
            {col.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-forge-text-2 hover:text-forge-accent transition-colors duration-150 flex items-center gap-2"
                >
                  {link.label}
                  {link.badge && (
                    <span class="badge-accent text-2xs">{link.badge}</span>
                  )}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-forge-border">
    <div class="container-forge py-5 flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="flex flex-wrap items-center justify-center sm:justify-start gap-x-6 gap-y-2">
        <p class="text-xs text-forge-text-3">
          © {new Date().getFullYear()} Forge CI, Inc. All rights reserved.
        </p>
        <a href="/privacy" class="text-xs text-forge-text-3 hover:text-forge-text transition-colors">Privacy</a>
        <a href="/terms" class="text-xs text-forge-text-3 hover:text-forge-text transition-colors">Terms</a>
        <a href="/cookies" class="text-xs text-forge-text-3 hover:text-forge-text transition-colors">Cookies</a>
        <a href="/sla" class="text-xs text-forge-text-3 hover:text-forge-text transition-colors">SLA</a>
        <a href="/security" class="text-xs text-forge-text-3 hover:text-forge-text transition-colors">Security</a>
      </div>

      <div class="flex items-center gap-4">
        <!-- Trust badges -->
        <div class="flex items-center gap-3">
          <div class="flex items-center gap-1.5 text-2xs text-forge-text-3 border border-forge-border rounded-md px-2 py-1">
            <svg class="w-3 h-3 text-forge-success" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            SOC 2 Type II
          </div>
          <div class="flex items-center gap-1.5 text-2xs text-forge-text-3 border border-forge-border rounded-md px-2 py-1">
            <svg class="w-3 h-3 text-forge-info" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 1.944A11.954 11.954 0 012.166 5C2.056 5.649 2 6.319 2 7c0 5.225 3.34 9.67 8 11.317C14.66 16.67 18 12.225 18 7c0-.682-.057-1.35-.166-2.001A11.954 11.954 0 0110 1.944zM11 14a1 1 0 11-2 0 1 1 0 012 0zm0-7a1 1 0 10-2 0v3a1 1 0 102 0V7z" clip-rule="evenodd"/>
            </svg>
            GDPR
          </div>
          <div class="flex items-center gap-1.5 text-2xs text-forge-text-3 border border-forge-border rounded-md px-2 py-1">
            <svg class="w-3 h-3 text-forge-warning" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
            HIPAA Ready
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>
