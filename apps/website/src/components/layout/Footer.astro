---
const cols = [
  {title:'Product',   links:[{l:'Features',href:'/features'},{l:'Pricing',href:'/pricing'},{l:'Integrations',href:'/integrations'},{l:'Changelog',href:'/changelog'},{l:'Status',href:'/status'},{l:'Roadmap',href:'/roadmap'}]},
  {title:'Platform',  links:[{l:'Dashboard',href:'/dashboard'},{l:'Builds',href:'/dashboard/builds'},{l:'Registry',href:'/dashboard/registry'},{l:'Marketplace',href:'/dashboard/marketplace'},{l:'Sandboxes',href:'/dashboard/sandboxes'},{l:'Sherlock AI',href:'/dashboard/ai-agents'}]},
  {title:'Solutions', links:[{l:'Enterprise',href:'/enterprise'},{l:'Open Source',href:'/open-source'},{l:'BYOC Runners',href:'/byoc'},{l:'Security',href:'/security'},{l:'Compliance',href:'/security#compliance'},{l:'Startups',href:'/startups'}]},
  {title:'Developers',links:[{l:'Documentation',href:'/docs'},{l:'API Reference',href:'/docs/api'},{l:'CLI Reference',href:'/docs/cli'},{l:'SDKs & Libraries',href:'/docs/sdks'},{l:'Plugin SDK',href:'/docs/plugins'},{l:'GitHub',href:'https://github.com/forge-ci'}]},
  {title:'Company',   links:[{l:'About',href:'/about'},{l:'Blog',href:'/blog'},{l:'Customers',href:'/customers'},{l:'Careers',href:'/careers',badge:'Hiring'},{l:'Press',href:'/press'},{l:'Contact',href:'/contact'}]},
