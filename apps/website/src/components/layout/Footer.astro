  {l:'GitHub',   href:'https://github.com/forge-ci',icon:'M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z'},
  {l:'Twitter',  href:'https://twitter.com/forgeci', icon:'M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z'},
  {l:'Discord',  href:'https://discord.gg/forgeci', icon:'M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03z'},
];
---

<footer class="border-t-2" style="border-color:#2C2C2C;background:#0A0A0A">
  <!-- Main grid -->
  <div class="container-forge py-14">
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-8">
      <!-- Brand -->
      <div class="col-span-2 md:col-span-3 lg:col-span-1 space-y-5">
        <a href="/" class="inline-flex items-center gap-2.5">
          <svg width="28" height="28" viewBox="0 0 32 32" fill="none">
            <rect width="32" height="32" fill="#FFEE00"/>
            <path d="M8 24L14 8H18L20 14L24 8H28L22 24H18L16 17L12 24H8Z" fill="#0A0A0A"/>
            <circle cx="24" cy="8" r="2.5" fill="#0A0A0A"/>
          </svg>
          <span style="font-family:'Space Grotesk';font-weight:700;font-size:1rem;color:#F0F0F0">Forge<span style="color:#FFEE00">CI</span></span>
        </a>
        <p class="text-sm leading-relaxed" style="color:#666666">The fastest CI/CD platform for modern engineering teams.</p>

        <!-- Newsletter -->
        <div>
          <p class="text-xs font-mono font-semibold uppercase tracking-widest mb-2" style="color:#AAAAAA">Stay updated</p>
          <form class="flex gap-0" onsubmit="return false;">
            <input type="email" placeholder="you@company.com" class="input flex-1 text-xs border-r-0" style="border-radius:0"/>
            <button class="btn-primary btn-sm flex-shrink-0" style="border-radius:0">→</button>
          </form>
        </div>

        <!-- Social -->
        <div class="flex gap-2">
          {social.map(s => (
            <a href={s.href} target="_blank" rel="noopener noreferrer" aria-label={s.l}
               class="w-8 h-8 border flex items-center justify-center transition-all"
               style="border-color:#2C2C2C;background:#111111;color:#666666"
               onmouseover="this.style.borderColor='#FFEE00';this.style.color='#FFEE00'"
               onmouseout="this.style.borderColor='#2C2C2C';this.style.color='#666666'">
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d={s.icon}/></svg>
            </a>
          ))}
        </div>
      </div>

      <!-- Nav columns -->
      {cols.map(col => (
        <div>
          <h3 class="text-xs font-mono font-bold uppercase tracking-widest mb-4" style="color:#666666">{col.title}</h3>
          <ul class="space-y-2.5">
            {col.links.map(link => (
              <li>
                <a href={link.href} class="text-sm flex items-center gap-2 transition-colors duration-100"
                   style="color:#AAAAAA"
                   onmouseover="this.style.color='#FFEE00'"
                   onmouseout="this.style.color='#AAAAAA'">
                  {link.l}
                  {link.badge && <span class="badge-accent text-xs">{link.badge}</span>}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t-2" style="border-color:#2C2C2C">
    <div class="container-forge py-5 flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="flex flex-wrap items-center gap-x-5 gap-y-2 text-xs font-mono" style="color:#444444">
        <span>© {new Date().getFullYear()} Forge CI, Inc.</span>
        {['Privacy','Terms','Security','SLA','Cookies'].map(l => (
          <a href={`/${l.toLowerCase()}`} class="hover:text-[#FFEE00] transition-colors">{l}</a>
        ))}
      </div>
      <div class="flex flex-wrap gap-2">
        {['SOC 2 Type II','GDPR','HIPAA Ready','ISO 27001'].map(t => (
          <div class="flex items-center gap-1.5 text-xs font-mono border px-2 py-1"
               style="border-color:#2C2C2C;color:#666666">
            <svg class="w-3 h-3" fill="#00FF88" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            {t}
          </div>
        ))}
      </div>
    </div>
  </div>
</footer>
