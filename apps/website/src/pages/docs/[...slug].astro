---
import MarketingLayout from '../../layouts/MarketingLayout.astro';
import { DOCS, DOCS_CATEGORIES, getDocBySlug, getDocsByCategory } from '../../data/docs.ts';

export function getStaticPaths() {
  return DOCS.map(doc => ({ params: { slug: doc.slug }, props: { doc } }));
}

const { doc } = Astro.props;
const catPages = getDocsByCategory(doc.category);
const curIdx   = catPages.findIndex(p => p.slug === doc.slug);
const prev     = curIdx > 0 ? catPages[curIdx - 1] : null;
const next     = curIdx < catPages.length - 1 ? catPages[curIdx + 1] : null;

const catIcons: Record<string, string> = {
  'Getting Started': '🚀', 'Pipelines': '⚡', 'Caching': '◈',
  'Secrets': '◆', 'Observability': '◎', 'Runners': '▣', 'API Reference': '▤',
};
---
<MarketingLayout title={`${doc.title} — Forge CI Docs`} description={doc.excerpt}>
  <div class="flex pt-16 min-h-screen">

    <!-- Left sidebar -->
    <aside class="hidden lg:flex flex-col flex-shrink-0 w-60 border-r-2 pt-8 sticky top-16 h-[calc(100vh-4rem)] overflow-y-auto"
           style="border-color:#2C2C2C;background:#060606">
      <a href="/docs" class="flex items-center gap-2 px-5 pb-5 mb-2 border-b-2 text-xs font-mono" style="border-color:#2C2C2C;color:#8A8A8A">
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="square" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        All docs
      </a>

      {DOCS_CATEGORIES.map(cat => {
        const pages = getDocsByCategory(cat);
        return (
          <div class="mb-1">
            <div class="px-5 py-2 text-xs font-mono uppercase tracking-widest flex items-center gap-2" style="color:#8A8A8A">
              <span>{catIcons[cat] ?? '◌'}</span>
              {cat}
            </div>
            {pages.map(p => {
              const isActive = p.slug === doc.slug;
              return (
                <a
                  href={`/docs/${p.slug}`}
                  class="flex items-center gap-2 px-5 py-1.5 text-xs font-medium transition-all border-l-2"
                  style={isActive
                    ? 'border-left-color:#FFEE00;color:#FFEE00;background:rgba(255,238,0,0.06)'
                    : 'border-left-color:transparent;color:#8A8A8A'}
                >
                  {p.title}
                </a>
              );
            })}
          </div>
        );
      })}
    </aside>

    <!-- Main content -->
    <div class="flex-1 min-w-0 px-6 sm:px-10 lg:px-16 py-12 max-w-3xl">

      <!-- Breadcrumb -->
      <nav class="flex items-center gap-1.5 text-xs font-mono mb-8" style="color:#8A8A8A">
        <a href="/docs" style="color:#8A8A8A" class="hover:text-[#FFEE00] transition-colors">Docs</a>
        <span>›</span>
        <a href="/docs" style="color:#8A8A8A" class="hover:text-[#FFEE00] transition-colors">{doc.category}</a>
        <span>›</span>
        <span style="color:#B0B0B0">{doc.title}</span>
      </nav>

      <!-- Category badge -->
      <div class="section-label mb-5">{catIcons[doc.category] ?? ''} {doc.category}</div>

      <!-- Title -->
      <h1 class="section-title mb-4" style="font-size:clamp(1.75rem,4vw,2.5rem)">{doc.title}</h1>
      <p class="section-subtitle mb-10">{doc.excerpt}</p>

      <!-- Table of contents (inline) -->
      {doc.toc.length > 0 && (
        <div class="card p-5 mb-10">
          <div class="text-xs font-mono uppercase tracking-widest mb-3" style="color:#8A8A8A">On this page</div>
          <ul class="space-y-1.5">
            {doc.toc.map(item => (
              <li style={`padding-left:${(item.depth - 2) * 12}px`}>
                <a href={`#${item.id}`} class="text-xs font-mono hover:text-[#FFEE00] transition-colors" style="color:#8A8A8A">{item.label}</a>
              </li>
            ))}
          </ul>
        </div>
      )}

      <!-- Content: rendered as markdown-like HTML -->
      <!-- In production wire to MDX; here we render the mock content as preformatted -->
      <div class="prose-brut space-y-0 text-sm">
        {doc.content.split('\n\n').map((block, bi) => {
          const isH2 = block.startsWith('## ');
          const isH3 = block.startsWith('### ');
          const isCode = block.startsWith('```');
          const isTable = block.trim().startsWith('|');
          const isList = block.trim().startsWith('-') || block.trim().startsWith('*');

          if (isH2) return (
            <h2 id={block.slice(3).trim().toLowerCase().replace(/[^a-z0-9]+/g, '-')}
                class="text-xl font-bold mt-10 mb-4 pt-8 border-t-2"
                style="font-family:'Space Grotesk';color:#F0F0F0;border-color:#2C2C2C">
              {block.slice(3)}
            </h2>
          );
          if (isH3) return (
            <h3 id={block.slice(4).trim().toLowerCase().replace(/[^a-z0-9]+/g, '-')}
                class="text-base font-bold mt-6 mb-3"
                style="font-family:'Space Grotesk';color:#F0F0F0">
              {block.slice(4)}
            </h3>
          );
          if (isCode) return (
            <div class="terminal my-5">
              <div class="terminal-header">
                <div class="terminal-dot" style="background:#FF5F57"></div>
                <div class="terminal-dot" style="background:#FFBD2E"></div>
                <div class="terminal-dot" style="background:#28C840"></div>
              </div>
              <pre class="p-5 text-xs font-mono overflow-x-auto leading-relaxed" style="color:#B0B0B0">
                <code>{block.replace(/^```[a-z]*\n?/, '').replace(/```$/, '').trim()}</code>
              </pre>
            </div>
          );
          if (isTable) return (
            <div class="overflow-x-auto my-5">
              <table class="table-brut">
                {block.split('\n').filter(l => !l.match(/^[\|\ \-]+$/)).map((row, ri) => {
                  const cells = row.split('|').filter(c => c.trim());
                  return ri === 0
                    ? <thead><tr>{cells.map(c => <th>{c.trim()}</th>)}</tr></thead>
                    : <tbody><tr>{cells.map(c => <td>{c.trim()}</td>)}</tr></tbody>;
                })}
              </table>
            </div>
          );
          if (isList) return (
            <ul class="space-y-1.5 my-3 ml-4">
              {block.split('\n').filter(l => l.trim()).map(l => (
                <li class="flex items-start gap-2 text-sm" style="color:#B0B0B0">
                  <span style="color:#FFEE00;flex-shrink:0">→</span>
                  {l.replace(/^[-*]\s+/, '')}
                </li>
              ))}
            </ul>
          );
          return <p class="leading-relaxed my-3" style="color:#B0B0B0">{block}</p>;
        })}
      </div>

      <!-- Prev / Next navigation -->
      <div class="grid sm:grid-cols-2 gap-4 mt-16 pt-8 border-t-2" style="border-color:#2C2C2C">
        {prev ? (
          <a href={`/docs/${prev.slug}`} class="card-hover p-5 group">
            <div class="text-xs font-mono mb-2" style="color:#8A8A8A">← Previous</div>
            <div class="text-sm font-semibold group-hover:text-[#FFEE00] transition-colors" style="color:#F0F0F0">{prev.title}</div>
          </a>
        ) : <div/>}
        {next && (
          <a href={`/docs/${next.slug}`} class="card-hover p-5 group text-right">
            <div class="text-xs font-mono mb-2" style="color:#8A8A8A">Next →</div>
            <div class="text-sm font-semibold group-hover:text-[#FFEE00] transition-colors" style="color:#F0F0F0">{next.title}</div>
          </a>
        )}
      </div>
    </div>

    <!-- Right TOC sidebar (desktop) -->
    <aside class="hidden xl:flex flex-col w-52 flex-shrink-0 pt-12 px-6 sticky top-16 h-[calc(100vh-4rem)] overflow-y-auto">
      {doc.toc.length > 0 && (
        <>
          <div class="text-xs font-mono uppercase tracking-widest mb-4" style="color:#8A8A8A">On this page</div>
          <ul class="space-y-2">
            {doc.toc.map(item => (
              <li style={`padding-left:${(item.depth - 2) * 10}px`}>
                <a href={`#${item.id}`} class="text-xs font-mono hover:text-[#FFEE00] transition-colors block" style="color:#8A8A8A">{item.label}</a>
              </li>
            ))}
          </ul>
        </>
      )}

      <div class="mt-auto pt-6 border-t-2 mt-8" style="border-color:#2C2C2C">
        <a href="/auth/signup" class="btn-primary btn-sm w-full justify-center mb-2">Start free</a>
        <a href="/docs" class="btn-secondary btn-sm w-full justify-center">All docs</a>
      </div>
    </aside>
  </div>
</MarketingLayout>
