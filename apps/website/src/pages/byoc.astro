---
import MarketingLayout from '../layouts/MarketingLayout.astro';

const clouds = [
  { name:'AWS',   logo:'AW', color:'#FF9900',  desc:'EC2, EKS, Fargate, Graviton ARM64. OIDC-based auth — no long-lived credentials.' },
  { name:'GCP',   logo:'GC', color:'#4285F4',  desc:'GCE, GKE, Cloud Run. Workload Identity Federation out of the box.' },
  { name:'Azure', logo:'AZ', color:'#0078D4',  desc:'AKS, Azure VMs. Managed Identity and AD workload federation supported.' },
  { name:'On-prem',logo:'OP',color:'#10B981',  desc:'Bare metal, VMware, Proxmox, or any Linux host. Register via the runner agent.' },
];

const steps = [
  { n:'1', title:'Install the runner agent', body:'One-line install on any Linux or macOS host. Docker, systemd, or Kubernetes DaemonSet.' },
  { n:'2', title:'Register with your org', body:'Run forge runner register with your org token. The agent authenticates via mTLS.' },
  { n:'3', title:'Label your runners', body:'Tag runners by size, region, OS, or any custom label. Route jobs with runs-on:.' },
  { n:'4', title:'Build on your infrastructure', body:'Builds run exclusively on your machines. Data never leaves your network.' },
];
---

<MarketingLayout
  title="BYOC Runners — Forge CI"
  description="Bring Your Own Cloud. Run Forge CI builds on your AWS, GCP, Azure, or on-premise infrastructure. Zero data egress, full compliance."
>
  <section class="relative pt-32 pb-20 overflow-hidden">
    <div class="absolute inset-0 bg-grid opacity-25 pointer-events-none" aria-hidden="true"></div>
    <div class="container-forge relative z-10 text-center max-w-3xl mx-auto">
      <div class="section-label mb-6">BYOC Runners</div>
      <h1 class="section-title mb-6">
        Your cloud.
        <span class="text-gradient"> Our brains.</span>
      </h1>
      <p class="text-lg text-forge-text-2 mb-10 mx-auto leading-relaxed">
        Register your own EC2 instances, GKE nodes, or bare-metal machines as Forge CI runners.
        Full CI orchestration, zero data leaving your perimeter.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/docs/byoc" class="btn-primary btn-xl">Read the docs</a>
        <a href="/auth/signup?plan=team" class="btn-secondary btn-xl">Start free trial</a>
      </div>
    </div>
  </section>

  <!-- Cloud providers -->
  <section class="section border-t border-forge-border">
    <div class="container-forge">
      <h2 class="font-display font-bold text-3xl text-center text-forge-text mb-10">Works with any cloud or on-premise host</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {clouds.map(c => (
          <div class="card p-6 text-center hover:border-forge-accent/20 transition-colors">
            <div class="w-12 h-12 rounded-xl border border-forge-border flex items-center justify-center text-sm font-mono font-bold text-forge-text-2 mx-auto mb-4 bg-forge-surface3">
              {c.logo}
            </div>
            <h3 class="font-display font-bold text-lg text-forge-text mb-2">{c.name}</h3>
            <p class="text-xs text-forge-text-3 leading-relaxed">{c.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="section border-t border-forge-border bg-forge-surface/20">
    <div class="container-forge max-w-3xl">
      <h2 class="font-display font-bold text-3xl text-forge-text text-center mb-12">Set up in 4 steps</h2>
      <div class="space-y-6">
        {steps.map(({ n, title, body }) => (
          <div class="flex gap-5 items-start">
            <div class="w-10 h-10 rounded-full bg-forge-accent flex items-center justify-center font-display font-bold text-forge-bg flex-shrink-0">
              {n}
            </div>
            <div>
              <h3 class="font-display font-bold text-lg text-forge-text mb-1">{title}</h3>
              <p class="text-forge-text-2 leading-relaxed">{body}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Code snippet -->
      <div class="terminal mt-10">
        <div class="terminal-header">
          <div class="terminal-dot bg-[#FF5F57]"></div>
          <div class="terminal-dot bg-[#FFBD2E]"></div>
          <div class="terminal-dot bg-[#28C840]"></div>
          <span class="font-mono text-xs text-forge-text-3 ml-2">Install runner agent</span>
        </div>
        <pre class="p-5 font-mono text-xs text-forge-text-2 leading-relaxed overflow-x-auto"><code><span class="text-forge-text-3"># Install on any Linux host</span>
<span class="text-forge-accent">curl -sSL https://install.forge-ci.dev/runner | bash</span>

<span class="text-forge-text-3"># Register with your org</span>
<span class="text-forge-text">forge runner register \
  --org acme-corp \
  --token $FORGE_RUNNER_TOKEN \
  --labels linux,x64,large,us-west-2 \
  --concurrency 4</span>

<span class="text-forge-text-3"># Runner is now active ✓</span>
<span class="text-forge-success">✓ Runner sb-r8f2 registered and listening for jobs</span></code></pre>
      </div>
    </div>
  </section>

  <!-- Benefits -->
  <section class="section border-t border-forge-border">
    <div class="container-forge">
      <div class="grid sm:grid-cols-3 gap-6 text-center">
        {[
          { icon:'🔒', title:'Zero data egress', desc:'Source code, secrets, and artifacts stay inside your VPC. Forge CI only sends job metadata.' },
          { icon:'💸', title:'Use your existing budget', desc:'Leverages existing AWS, GCP, or Azure spend commitments. No surprise Forge CI egress bills.' },
          { icon:'⚡', title:'Full Forge CI features', desc:'Intelligent caching, matrix builds, Sherlock AI, and real-time metrics work on your runners.' },
        ].map(({ icon, title, desc }) => (
          <div class="card p-8">
            <div class="text-4xl mb-4">{icon}</div>
            <h3 class="font-display font-bold text-lg text-forge-text mb-2">{title}</h3>
            <p class="text-sm text-forge-text-2 leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</MarketingLayout>
