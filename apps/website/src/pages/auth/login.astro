---
import AuthLayout from '../../layouts/AuthLayout.astro';
---

<AuthLayout title="Sign in — Forge CI">
  <div class="max-w-sm w-full animate-slide-up">

    <!-- Heading -->
    <div class="mb-8">
      <h1 class="font-display font-bold text-3xl text-forge-text">Welcome back</h1>
      <p class="text-forge-text-2 mt-2">
        Don't have an account?
        <a href="/auth/signup" class="text-forge-accent hover:text-forge-accent-dim transition-colors font-medium ml-1">
          Sign up free
        </a>
      </p>
    </div>

    <!-- OAuth buttons -->
    <div class="space-y-2.5 mb-6">
      <button
        type="button"
        class="w-full flex items-center justify-center gap-3 px-4 py-2.5 rounded-lg border border-forge-border bg-forge-surface text-sm font-medium text-forge-text hover:bg-forge-surface2 hover:border-forge-border-2 transition-all duration-150 active:scale-[0.99]"
        onclick="handleOAuth('github')"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
        </svg>
        Continue with GitHub
      </button>

      <button
        type="button"
        class="w-full flex items-center justify-center gap-3 px-4 py-2.5 rounded-lg border border-forge-border bg-forge-surface text-sm font-medium text-forge-text hover:bg-forge-surface2 hover:border-forge-border-2 transition-all duration-150 active:scale-[0.99]"
        onclick="handleOAuth('google')"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        Continue with Google
      </button>

      <button
        type="button"
        id="sso-btn"
        class="w-full flex items-center justify-center gap-3 px-4 py-2.5 rounded-lg border border-forge-border bg-forge-surface text-sm font-medium text-forge-text-2 hover:bg-forge-surface2 hover:border-forge-border-2 transition-all duration-150 active:scale-[0.99]"
        onclick="toggleSSOInput()"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
        </svg>
        Continue with SSO
      </button>

      <!-- SSO domain input (hidden initially) -->
      <div id="sso-input" class="hidden">
        <div class="flex gap-2">
          <input
            type="text"
            id="sso-domain"
            placeholder="your-company.com"
            class="input flex-1"
            autocomplete="off"
            spellcheck="false"
          />
          <button
            type="button"
            onclick="submitSSO()"
            class="btn-primary btn-md flex-shrink-0"
          >
            Continue
          </button>
        </div>
        <p class="text-xs text-forge-text-3 mt-1.5 ml-1">Enter your organization's domain</p>
      </div>
    </div>

    <!-- Divider -->
    <div class="relative mb-6">
      <div class="absolute inset-0 flex items-center" aria-hidden="true">
        <div class="w-full border-t border-forge-border"></div>
      </div>
      <div class="relative flex justify-center text-xs">
        <span class="bg-forge-bg px-3 text-forge-text-3">or continue with email</span>
      </div>
    </div>

    <!-- Email / password form -->
    <form id="login-form" class="space-y-4" novalidate>
      <div>
        <label class="input-label" for="email">Work email</label>
        <input
          type="email"
          id="email"
          name="email"
          class="input"
          placeholder="you@company.com"
          autocomplete="email"
          required
        />
      </div>

      <div>
        <div class="flex items-center justify-between mb-1.5">
          <label class="input-label !mb-0" for="password">Password</label>
          <a href="/auth/forgot-password" class="text-xs text-forge-text-3 hover:text-forge-accent transition-colors">
            Forgot password?
          </a>
        </div>
        <div class="relative">
          <input
            type="password"
            id="password"
            name="password"
            class="input !pr-11"
            placeholder="••••••••••••"
            autocomplete="current-password"
            required
          />
          <button
            type="button"
            id="toggle-pw"
            class="absolute right-3 top-1/2 -translate-y-1/2 text-forge-text-3 hover:text-forge-text transition-colors"
            aria-label="Toggle password visibility"
          >
            <svg id="eye-open" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
            </svg>
            <svg id="eye-closed" class="w-4 h-4 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/>
            </svg>
          </button>
        </div>
      </div>

      <!-- Error state -->
      <div id="login-error" class="hidden rounded-lg bg-forge-danger-bg border border-forge-danger/30 px-4 py-3 text-sm text-forge-danger" role="alert">
        Invalid email or password. <a href="/auth/forgot-password" class="underline">Reset your password?</a>
      </div>

      <!-- Submit -->
      <button type="submit" class="btn-primary btn-md w-full justify-center" id="submit-btn">
        Sign in
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </button>
    </form>

    <!-- MFA panel (shown after email/pw success) -->
    <div id="mfa-panel" class="hidden mt-6">
      <div class="p-5 rounded-xl border border-forge-border bg-forge-surface2/50">
        <h2 class="font-medium text-forge-text mb-1">Two-factor authentication</h2>
        <p class="text-sm text-forge-text-3 mb-4">Enter the 6-digit code from your authenticator app.</p>
        <div class="flex gap-2 mb-4">
          {Array.from({length: 6}).map((_, i) => (
            <input
              type="text"
              maxlength="1"
              inputmode="numeric"
              pattern="[0-9]"
              class="w-10 h-12 rounded-lg border border-forge-border bg-forge-surface text-center text-lg font-mono text-forge-text focus:border-forge-accent focus:shadow-input outline-none transition-all"
              data-mfa-digit
              aria-label={`Digit ${i + 1}`}
            />
          ))}
        </div>
        <button class="btn-primary btn-md w-full justify-center">Verify</button>
        <button class="btn-ghost btn-sm w-full justify-center mt-2 text-forge-text-3">
          Use a backup code instead
        </button>
      </div>
    </div>

    <!-- Footer links -->
    <div class="mt-8 pt-6 border-t border-forge-border">
      <p class="text-xs text-forge-text-3 text-center">
        By signing in you agree to our
        <a href="/terms" class="hover:text-forge-accent transition-colors">Terms of Service</a>
        and
        <a href="/privacy" class="hover:text-forge-accent transition-colors">Privacy Policy</a>.
      </p>
    </div>
  </div>
</AuthLayout>

<script>
  // OAuth handler
  function handleOAuth(provider: string) {
    console.log('OAuth:', provider);
    // In production: window.location.href = `/api/auth/${provider}`;
  }

  // SSO toggle
  function toggleSSOInput() {
    const el = document.getElementById('sso-input')!;
    el.classList.toggle('hidden');
    if (!el.classList.contains('hidden')) {
      (document.getElementById('sso-domain') as HTMLInputElement)?.focus();
    }
  }

  function submitSSO() {
    const domain = (document.getElementById('sso-domain') as HTMLInputElement)?.value.trim();
    if (domain) {
      console.log('SSO for domain:', domain);
      // window.location.href = `/api/auth/sso?domain=${encodeURIComponent(domain)}`;
    }
  }

  // Make these global for inline onclick
  (window as any).handleOAuth = handleOAuth;
  (window as any).toggleSSOInput = toggleSSOInput;
  (window as any).submitSSO = submitSSO;

  // Password toggle
  const togglePw = document.getElementById('toggle-pw')!;
  const pwInput = document.getElementById('password') as HTMLInputElement;
  const eyeOpen = document.getElementById('eye-open')!;
  const eyeClosed = document.getElementById('eye-closed')!;

  togglePw?.addEventListener('click', () => {
    const shown = pwInput.type === 'text';
    pwInput.type = shown ? 'password' : 'text';
    eyeOpen.classList.toggle('hidden', !shown);
    eyeClosed.classList.toggle('hidden', shown);
  });

  // Form submit
  const form = document.getElementById('login-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn')!;
  const errorEl = document.getElementById('login-error')!;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.textContent = 'Signing in…';
    submitBtn.setAttribute('disabled', 'true');
    errorEl.classList.add('hidden');

    // Simulate auth call
    await new Promise(r => setTimeout(r, 1200));

    // Demo: show error for wrong creds, success redirect for anything else
    const email = (form.querySelector('#email') as HTMLInputElement).value;
    if (email === 'wrong@example.com') {
      errorEl.classList.remove('hidden');
      submitBtn.textContent = 'Sign in';
      submitBtn.removeAttribute('disabled');
    } else {
      // Redirect to dashboard
      window.location.href = '/dashboard';
    }
  });

  // MFA digit navigation
  const mfaDigits = document.querySelectorAll<HTMLInputElement>('[data-mfa-digit]');
  mfaDigits.forEach((input, idx) => {
    input.addEventListener('input', () => {
      if (input.value && idx < mfaDigits.length - 1) {
        mfaDigits[idx + 1].focus();
      }
    });
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Backspace' && !input.value && idx > 0) {
        mfaDigits[idx - 1].focus();
      }
    });
  });
</script>
