---
import AuthLayout from '../../layouts/AuthLayout.astro';
---
<AuthLayout title="Sign in — Forge CI">
<div class="max-w-sm w-full">
  <div class="mb-8">
    <a href="/" class="inline-flex items-center gap-2.5 mb-8 group">
      <svg width="28" height="28" viewBox="0 0 32 32" fill="none"><rect width="32" height="32" fill="#FFEE00"/><path d="M8 24L14 8H18L20 14L24 8H28L22 24H18L16 17L12 24H8Z" fill="#0A0A0A"/><circle cx="24" cy="8" r="2.5" fill="#0A0A0A"/></svg>
      <span style="font-family:'Space Grotesk';font-weight:700;font-size:1.1rem;color:#F0F0F0">Forge<span style="color:#FFEE00">CI</span></span>
    </a>
    <h1 style="font-family:'Space Grotesk';font-weight:700;font-size:1.875rem;letter-spacing:-0.04em;color:#F0F0F0;line-height:1.0" class="mb-2">Welcome back</h1>
    <p class="text-sm" style="color:#AAAAAA">New here? <a href="/auth/signup" style="color:#FFEE00;font-weight:600">Create an account →</a></p>
  </div>

  <!-- OAuth + social -->
  <div class="space-y-2 mb-6">
    {[
      {p:'github',    label:'Continue with GitHub',    bg:'#161B22', svg:'M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z'},
      {p:'google',    label:'Continue with Google',    bg:'#1A1A1A', google:true},
      {p:'microsoft', label:'Continue with Microsoft', bg:'#1A1A1A', ms:true},
    ].map(item => (
      <a href={`/api/auth/ory?provider=${item.p}&flow=login`}
         class="w-full flex items-center justify-center gap-3 px-4 py-2.5 text-sm font-semibold border-2 transition-all"
         style={`background:${item.bg};border-color:#3C3C3C;color:#F0F0F0`}
         onmouseover="this.style.borderColor='#FFEE00';this.style.color='#FFEE00'"
         onmouseout="this.style.borderColor='#3C3C3C';this.style.color='#F0F0F0'">
        {item.svg && <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d={item.svg}/></svg>}
        {item.google && (
          <svg width="16" height="16" viewBox="0 0 24 24">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
        )}
        {item.ms && (
          <svg width="16" height="16" viewBox="0 0 23 23">
            <path fill="#f35325" d="M1 1h10v10H1z"/><path fill="#81bc06" d="M12 1h10v10H12z"/>
            <path fill="#05a6f0" d="M1 12h10v10H1z"/><path fill="#ffba08" d="M12 12h10v10H12z"/>
          </svg>
        )}
        {item.label}
      </a>
    ))}

    <!-- Passkey -->
    <button id="passkey-btn" type="button"
            class="w-full flex items-center justify-center gap-3 px-4 py-2.5 text-sm font-semibold border-2 transition-all"
            style="background:#1A1A1A;border-color:#3C3C3C;color:#AAAAAA"
            onmouseover="this.style.borderColor='#FFEE00';this.style.color='#FFEE00'"
            onmouseout="this.style.borderColor='#3C3C3C';this.style.color='#AAAAAA'">
      <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="square" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/></svg>
      Sign in with passkey / hardware key
    </button>
  </div>

  <!-- Divider -->
  <div class="relative mb-5">
    <div class="absolute inset-0 flex items-center"><div class="w-full border-t-2" style="border-color:#2C2C2C"></div></div>
    <div class="relative flex justify-center"><span class="px-3 text-xs font-mono" style="background:#0A0A0A;color:#666666">OR</span></div>
  </div>

  <!-- SSO input -->
  <div class="mb-5">
    <button id="sso-toggle" class="w-full flex items-center justify-between px-4 py-2.5 text-sm border-2 mb-2 transition-all"
            style="background:#1A1A1A;border-color:#2C2C2C;color:#AAAAAA"
            onmouseover="this.style.borderColor='#FFEE00'"
            onmouseout="this.style.borderColor='#2C2C2C'">
      <span class="flex items-center gap-2 font-semibold">
        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-width="1.75" stroke-linecap="square" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
        Continue with SSO / SAML
      </span>
      <svg id="sso-chevron" width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="transition:transform 0.15s"><path stroke-width="2.5" d="M19 9l-7 7-7-7"/></svg>
    </button>
    <div id="sso-form" class="hidden">
      <div class="flex gap-0 border-2" style="border-color:#3C3C3C">
        <span class="input-addon">@</span>
        <input type="text" id="sso-domain" placeholder="yourcompany.com" class="input border-0" style="border-radius:0" autocomplete="off" spellcheck="false"/>
        <button id="sso-submit" class="btn-primary btn-sm flex-shrink-0" style="border-radius:0">→</button>
      </div>
      <p class="text-xs font-mono mt-1.5" style="color:#666666">We'll redirect you to your identity provider</p>
    </div>
  </div>

  <!-- Email/password -->
  <form id="login-form" class="space-y-4" novalidate autocomplete="on">
    <input type="hidden" id="csrf-token" name="csrf_token"/>
    <div>
      <label class="input-label" for="identifier">Work email</label>
      <input type="email" id="identifier" name="identifier" class="input" placeholder="you@company.com" autocomplete="email" required/>
    </div>
    <div>
      <div class="flex items-center justify-between mb-1.5">
        <label class="input-label !mb-0" for="password">Password</label>
        <a href="/auth/forgot-password" class="text-xs font-mono font-bold" style="color:#FFEE00">Forgot?</a>
      </div>
      <div class="relative">
        <input type="password" id="password" name="password" class="input pr-10" placeholder="••••••••••••" autocomplete="current-password" required/>
        <button type="button" id="pw-toggle" class="absolute right-3 top-1/2 -translate-y-1/2" style="color:#666666">
          <svg id="eye-show" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-width="1.5" stroke-linecap="square" d="M15 12a3 3 0 11-6 0 3 3 0 016 0zM2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
          <svg id="eye-hide" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="hidden"><path stroke-width="1.5" stroke-linecap="square" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/></svg>
        </button>
      </div>
    </div>

    <div id="form-error" class="hidden px-3 py-2.5 border-2 text-xs font-mono" style="background:rgba(255,51,51,0.08);border-color:#FF3333;color:#FF3333"></div>

    <button type="submit" id="submit-btn" class="btn-primary btn-md w-full justify-center">
      Sign in
      <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="square" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
    </button>

    <!-- Magic link option -->
    <button type="button" id="magic-link-btn" class="btn-ghost btn-sm w-full justify-center text-xs font-mono" style="color:#666666">
      Send me a magic link instead
    </button>
  </form>

  <!-- Magic link sent confirmation -->
  <div id="magic-link-sent" class="hidden mt-4 card p-4 card-green">
    <div class="text-xs font-mono font-bold uppercase" style="color:#00FF88">✓ Magic link sent!</div>
    <p class="text-xs mt-1.5" style="color:#AAAAAA">Check your inbox at <span id="magic-email" class="font-mono" style="color:#F0F0F0"></span>. Expires in 10 minutes.</p>
  </div>

  <!-- MFA panel -->
  <div id="mfa-panel" class="hidden mt-5">
    <div class="card card-accent p-5">
      <div class="text-xs font-mono font-bold uppercase tracking-widest mb-1" style="color:#FFEE00">⬡ 2-Factor Auth Required</div>
      <p class="text-xs mb-4" style="color:#AAAAAA">Enter the 6-digit code from your authenticator app.</p>
      <div class="flex gap-2 mb-4">
        {Array.from({length:6}).map((_, i) => (
          <input type="text" maxlength="1" inputmode="numeric" pattern="[0-9]"
            class="w-10 h-12 text-center text-xl font-mono font-bold border-2 outline-none transition-all"
            style="background:#1A1A1A;border-color:#3C3C3C;color:#F0F0F0"
            data-mfa-digit aria-label={`Digit ${i+1}`}/>
        ))}
      </div>
      <button id="totp-submit" class="btn-primary btn-md w-full justify-center">Verify →</button>
      <div class="flex gap-4 mt-3 justify-center">
        <button id="use-backup" class="btn-ghost btn-xs font-mono" style="color:#666666">Use backup code</button>
        <button id="use-webauthn" class="btn-ghost btn-xs font-mono" style="color:#666666">Use hardware key</button>
      </div>
    </div>
    <div id="backup-panel" class="hidden mt-3 card p-4">
      <label class="input-label">Backup recovery code</label>
      <input type="text" id="backup-code" class="input input-mono mb-3" placeholder="XXXX-XXXX-XXXX" autocomplete="one-time-code"/>
      <button class="btn-secondary btn-md w-full">Use code</button>
    </div>
  </div>

  <div class="mt-6 pt-5 border-t-2" style="border-color:#2C2C2C">
    <p class="text-xs text-center font-mono" style="color:#444444">
      By signing in you agree to our <a href="/terms" style="color:#FFEE00">Terms</a> and <a href="/privacy" style="color:#FFEE00">Privacy</a>.
    </p>
  </div>
</div>
</AuthLayout>

<script>
  const KRATOS = '';  // set via env in production — empty = demo mode

  // Password toggle
  const pwInput = document.getElementById('password') as HTMLInputElement;
  document.getElementById('pw-toggle')?.addEventListener('click', () => {
    const v = pwInput.type === 'text';
    pwInput.type = v ? 'password' : 'text';
    document.getElementById('eye-show')!.classList.toggle('hidden', !v);
    document.getElementById('eye-hide')!.classList.toggle('hidden', v);
  });

  // SSO
  const ssoToggle  = document.getElementById('sso-toggle')!;
  const ssoForm    = document.getElementById('sso-form')!;
  const ssoChevron = document.getElementById('sso-chevron')!;
  ssoToggle.addEventListener('click', () => {
    ssoForm.classList.toggle('hidden');
    ssoChevron.style.transform = ssoForm.classList.contains('hidden') ? '' : 'rotate(180deg)';
    if (!ssoForm.classList.contains('hidden')) (document.getElementById('sso-domain') as HTMLInputElement).focus();
  });
  document.getElementById('sso-submit')?.addEventListener('click', () => {
    const d = (document.getElementById('sso-domain') as HTMLInputElement).value.trim();
    if (d) window.location.href = `/api/auth/ory/sso?domain=${encodeURIComponent(d)}`;
  });

  // Form
  const form = document.getElementById('login-form') as HTMLFormElement;
  const btn  = document.getElementById('submit-btn') as HTMLButtonElement;
  const errEl = document.getElementById('form-error')!;
  const showErr = (m: string) => { errEl.textContent = m; errEl.classList.remove('hidden'); };

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.innerHTML = 'Signing in…'; btn.disabled = true;
    errEl.classList.add('hidden');
    const email = (form.querySelector('#identifier') as HTMLInputElement).value;
    const pw    = (form.querySelector('#password') as HTMLInputElement).value;
    const csrf  = (form.querySelector('#csrf-token') as HTMLInputElement).value;

    try {
      if (KRATOS) {
        const res = await fetch(`${KRATOS}/self-service/login`, {
          method: 'POST', credentials: 'include',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify({ method: 'password', identifier: email, password: pw, csrf_token: csrf }),
        });
        const data = await res.json();
        if (res.ok) { window.location.href = '/dashboard'; return; }
        if (res.status === 422 && data.redirect_browser_to) { window.location.href = data.redirect_browser_to; return; }
        showErr(data.ui?.messages?.[0]?.text ?? 'Invalid credentials.');
      } else {
        // Demo mode
        await new Promise(r => setTimeout(r, 700));
        if (email) window.location.href = '/dashboard';
        else showErr('Please enter your email address.');
      }
    } catch { showErr('Network error. Please try again.'); }
    finally { btn.innerHTML = 'Sign in <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="square" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>'; btn.disabled = false; }
  });

  // Magic link
  document.getElementById('magic-link-btn')?.addEventListener('click', async () => {
    const email = (form.querySelector('#identifier') as HTMLInputElement).value.trim();
    if (!email) { showErr('Enter your email first.'); return; }
    document.getElementById('magic-email')!.textContent = email;
    document.getElementById('magic-link-sent')!.classList.remove('hidden');
    form.classList.add('opacity-40', 'pointer-events-none');
  });

  // Passkey
  document.getElementById('passkey-btn')?.addEventListener('click', async () => {
    if (!window.PublicKeyCredential) { alert('WebAuthn is not supported in this browser.'); return; }
    alert('In production: Ory Kratos triggers WebAuthn credential assertion here.');
  });

  // TOTP digits
  const digits = Array.from(document.querySelectorAll<HTMLInputElement>('[data-mfa-digit]'));
  digits.forEach((inp, i) => {
    inp.addEventListener('focus', () => inp.style.borderColor = '#FFEE00');
    inp.addEventListener('blur',  () => inp.style.borderColor = '#3C3C3C');
    inp.addEventListener('input', () => {
      inp.value = inp.value.slice(-1).replace(/\D/, '');
      if (inp.value && i < digits.length - 1) digits[i+1].focus();
      if (digits.map(d => d.value).join('').length === 6) document.getElementById('totp-submit')?.click();
    });
    inp.addEventListener('keydown', (e: KeyboardEvent) => { if (e.key === 'Backspace' && !inp.value && i > 0) digits[i-1].focus(); });
  });

  document.getElementById('totp-submit')?.addEventListener('click', async () => {
    const code = digits.map(d => d.value).join('');
    if (code.length < 6) return;
    await new Promise(r => setTimeout(r, 500));
    window.location.href = '/dashboard'; // demo
  });

  document.getElementById('use-backup')?.addEventListener('click', () => {
    document.getElementById('backup-panel')?.classList.toggle('hidden');
  });
</script>
