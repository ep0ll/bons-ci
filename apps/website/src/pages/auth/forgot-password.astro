---
import AuthLayout from '../../layouts/AuthLayout.astro';
---

<AuthLayout title="Reset your password — Forge CI">
  <div class="max-w-sm w-full animate-slide-up">

    <div class="mb-8">
      <a href="/auth/login" class="inline-flex items-center gap-2 text-sm text-forge-text-2 hover:text-forge-text transition-colors mb-6">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Back to sign in
      </a>
      <h1 class="font-display font-bold text-3xl text-forge-text">Reset your password</h1>
      <p class="text-forge-text-2 mt-2 text-sm leading-relaxed">
        Enter your work email and we'll send you a link to reset your password. The link expires in 30 minutes.
      </p>
    </div>

    <!-- Step 1: Email entry -->
    <div id="step-email">
      <form id="reset-form" class="space-y-4" novalidate>
        <div>
          <label class="input-label" for="reset-email">Work email</label>
          <input
            type="email"
            id="reset-email"
            class="input"
            placeholder="you@company.com"
            autocomplete="email"
            required
          />
        </div>

        <div id="email-error" class="hidden rounded-lg bg-forge-danger-bg border border-forge-danger/30 px-4 py-3 text-sm text-forge-danger" role="alert">
          We couldn't find an account with that email.
          <a href="/auth/signup" class="underline ml-1">Create one?</a>
        </div>

        <button type="submit" class="btn-primary btn-md w-full justify-center" id="reset-btn">
          Send reset link
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
        </button>
      </form>

      <div class="mt-6 pt-5 border-t border-forge-border">
        <p class="text-xs text-forge-text-3 text-center">
          If your account uses SSO, sign in through your identity provider instead.
          <a href="/auth/login" class="text-forge-accent hover:underline ml-1">Back to sign in</a>
        </p>
      </div>
    </div>

    <!-- Step 2: Sent confirmation (hidden initially) -->
    <div id="step-sent" class="hidden text-center">
      <div class="w-16 h-16 rounded-2xl bg-forge-success-bg border border-forge-success/30 flex items-center justify-center mx-auto mb-6">
        <svg class="w-8 h-8 text-forge-success" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
      </div>
      <h2 class="font-display font-bold text-2xl text-forge-text mb-3">Check your email</h2>
      <p class="text-sm text-forge-text-2 mb-1">We sent a reset link to</p>
      <p class="font-medium text-forge-accent mb-6" id="sent-to-email"></p>
      <p class="text-xs text-forge-text-3 mb-6 leading-relaxed">
        The link expires in 30 minutes. If you don't see it, check your spam folder.
      </p>
      <button id="resend-btn" class="btn-secondary btn-md w-full justify-center">
        Resend reset email
      </button>
      <a href="/auth/login" class="btn-ghost btn-md w-full justify-center mt-2 text-forge-text-3">
        Back to sign in
      </a>
    </div>

  </div>
</AuthLayout>

<script>
  const form = document.getElementById('reset-form') as HTMLFormElement;
  const btn = document.getElementById('reset-btn') as HTMLButtonElement;
  const errorEl = document.getElementById('email-error')!;
  const stepEmail = document.getElementById('step-email')!;
  const stepSent = document.getElementById('step-sent')!;
  const sentTo = document.getElementById('sent-to-email')!;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = (document.getElementById('reset-email') as HTMLInputElement).value.trim();
    if (!email) return;

    btn.textContent = 'Sending…';
    btn.setAttribute('disabled', 'true');
    errorEl.classList.add('hidden');

    await new Promise(r => setTimeout(r, 1200));

    // Demo: show error for unknown email
    if (email === 'unknown@example.com') {
      errorEl.classList.remove('hidden');
      btn.textContent = 'Send reset link';
      btn.removeAttribute('disabled');
      return;
    }

    sentTo.textContent = email;
    stepEmail.classList.add('hidden');
    stepSent.classList.remove('hidden');
  });

  document.getElementById('resend-btn')?.addEventListener('click', async () => {
    const resendBtn = document.getElementById('resend-btn') as HTMLButtonElement;
    resendBtn.textContent = 'Sent!';
    resendBtn.setAttribute('disabled', 'true');
    await new Promise(r => setTimeout(r, 2000));
    resendBtn.textContent = 'Resend reset email';
    resendBtn.removeAttribute('disabled');
  });
</script>
