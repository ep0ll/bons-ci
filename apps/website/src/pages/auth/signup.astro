---
import AuthLayout from '../../layouts/AuthLayout.astro';
---

<AuthLayout title="Create your account — Forge CI">
  <div class="max-w-sm w-full animate-slide-up">

    <!-- Step indicator -->
    <div class="mb-8">
      <div class="flex items-center gap-2 mb-6" id="step-indicator" aria-label="Step progress">
        {[1,2,3].map((n) => (
          <div class="flex items-center gap-2">
            <div
              class={`step-dot w-7 h-7 rounded-full flex items-center justify-center text-xs font-mono font-bold border transition-all duration-300 ${
                n === 1
                  ? 'bg-forge-accent border-forge-accent text-forge-bg'
                  : 'bg-transparent border-forge-border text-forge-text-3'
              }`}
              data-step={n}
            >
              {n}
            </div>
            {n < 3 && <div class={`step-line h-px flex-1 w-8 transition-colors duration-500 ${n === 1 ? 'bg-forge-border' : 'bg-forge-border'}`} data-line={n}></div>}
          </div>
        ))}
        <span class="ml-1 text-xs text-forge-text-3" id="step-label">Your account</span>
      </div>

      <h1 class="font-display font-bold text-3xl text-forge-text" id="step-title">Create your account</h1>
      <p class="text-forge-text-2 mt-2" id="step-desc">
        Already have an account?
        <a href="/auth/login" class="text-forge-accent hover:text-forge-accent-dim transition-colors font-medium ml-1">Sign in</a>
      </p>
    </div>

    <!-- ── STEP 1: Account details ─────────────────── -->
    <div id="step-1" class="space-y-4">

      <!-- OAuth quick signup -->
      <div class="space-y-2 mb-5">
        <button type="button" class="w-full flex items-center justify-center gap-3 px-4 py-2.5 rounded-lg border border-forge-border bg-forge-surface text-sm font-medium text-forge-text hover:bg-forge-surface2 transition-all">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
          Sign up with GitHub
        </button>
        <button type="button" class="w-full flex items-center justify-center gap-3 px-4 py-2.5 rounded-lg border border-forge-border bg-forge-surface text-sm font-medium text-forge-text hover:bg-forge-surface2 transition-all">
          <svg class="w-4 h-4" viewBox="0 0 24 24">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          Sign up with Google
        </button>
      </div>

      <div class="relative mb-5">
        <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-forge-border"></div></div>
        <div class="relative flex justify-center text-xs"><span class="bg-forge-bg px-3 text-forge-text-3">or with email</span></div>
      </div>

      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="input-label" for="first-name">First name</label>
          <input type="text" id="first-name" class="input" placeholder="Ada" autocomplete="given-name" required />
        </div>
        <div>
          <label class="input-label" for="last-name">Last name</label>
          <input type="text" id="last-name" class="input" placeholder="Lovelace" autocomplete="family-name" required />
        </div>
      </div>

      <div>
        <label class="input-label" for="email">Work email</label>
        <input type="email" id="signup-email" class="input" placeholder="ada@company.com" autocomplete="email" required />
      </div>

      <div>
        <label class="input-label" for="signup-password">Password</label>
        <div class="relative">
          <input type="password" id="signup-password" class="input !pr-11" placeholder="Min. 12 characters" required minlength="12" />
          <div id="pw-strength" class="absolute right-3 top-1/2 -translate-y-1/2 text-xs font-mono"></div>
        </div>
        <!-- Strength bar -->
        <div class="flex gap-1 mt-1.5">
          {Array.from({length:4}).map((_, i) => (
            <div class="h-1 flex-1 rounded-full bg-forge-surface2 overflow-hidden">
              <div class={`h-full rounded-full transition-all duration-300 pw-bar-${i}`} style="width: 0%"></div>
            </div>
          ))}
        </div>
      </div>

      <button type="button" onclick="nextStep(2)" class="btn-primary btn-md w-full justify-center mt-2">
        Continue
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </button>

      <p class="text-xs text-forge-text-3 text-center">
        By signing up you agree to our
        <a href="/terms" class="hover:text-forge-accent transition-colors">Terms</a>
        and
        <a href="/privacy" class="hover:text-forge-accent transition-colors">Privacy Policy</a>.
      </p>
    </div>

    <!-- ── STEP 2: Organization ───────────────────── -->
    <div id="step-2" class="space-y-4 hidden">

      <div>
        <label class="input-label" for="org-name">Organization name</label>
        <input type="text" id="org-name" class="input" placeholder="Acme Corp" required />
        <p class="text-xs text-forge-text-3 mt-1">This is the name your team will see on Forge CI.</p>
      </div>

      <div>
        <label class="input-label" for="org-slug">Organization URL</label>
        <div class="flex items-center gap-0 border border-forge-border rounded-lg overflow-hidden focus-within:border-forge-accent focus-within:shadow-input transition-all">
          <span class="px-3 py-2.5 bg-forge-surface2 text-forge-text-3 text-sm border-r border-forge-border flex-shrink-0 font-mono">
            forge-ci.dev/
          </span>
          <input
            type="text"
            id="org-slug"
            class="flex-1 px-3 py-2.5 bg-forge-surface text-forge-text text-sm outline-none font-mono"
            placeholder="acme-corp"
            pattern="[a-z0-9-]+"
          />
        </div>
        <div id="slug-status" class="text-xs mt-1 flex items-center gap-1"></div>
      </div>

      <div>
        <label class="input-label" for="team-size">Team size</label>
        <select id="team-size" class="input">
          <option value="">Select team size…</option>
          <option value="1">Just me</option>
          <option value="2-5">2–5 people</option>
          <option value="6-20">6–20 people</option>
          <option value="21-100">21–100 people</option>
          <option value="101+">101+ people</option>
        </select>
      </div>

      <div>
        <label class="input-label" for="use-case">Primary use case</label>
        <select id="use-case" class="input">
          <option value="">Select primary use case…</option>
          <option value="web">Web application CI/CD</option>
          <option value="mobile">Mobile app build &amp; test</option>
          <option value="ml">ML model training &amp; deployment</option>
          <option value="infra">Infrastructure as code</option>
          <option value="oss">Open source project</option>
          <option value="other">Other</option>
        </select>
      </div>

      <div class="flex gap-3 pt-2">
        <button type="button" onclick="nextStep(1)" class="btn-secondary btn-md flex-1 justify-center">
          Back
        </button>
        <button type="button" onclick="nextStep(3)" class="btn-primary btn-md flex-1 justify-center">
          Continue →
        </button>
      </div>
    </div>

    <!-- ── STEP 3: Plan selection ──────────────────── -->
    <div id="step-3" class="hidden">

      <div class="space-y-3 mb-6">
        {[
          { id: 'hobby', name: 'Hobby', price: 'Free', desc: '2,000 build mins/mo · 1 concurrent', recommended: false },
          { id: 'pro', name: 'Pro', price: '$29/user/mo', desc: '20,000 mins · 10 concurrent · macOS runners', recommended: false },
          { id: 'team', name: 'Team', price: '$79/user/mo', desc: '100k mins · 50 concurrent · SSO · AI agent', recommended: true },
        ].map(({ id, name, price, desc, recommended }) => (
          <label
            class={`flex items-center gap-4 p-4 rounded-xl border cursor-pointer transition-all duration-150 ${
              recommended ? 'border-forge-accent/40 bg-forge-accent-muted/20' : 'border-forge-border hover:border-forge-border-2'
            }`}
          >
            <input
              type="radio"
              name="plan"
              value={id}
              checked={recommended}
              class="sr-only peer"
            />
            <div class="w-4 h-4 rounded-full border-2 border-forge-border peer-checked:border-forge-accent flex-shrink-0 flex items-center justify-center transition-colors">
              <div class="w-2 h-2 rounded-full bg-forge-accent opacity-0 peer-checked:opacity-100 transition-opacity plan-dot"></div>
            </div>
            <div class="flex-1">
              <div class="flex items-center gap-2">
                <span class="text-sm font-medium text-forge-text">{name}</span>
                {recommended && <span class="badge-accent text-2xs">Recommended</span>}
              </div>
              <div class="text-xs text-forge-text-3 mt-0.5">{desc}</div>
            </div>
            <div class="text-sm font-mono font-bold text-forge-text">{price}</div>
          </label>
        ))}
      </div>

      <p class="text-xs text-forge-text-3 mb-4">
        ✓ 14-day free trial on Pro & Team · No credit card required · Cancel anytime
      </p>

      <div class="flex gap-3">
        <button type="button" onclick="nextStep(2)" class="btn-secondary btn-md flex-shrink-0 justify-center px-4">
          Back
        </button>
        <button type="button" onclick="createAccount()" class="btn-primary btn-md flex-1 justify-center" id="create-btn">
          Create account
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- ── STEP 4: Email verification ─────────────── -->
    <div id="step-4" class="hidden text-center">
      <div class="w-16 h-16 rounded-2xl bg-forge-accent-muted border border-forge-accent/30 flex items-center justify-center mx-auto mb-6">
        <svg class="w-8 h-8 text-forge-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
      </div>

      <h2 class="font-display font-bold text-2xl text-forge-text mb-3">Check your inbox</h2>
      <p class="text-forge-text-2 text-sm mb-6 leading-relaxed">
        We sent a verification link to <strong id="verify-email" class="text-forge-text">your email</strong>.
        Click the link to activate your account.
      </p>

      <div class="space-y-3">
        <a href="/dashboard/onboarding" class="btn-primary btn-md w-full justify-center">
          I've verified my email →
        </a>
        <button type="button" class="btn-ghost btn-sm w-full justify-center text-forge-text-3">
          Resend verification email
        </button>
      </div>

      <p class="text-xs text-forge-text-3 mt-6">
        Wrong email? <button class="text-forge-accent hover:underline" onclick="nextStep(1)">Go back</button>
      </p>
    </div>

  </div>
</AuthLayout>

<script>
  const stepLabels = ['', 'Your account', 'Organization', 'Choose plan', 'Verify email'];
  const stepTitles = ['', 'Create your account', 'Set up your org', 'Pick a plan', 'Almost there!'];
  const stepDescs  = ['', '', 'Tell us about your team.', 'Start with a 14-day free trial.', ''];

  function nextStep(n: number) {
    // Hide all steps
    [1,2,3,4].forEach(i => {
      document.getElementById(`step-${i}`)?.classList.add('hidden');
    });
    document.getElementById(`step-${n}`)?.classList.remove('hidden');

    // Update step indicator
    document.querySelectorAll<HTMLElement>('.step-dot').forEach((dot, idx) => {
      const stepNum = idx + 1;
      if (stepNum < n) {
        dot.className = 'step-dot w-7 h-7 rounded-full flex items-center justify-center text-xs font-mono font-bold border transition-all duration-300 bg-forge-success border-forge-success text-forge-bg';
        dot.innerHTML = '✓';
      } else if (stepNum === n) {
        dot.className = 'step-dot w-7 h-7 rounded-full flex items-center justify-center text-xs font-mono font-bold border transition-all duration-300 bg-forge-accent border-forge-accent text-forge-bg';
        dot.textContent = String(stepNum);
      } else {
        dot.className = 'step-dot w-7 h-7 rounded-full flex items-center justify-center text-xs font-mono font-bold border transition-all duration-300 bg-transparent border-forge-border text-forge-text-3';
        dot.textContent = String(stepNum);
      }
    });

    // Update header text
    const label = document.getElementById('step-label');
    const title = document.getElementById('step-title');
    const desc  = document.getElementById('step-desc');
    if (label) label.textContent = stepLabels[n] ?? '';
    if (title) title.textContent = stepTitles[n] ?? '';
    if (desc && stepDescs[n]) desc.textContent = stepDescs[n];
  }

  async function createAccount() {
    const btn = document.getElementById('create-btn')!;
    btn.textContent = 'Creating account…';
    btn.setAttribute('disabled', 'true');

    await new Promise(r => setTimeout(r, 1500));

    const email = (document.getElementById('signup-email') as HTMLInputElement)?.value;
    const verifyEl = document.getElementById('verify-email');
    if (verifyEl) verifyEl.textContent = email || 'your email';

    nextStep(4);
  }

  // Slug validation (debounced)
  const slugInput = document.getElementById('org-slug') as HTMLInputElement;
  const slugStatus = document.getElementById('slug-status')!;
  let slugTimer: ReturnType<typeof setTimeout>;

  slugInput?.addEventListener('input', () => {
    clearTimeout(slugTimer);
    const val = slugInput.value.toLowerCase().replace(/[^a-z0-9-]/g, '');
    slugInput.value = val;
    if (!val) { slugStatus.innerHTML = ''; return; }

    slugStatus.innerHTML = `<span class="text-forge-text-3">Checking…</span>`;
    slugTimer = setTimeout(() => {
      const taken = ['acme', 'forge', 'test'].includes(val);
      slugStatus.innerHTML = taken
        ? `<span class="text-forge-danger">✗ "${val}" is taken</span>`
        : `<span class="text-forge-success">✓ "${val}" is available</span>`;
    }, 600);
  });

  // Password strength
  const pwInput = document.getElementById('signup-password') as HTMLInputElement;
  pwInput?.addEventListener('input', () => {
    const v = pwInput.value;
    let strength = 0;
    if (v.length >= 8) strength++;
    if (v.length >= 12) strength++;
    if (/[A-Z]/.test(v) && /[0-9]/.test(v)) strength++;
    if (/[^a-zA-Z0-9]/.test(v)) strength++;

    const colors = ['bg-forge-danger', 'bg-forge-warning', 'bg-forge-info', 'bg-forge-success'];
    const labels = ['', 'Weak', 'Fair', 'Good', 'Strong'];
    const strengthEl = document.getElementById('pw-strength')!;
    strengthEl.textContent = labels[strength];
    strengthEl.className = `absolute right-3 top-1/2 -translate-y-1/2 text-xs font-mono ${
      strength <= 1 ? 'text-forge-danger' : strength === 2 ? 'text-forge-warning' : strength === 3 ? 'text-forge-info' : 'text-forge-success'
    }`;

    document.querySelectorAll<HTMLElement>('[class*="pw-bar-"]').forEach((bar, i) => {
      bar.style.width = i < strength ? '100%' : '0%';
      bar.className = `h-full rounded-full transition-all duration-300 pw-bar-${i} ${i < strength ? colors[strength - 1] : ''}`;
    });
  });

  // Make global for inline handlers
  (window as any).nextStep = nextStep;
  (window as any).createAccount = createAccount;
</script>
