---
import AuthLayout from '../../layouts/AuthLayout.astro';
import { PRICING_TIERS } from '../../data/mock.ts';
const plans = PRICING_TIERS.filter(t => t.id !== 'enterprise');
---
<AuthLayout title="Create account — Forge CI">
<div class="max-w-sm w-full">
  <!-- Logo -->
  <div class="mb-8">
    <a href="/" class="inline-flex items-center gap-2.5 mb-6">
      <svg width="28" height="28" viewBox="0 0 32 32" fill="none"><rect width="32" height="32" fill="#FFEE00"/><path d="M8 24L14 8H18L20 14L24 8H28L22 24H18L16 17L12 24H8Z" fill="#0A0A0A"/><circle cx="24" cy="8" r="2.5" fill="#0A0A0A"/></svg>
      <span style="font-family:'Space Grotesk';font-weight:700;font-size:1.1rem;color:#F0F0F0">Forge<span style="color:#FFEE00">CI</span></span>
    </a>
    <!-- Step bar -->
    <div class="flex items-center gap-0 mb-5" id="step-bar">
      {[1,2,3,4].map((n,i) => (
        <>
          <div class="step-dot w-8 h-8 flex items-center justify-center text-xs font-mono font-bold border-2 transition-all flex-shrink-0"
               data-step-dot={n}
               style={n===1 ? 'background:#FFEE00;border-color:#FFEE00;color:#0A0A0A' : 'background:#0A0A0A;border-color:#8A8A8A;color:#8A8A8A'}>
            {n}
          </div>
          {i < 3 && <div class="flex-1 h-0.5 transition-all" style="background:#2C2C2C" data-step-line={n}></div>}
        </>
      ))}
    </div>
    <h1 id="step-title" style="font-family:'Space Grotesk';font-weight:700;font-size:1.5rem;letter-spacing:-0.04em;color:#F0F0F0" class="mb-1">Create your account</h1>
    <p class="text-sm" style="color:#B0B0B0">Already have an account? <a href="/auth/login" style="color:#FFEE00;font-weight:600">Sign in</a></p>
  </div>

  <!-- Step 1: Account -->
  <div id="step-1">
    <!-- OAuth -->
    <div class="space-y-2 mb-5">
      {[
        {p:'github',l:'Sign up with GitHub'},
        {p:'google',l:'Sign up with Google'},
      ].map(item => (
        <a href={`/api/auth/ory?provider=${item.p}&flow=registration`}
           class="w-full flex items-center justify-center gap-3 px-4 py-2.5 text-sm font-semibold border-2 transition-all"
           style="background:#1A1A1A;border-color:#8A8A8A;color:#F0F0F0"
           onmouseover="this.style.borderColor='#FFEE00';this.style.color='#FFEE00'"
           onmouseout="this.style.borderColor='#3C3C3C';this.style.color='#F0F0F0'">
          {item.p === 'github' && <svg width="15" height="15" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>}
          {item.p === 'google' && <svg width="15" height="15" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>}
          {item.l}
        </a>
      ))}
    </div>
    <div class="relative mb-5">
      <div class="absolute inset-0 flex items-center"><div class="w-full border-t-2" style="border-color:#2C2C2C"></div></div>
      <div class="relative flex justify-center"><span class="px-3 text-xs font-mono" style="background:#0A0A0A;color:#8A8A8A">OR EMAIL</span></div>
    </div>
    <div class="space-y-3">
      <div class="grid grid-cols-2 gap-3">
        <div><label class="input-label">First name</label><input type="text" id="first-name" class="input" placeholder="Ada" autocomplete="given-name"/></div>
        <div><label class="input-label">Last name</label><input type="text" id="last-name" class="input" placeholder="Lovelace" autocomplete="family-name"/></div>
      </div>
      <div>
        <label class="input-label">Work email</label>
        <input type="email" id="signup-email" class="input" placeholder="ada@company.com" autocomplete="email"/>
        <div id="email-hint" class="hidden text-xs font-mono mt-1" style="color:#8A8A8A"></div>
      </div>
      <div>
        <label class="input-label">Password</label>
        <input type="password" id="signup-pw" class="input" placeholder="Min 12 characters" minlength="12" autocomplete="new-password"/>
        <!-- Strength meter -->
        <div class="flex gap-1 mt-1.5">
          {Array.from({length:4}).map((_, i) => (
            <div class="h-1 flex-1 overflow-hidden" style="border:1px solid #2C2C2C">
              <div class={`pw-bar-${i} h-full transition-all duration-300`} style="width:0%"></div>
            </div>
          ))}
        </div>
        <div id="pw-label" class="text-xs font-mono mt-1" style="color:#8A8A8A"></div>
      </div>
    </div>
    <button type="button" onclick="goStep(2)" class="btn-primary btn-md w-full justify-center mt-5">
      Continue → <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="square" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
    </button>
    <p class="text-xs font-mono text-center mt-4" style="color:#8A8A8A">
      By signing up you agree to our <a href="/terms" style="color:#FFEE00">Terms</a> and <a href="/privacy" style="color:#FFEE00">Privacy Policy</a>.
    </p>
  </div>

  <!-- Step 2: Organization -->
  <div id="step-2" class="hidden space-y-4">
    <div>
      <label class="input-label">Organization name</label>
      <input type="text" id="org-name" class="input" placeholder="Acme Corp" autocomplete="organization"/>
    </div>
    <div>
      <label class="input-label">Organization URL</label>
      <div class="input-group">
        <span class="input-addon">forge-ci.dev/</span>
        <input type="text" id="org-slug" class="input input-mono" placeholder="acme-corp" autocomplete="off" spellcheck="false"/>
      </div>
      <div id="slug-status" class="text-xs font-mono mt-1.5"></div>
    </div>
    <div>
      <label class="input-label">Team size</label>
      <select class="input">
        <option value="">Select size…</option>
        <option>Just me</option><option>2–5</option><option>6–20</option><option>21–100</option><option>101+</option>
      </select>
    </div>
    <div class="flex gap-3 pt-2">
      <button type="button" onclick="goStep(1)" class="btn-secondary btn-md flex-1 justify-center">← Back</button>
      <button type="button" onclick="goStep(3)" class="btn-primary btn-md flex-1 justify-center">Continue →</button>
    </div>
  </div>

  <!-- Step 3: Plan -->
  <div id="step-3" class="hidden space-y-3">
    {plans.map(t => (
      <label class="flex items-center gap-3 p-4 border-2 cursor-pointer transition-all"
             style="border-color:#2C2C2C;background:#111111"
             onmouseover="this.style.borderColor='#FFEE00'"
             onmouseout={`this.style.borderColor=document.querySelector('input[name=plan][value="${t.id}"]').checked?'#FFEE00':'#2C2C2C'`}>
        <input type="radio" name="plan" value={t.id} class="sr-only" checked={t.featured}
               onchange="document.querySelectorAll('.plan-label').forEach(l=>l.style.borderColor='#2C2C2C');this.closest('label').style.borderColor='#FFEE00'"/>
        <div class="w-4 h-4 border-2 flex-shrink-0 flex items-center justify-center transition-all"
             style={t.featured ? 'border-color:#FFEE00;background:#FFEE00' : 'border-color:#8A8A8A'}>
          {t.featured && <div class="w-2 h-2" style="background:#0A0A0A"></div>}
        </div>
        <div class="flex-1">
          <div class="flex items-center gap-2">
            <span class="text-sm font-semibold" style="color:#F0F0F0">{t.name}</span>
            {t.featured && <span class="badge-accent text-xs">Recommended</span>}
          </div>
          <div class="text-xs font-mono mt-0.5" style="color:#8A8A8A">{t.build_minutes} · {t.parallelism}</div>
        </div>
        <div class="text-sm font-mono font-bold" style="color:#FFEE00">{t.monthly_price === 0 ? 'Free' : `$${t.monthly_price}/mo`}</div>
      </label>
    ))}
    <p class="text-xs font-mono" style="color:#8A8A8A">✓ 14-day free trial on Pro & Team. No card required.</p>
    <div class="flex gap-3">
      <button type="button" onclick="goStep(2)" class="btn-secondary btn-md flex-shrink-0 px-4">←</button>
      <button type="button" onclick="createAccount()" id="create-btn" class="btn-primary btn-md flex-1 justify-center">
        Create account ✓
      </button>
    </div>
  </div>

  <!-- Step 4: Verify email -->
  <div id="step-4" class="hidden text-center">
    <div class="w-16 h-16 border-2 flex items-center justify-center mx-auto mb-6" style="border-color:#00FF88;background:rgba(0,255,136,0.08)">
      <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color:#00FF88"><path stroke-linecap="square" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
    </div>
    <h2 class="text-2xl font-bold mb-3" style="font-family:'Space Grotesk';letter-spacing:-0.03em;color:#F0F0F0">Check your inbox</h2>
    <p class="text-sm mb-6" style="color:#B0B0B0">
      Ory Kratos sent a verification link to<br/>
      <strong class="font-mono" style="color:#F0F0F0" id="verify-email"></strong>
    </p>
    <a href="/auth/onboarding" class="btn-primary btn-md w-full justify-center">I've verified my email →</a>
    <button class="btn-ghost btn-sm w-full justify-center mt-2 text-xs font-mono" style="color:#8A8A8A">Resend verification email</button>
  </div>
</div>
</AuthLayout>

<script>
  const stepTitles = ['','Create your account','Set up your org','Choose a plan','Verify your email'];

  function goStep(n: number) {
    [1,2,3,4].forEach(i => document.getElementById(`step-${i}`)?.classList.add('hidden'));
    document.getElementById(`step-${n}`)?.classList.remove('hidden');
    const title = document.getElementById('step-title')!;
    if (stepTitles[n]) title.textContent = stepTitles[n];

    // Update step dots
    [1,2,3,4].forEach(i => {
      const dot = document.querySelector<HTMLElement>(`[data-step-dot="${i}"]`)!;
      const line = document.querySelector<HTMLElement>(`[data-step-line="${i}"]`);
      if (i < n) {
        dot.style.cssText = 'background:#00FF88;border-color:#00FF88;color:#0A0A0A';
        dot.textContent = '✓';
        if (line) line.style.background = '#00FF88';
      } else if (i === n) {
        dot.style.cssText = 'background:#FFEE00;border-color:#FFEE00;color:#0A0A0A';
        dot.textContent = String(i);
        if (line) line.style.background = '#2C2C2C';
      } else {
        dot.style.cssText = 'background:#0A0A0A;border-color:#8A8A8A;color:#8A8A8A';
        dot.textContent = String(i);
        if (line) line.style.background = '#2C2C2C';
      }
    });
  }

  async function createAccount() {
    const btn = document.getElementById('create-btn') as HTMLButtonElement;
    btn.textContent = 'Creating…'; btn.disabled = true;
    await new Promise(r => setTimeout(r, 1200));
    const email = (document.getElementById('signup-email') as HTMLInputElement)?.value;
    (document.getElementById('verify-email')!).textContent = email || 'your email';
    goStep(4);
  }

  // Slug auto-gen
  const orgName = document.getElementById('org-name') as HTMLInputElement;
  const orgSlug = document.getElementById('org-slug') as HTMLInputElement;
  const slugStatus = document.getElementById('slug-status')!;
  orgName?.addEventListener('input', () => {
    const s = orgName.value.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
    if (s && !orgSlug.value) orgSlug.value = s;
  });
  let slugTimer: ReturnType<typeof setTimeout>;
  orgSlug?.addEventListener('input', () => {
    const v = orgSlug.value.toLowerCase().replace(/[^a-z0-9-]/g, '');
    orgSlug.value = v;
    clearTimeout(slugTimer);
    if (!v) { slugStatus.innerHTML = ''; return; }
    slugStatus.innerHTML = '<span style="color:#8A8A8A">Checking availability…</span>';
    slugTimer = setTimeout(() => {
      const taken = ['acme','forge','test','demo','admin'].includes(v);
      slugStatus.innerHTML = taken
        ? `<span style="color:#FF3333">✗ "${v}" is taken</span>`
        : `<span style="color:#00FF88">✓ "${v}" is available</span>`;
    }, 500);
  });

  // Password strength
  const pwInput = document.getElementById('signup-pw') as HTMLInputElement;
  const pwLabel = document.getElementById('pw-label')!;
  const barColors = ['','#FF3333','#FF7700','#33AAFF','#00FF88'];
  const barLabels = ['','Weak — too short','Fair — add numbers & symbols','Good — add uppercase','Strong'];

  pwInput?.addEventListener('input', () => {
    const v = pwInput.value;
    let s = 0;
    if (v.length >= 8)  s++;
    if (v.length >= 12) s++;
    if (/[A-Z]/.test(v) && /[0-9]/.test(v)) s++;
    if (/[^a-zA-Z0-9]/.test(v)) s++;
    [0,1,2,3].forEach(i => {
      const bar = document.querySelector<HTMLElement>(`.pw-bar-${i}`)!;
      bar.style.width   = i < s ? '100%' : '0%';
      bar.style.background = i < s ? barColors[s] : 'transparent';
    });
    pwLabel.textContent  = barLabels[s] ?? '';
    pwLabel.style.color  = barColors[s] ?? '#8A8A8A';
  });

  (window as any).goStep = goStep;
  (window as any).createAccount = createAccount;
</script>
