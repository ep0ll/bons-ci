---
import MarketingLayout from '../layouts/MarketingLayout.astro';

const complianceBadges = [
  { name:'SOC 2 Type II', icon:'🛡', status:'Current', detail:'Annual audit by Prescient Assurance. Full report under NDA within 24h.' },
  { name:'ISO 27001',     icon:'📋', status:'Current', detail:'Information security management. Certified by BSI Group.' },
  { name:'GDPR',          icon:'🇪🇺', status:'Compliant', detail:'DPA available. EU-US Data Privacy Framework participant.' },
  { name:'HIPAA Ready',   icon:'🏥', status:'Ready', detail:'BAA available. Architecture reviewed by healthcare counsel.' },
  { name:'Pen-tested',    icon:'🔍', status:'Annual', detail:'External pentest by NCC Group. Last completed Feb 2025.' },
  { name:'FedRAMP',       icon:'🏛', status:'In progress', detail:'Targeting Moderate authorization H2 2025.' },
];

const features = [
  { icon:'🔒', title:'SAML 2.0 SSO & SCIM',      desc:'Okta, Azure AD, Google Workspace, or any SAML 2.0 IdP. Auto-provision and deprovision via SCIM 2.0.' },
  { icon:'🖥', title:'Dedicated runner fleet',    desc:'Reserved private compute — no shared infra. Configurable CPU/memory, custom OS images, custom regions.' },
  { icon:'☁', title:'BYOC & VPC peering',        desc:'Run builds inside your own AWS, GCP, or Azure account. Private networking via Tailnet — no VPN required.' },
  { icon:'📋', title:'Unlimited audit logs',      desc:'Every API call, secret access, and settings change logged forever. Export to Splunk, Datadog, or any SIEM.' },
  { icon:'⚖', title:'Custom contracts & MSA',    desc:'Custom DPA, BAA for HIPAA, and Master Service Agreements all negotiable. Legal review within 48h.' },
  { icon:'📈', title:'99.99% uptime SLA',        desc:'Financial credits for downtime, not just promises. Enterprise SLA with dedicated incident response.' },
  { icon:'👤', title:'Dedicated CSM',            desc:'Named Customer Success Manager, quarterly business reviews, proactive capacity planning.' },
  { icon:'🤖', title:'Sherlock AI (unlimited)',   desc:'Unlimited AI-powered failure analysis, auto-fix PRs, pattern detection, and anomaly alerts.' },
];

const customers = [
  { name:'Vercel',      emoji:'▲', industry:'Platform tooling',       team:'2,000+ engineers', result:'12× faster deploys',    quote:'The migration took a weekend. The ROI was immediate.' },
  { name:'Stripe',      emoji:'💳', industry:'Financial infrastructure', team:'800+ engineers',  result:'$1.2M/yr saved',       quote:'Sherlock eliminated our CI on-call rotation entirely.' },
  { name:'Linear',      emoji:'📐', industry:'Dev Tools',               team:'50+ engineers',   result:'2-day Jenkins migration', quote:'Zero pipeline changes needed. Just connect and go.' },
  { name:'PlanetScale', emoji:'🌍', industry:'Infrastructure',          team:'200+ engineers',  result:'74% MTTR reduction',   quote:'We reinvested CI debugging hours into features.' },
];
---

<MarketingLayout
  title="Enterprise — Forge CI"
  description="Forge CI for enterprise engineering teams. SAML SSO, dedicated runners, BYOC, 99.99% SLA, and a dedicated CSM. Talk to sales."
>
  <!-- Hero -->
  <section class="relative pt-32 pb-20 overflow-hidden">
    <div class="absolute inset-0 bg-grid opacity-30 pointer-events-none" aria-hidden="true"></div>
    <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 900px 500px at 50% 0,rgba(255,238,0,0.07),transparent 60%)" aria-hidden="true"></div>
    <div class="container-forge relative z-10">
      <div class="grid lg:grid-cols-2 gap-14 items-center">
        <div>
          <div class="section-label mb-6">Enterprise</div>
          <h1 class="section-title mb-6">CI/CD built for <span class="text-gradient">enterprise scale.</span></h1>
          <p class="text-xl text-[#B0B0B0] leading-relaxed mb-8">
            The compliance your legal team requires. The performance your engineers love.
            SAML, SCIM, dedicated runners, unlimited audit logs, and a 99.99% SLA.
          </p>
          <div class="flex flex-col sm:flex-row gap-3 mb-8">
            <a href="#contact" class="btn-primary btn-xl">Talk to enterprise sales</a>
            <a href="/docs/enterprise" class="btn-secondary btn-xl">Read enterprise docs</a>
          </div>
          <p class="text-sm text-[#8A8A8A]">Avg. sales cycle: 3 weeks. POC environments available same day.</p>
        </div>
        <div class="grid grid-cols-3 gap-4">
          {[
            {v:'99.99%',l:'Uptime SLA',s:'financial credits'},
            {v:'< 4h',  l:'Support SLA',s:'P0 incidents'},
            {v:'SOC 2', l:'Type II',    s:'annual audit'},
            {v:'GDPR',  l:'Compliant',  s:'DPA available'},
            {v:'SCIM',  l:'Provisioning',s:'Okta, Azure AD'},
            {v:'VPC',   l:'Peering',    s:'BYOC & Tailnet'},
          ].map(s=>(
            <div class="card p-5 text-center hover:border-[rgba(255,238,0,0.2)] transition-colors">
              <div class="font-bold text-xl text-[#FFEE00] mb-1">{s.v}</div>
              <div class="text-sm font-medium text-[#F0F0F0]">{s.l}</div>
              <div class="text-xs text-[#8A8A8A] mt-0.5">{s.s}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Feature grid -->
  <section class="section border-t border-[#2C2C2C] bg-[rgba(12,16,24,0.4)]">
    <div class="container-forge">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <h2 class="section-title">Everything your security team needs.<br/><span class="text-gradient">And everything engineers want.</span></h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {features.map(f=>(
          <div class="card p-6 hover:border-[rgba(255,238,0,0.2)] transition-colors">
            <div class="text-2xl mb-4">{f.icon}</div>
            <h3 class="font-bold text-base text-[#F0F0F0] mb-2">{f.title}</h3>
            <p class="text-sm text-[#B0B0B0] leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Social proof -->
  <section class="section border-t border-[#2C2C2C]">
    <div class="container-forge">
      <div class="text-center mb-12">
        <h2 class="font-bold text-3xl text-[#F0F0F0]">Trusted by engineering teams at scale.</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-12">
        {customers.map(c=>(
          <div class="card p-6">
            <div class="flex items-center gap-3 mb-4">
              <div class="text-3xl">{c.emoji}</div>
              <div>
                <div class="font-bold text-lg text-[#F0F0F0]">{c.name}</div>
                <div class="text-xs text-[#8A8A8A]">{c.industry}</div>
              </div>
            </div>
            <div class="text-sm font-medium text-[#FFEE00] mb-3">{c.result}</div>
            <p class="text-xs text-[#8A8A8A] italic leading-relaxed">"{c.quote}"</p>
            <div class="text-xs text-[#8A8A8A] mt-3">— {c.team}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Compliance -->
  <section class="section border-t border-[#2C2C2C] bg-[rgba(12,16,24,0.4)]">
    <div class="container-forge">
      <div class="grid lg:grid-cols-2 gap-14 items-center">
        <div>
          <div class="section-label mb-5">Compliance & Security</div>
          <h2 class="font-bold text-4xl text-[#F0F0F0] mb-5">Pass your security review. <span class="text-gradient">Fast.</span></h2>
          <p class="text-lg text-[#B0B0B0] leading-relaxed mb-6">
            We maintain the certifications your procurement and legal teams require.
            Security questionnaires, compliance reports, and pentest results delivered under NDA within 24 hours.
          </p>
          <a href="/security" class="btn-secondary btn-lg">Full security overview →</a>
        </div>
        <div class="grid sm:grid-cols-2 gap-3">
          {complianceBadges.map(b=>(
            <div class="card p-4">
              <div class="flex items-center gap-2 mb-2">
                <span class="text-lg">{b.icon}</span>
                <span class="text-sm font-medium text-[#F0F0F0]">{b.name}</span>
                <span class:list={['badge text-xs ml-auto', b.status==='Current'||b.status==='Compliant'||b.status==='Annual'?'badge-success border border-[rgba(0,255,136,0.2)]':b.status==='Ready'?'badge-info border border-[rgba(51,170,255,0.2)]':'badge-warning border border-[rgba(245,158,11,0.2)]']}>{b.status}</span>
              </div>
              <p class="text-xs text-[#8A8A8A] leading-relaxed">{b.detail}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Contact form -->
  <section class="section border-t border-[#2C2C2C]" id="contact">
    <div class="container-forge max-w-2xl text-center">
      <h2 class="font-bold text-4xl text-[#F0F0F0] mb-4">Ready to get started?</h2>
      <p class="text-[#B0B0B0] mb-10 leading-relaxed">Talk to our enterprise team. We'll scope a POC, share compliance docs, and get you running in days — not months.</p>
      <div class="card p-8 text-left">
        <div class="grid sm:grid-cols-2 gap-4 mb-4">
          <div><label class="input-label">First name</label><input type="text" class="input" placeholder="Ada" /></div>
          <div><label class="input-label">Last name</label><input type="text" class="input" placeholder="Lovelace" /></div>
          <div><label class="input-label">Work email</label><input type="email" class="input" placeholder="ada@company.com" /></div>
          <div><label class="input-label">Company</label><input type="text" class="input" placeholder="Acme Corp" /></div>
          <div class="sm:col-span-2">
            <label class="input-label">Engineering team size</label>
            <select class="input">
              <option>25–100 engineers</option><option>101–500 engineers</option>
              <option>501–2,000 engineers</option><option>2,000+ engineers</option>
            </select>
          </div>
          <div class="sm:col-span-2">
            <label class="input-label">Current CI/CD setup & goals</label>
            <textarea rows={3} class="input resize-none" placeholder="Tell us about your current setup and what you're hoping to achieve…"></textarea>
          </div>
        </div>
        <button class="btn-primary btn-lg w-full justify-center">Talk to enterprise sales →</button>
        <p class="text-xs text-[#8A8A8A] mt-3 text-center">Response within 4 business hours. No spam, ever.</p>
      </div>
    </div>
  </section>
</MarketingLayout>
