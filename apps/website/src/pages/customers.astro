---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import { MOCK_CASE_STUDIES } from '../data/mock.ts';

const studies = MOCK_CASE_STUDIES;
---
<MarketingLayout
  title="Customers — Forge CI"
  description="See how engineering teams at Vercel, Stripe, and other leading companies transformed their CI/CD with Forge CI."
>
  <!-- Hero -->
  <section class="relative pt-32 pb-16 overflow-hidden">
    <div class="absolute inset-0 bg-grid-brut opacity-20 pointer-events-none"></div>
    <div class="absolute inset-0 pointer-events-none" style="background:radial-gradient(ellipse 1000px 400px at 50% -50px,rgba(255,238,0,0.05),transparent 60%)"></div>
    <div class="container-forge relative z-10 text-center">
      <div class="section-label mb-6 justify-center">Customer Stories</div>
      <h1 class="section-title mb-5">
        Trusted at scale.<br/>
        <span class="text-gradient-brut">Real results, real teams.</span>
      </h1>
      <p class="section-subtitle mx-auto max-w-2xl">
        From solo devs to 2,000-person platform teams — engineering leaders share how Forge CI transformed their CI&amp;CD.
      </p>
    </div>
  </section>

  <!-- Stats bar -->
  <div class="border-y-2" style="border-color:#2C2C2C;background:#060606">
    <div class="container-forge">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-0 text-center">
        {[
          { v:'50K+', l:'Teams building' },
          { v:'2.4B', l:'Builds delivered' },
          { v:'10×',  l:'Avg speed gain' },
          { v:'99.99%', l:'Uptime SLA' },
        ].map(s => (
          <div class="border-r-2 p-8 last:border-r-0" style="border-color:#2C2C2C">
            <div class="text-3xl sm:text-4xl font-bold mb-1" style="font-family:'Space Grotesk';color:#FFEE00;letter-spacing:-0.04em">{s.v}</div>
            <div class="text-xs font-mono" style="color:#8A8A8A">{s.l}</div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Case study cards -->
  <section class="section">
    <div class="container-forge">
      <div class="grid lg:grid-cols-2 gap-0 border-l-2 border-t-2" style="border-color:#2C2C2C">
        {studies.map(cs => (
          <a
            href={`/customers/${cs.slug}`}
            class="border-r-2 border-b-2 p-8 group block"
            style="border-color:#2C2C2C"
          >
            <div class="flex items-center gap-4 mb-5">
              <div class="text-5xl">{cs.logo_emoji}</div>
              <div>
                <div class="text-xl font-bold group-hover:text-[#FFEE00] transition-colors" style="font-family:'Space Grotesk';color:#F0F0F0">{cs.company}</div>
                <div class="text-xs font-mono" style="color:#8A8A8A">{cs.industry} · {cs.team_size}</div>
              </div>
            </div>

            <h2 class="text-base font-bold mb-5 leading-tight" style="font-family:'Space Grotesk';color:#F0F0F0">{cs.headline}</h2>

            <div class="space-y-2 mb-6">
              {cs.results.map(r => (
                <div class="flex items-center justify-between p-3 border-2" style="border-color:#2C2C2C;background:#111111">
                  <span class="text-sm" style="color:#B0B0B0">{r.metric}</span>
                  <div class="flex items-center gap-3 text-sm font-mono">
                    <span style="color:#8A8A8A;text-decoration:line-through">{r.before}</span>
                    <span style="color:#FFEE00">→</span>
                    <strong style="color:#FFEE00">{r.after}</strong>
                  </div>
                </div>
              ))}
            </div>

            <blockquote class="text-sm italic leading-relaxed border-l-2 border-[#FFEE00] pl-4 mb-5" style="color:#B0B0B0">
              "{cs.quote}"
              <footer class="text-xs font-mono mt-2 not-italic" style="color:#8A8A8A">— {cs.quote_author}</footer>
            </blockquote>

            <div class="flex items-center gap-2 text-sm font-semibold group-hover:text-[#FFEE00] transition-colors" style="color:#FFEE00">
              Read case study
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="square" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
              </svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured logos -->
  <section class="py-16 border-y-2" style="border-color:#2C2C2C;background:#060606">
    <div class="container-forge text-center">
      <p class="text-xs font-mono uppercase tracking-widest mb-8" style="color:#8A8A8A">Engineering teams that ship with Forge CI</p>
      <div class="flex flex-wrap justify-center gap-x-12 gap-y-4">
        {['Vercel','Stripe','Linear','Notion','Figma','Supabase','PlanetScale','Railway','Resend','Trigger.dev','Neon','Fly.io'].map(co => (
          <span class="font-bold text-lg cursor-default transition-colors" style="font-family:'Space Grotesk';color:#2C2C2C;letter-spacing:-0.02em"
                onmouseover="this.style.color='#FFEE00'" onmouseout="this.style.color='#2C2C2C'">{co}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container-forge text-center max-w-2xl mx-auto">
      <div class="section-label mb-6 justify-center">Join them</div>
      <h2 class="section-title mb-6">Ready to build faster?</h2>
      <p class="section-subtitle mb-8 mx-auto">Set up in 2 minutes. Free forever for solo devs. Scales to unlimited parallelism.</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/auth/signup" class="btn-primary btn-xl">Start building free →</a>
        <a href="/contact/sales" class="btn-secondary btn-xl">Talk to sales</a>
      </div>
    </div>
  </section>
</MarketingLayout>
