---
import MarketingLayout from '../../layouts/MarketingLayout.astro';
import { MOCK_BLOG_POSTS } from '../../data/mock.ts';

export function getStaticPaths() {
  return MOCK_BLOG_POSTS.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props as { post: typeof MOCK_BLOG_POSTS[number] };
const related = MOCK_BLOG_POSTS.filter(p => p.slug !== post.slug && p.category === post.category).slice(0, 2);
---
<MarketingLayout title={`${post.title} — Forge CI Blog`} description={post.excerpt}>
  <div class="pt-28 pb-20">
    <div class="container-forge max-w-3xl">
      <!-- Back -->
      <a href="/blog" class="inline-flex items-center gap-2 text-sm text-[#8A8A8A] hover:text-[#F0F0F0] transition-colors mb-8">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        Back to blog
      </a>
      <!-- Header -->
      <div class="mb-10">
        <div class="flex items-center gap-2 mb-5">
          <span class="badge-accent border border-[rgba(255,238,0,0.3)] text-sm">{post.category}</span>
          <span class="text-sm text-[#8A8A8A]">{post.read_time_min} min read</span>
        </div>
        <h1 class="font-bold text-3xl sm:text-4xl text-[#F0F0F0] leading-tight mb-6">{post.title}</h1>
        <div class="flex items-center gap-4 pb-6 border-b border-[#2C2C2C]">
          <div class="avatar-md avatar-base">{post.author.initials}</div>
          <div>
            <div class="text-sm font-medium text-[#F0F0F0]">{post.author.name}</div>
            <div class="text-xs text-[#8A8A8A]">{post.author.role} · {post.published_at}</div>
          </div>
          <div class="ml-auto flex gap-2">
            {['Twitter','LinkedIn','Copy link'].map(s => (
              <button class="btn-ghost btn-sm text-xs text-[#8A8A8A]">{s}</button>
            ))}
          </div>
        </div>
      </div>
      <!-- Hero image -->
      <div class="w-full rounded-none bg-[#1A1A1A] border border-[#2C2C2C] flex items-center justify-center py-16 text-8xl mb-10">{post.image_emoji}</div>
      <!-- Body -->
      <div class="prose-forge space-y-6 mb-12">
        <p class="text-lg text-[#B0B0B0] leading-relaxed">{post.excerpt}</p>
        <h2 class="font-bold text-2xl text-[#F0F0F0]">Overview</h2>
        <p class="text-[#B0B0B0] leading-relaxed">This post covers the key aspects of {post.title.toLowerCase()} and what it means for engineering teams using Forge CI. We'll walk through the motivation, the technical implementation, and real-world results from our beta customers.</p>
        <h2 class="font-bold text-2xl text-[#F0F0F0]">Background</h2>
        <p class="text-[#B0B0B0] leading-relaxed">The engineering team at Forge CI has been working on this feature for the past several months, iterating based on feedback from our beta customers. The goal was to make CI/CD dramatically faster and more intelligent without requiring any pipeline YAML changes.</p>
        <div class="card p-5 border-[rgba(255,238,0,0.2)] bg-[rgba(255,238,0,0.04)]">
          <div class="text-xs font-mono uppercase tracking-wider text-[#FFEE00] mb-2">Key result</div>
          <p class="text-sm text-[#B0B0B0]">Teams using this feature saw an average 10× improvement in build times with no configuration changes required.</p>
        </div>
        <h2 class="font-bold text-2xl text-[#F0F0F0]">Technical details</h2>
        <p class="text-[#B0B0B0] leading-relaxed">The implementation uses a content-addressed approach where each build step produces a hash based on its inputs — source files, environment variables, and configuration. This hash is used as the cache key, ensuring that identical inputs always produce identical outputs.</p>
        <div class="terminal">
          <div class="terminal-header"><div class="terminal-dot bg-[#FF5F57]"></div><div class="terminal-dot bg-[#FFBD2E]"></div><div class="terminal-dot bg-[#28C840]"></div></div>
          <pre class="p-5 text-xs font-mono text-[#B0B0B0] leading-relaxed">$ forge run --verbose
→ Computing cache key for step "install"...
→ Key: sha256:a4f9c2be49a1b28c3f9e8d4a0bc7e21f45c6d382
→ Cache HIT! Restoring 1.2 GB node_modules in 0.8s
→ Step "install" completed in 0.8s (was 24s)</pre>
        </div>
      </div>
      <!-- Tags -->
      <div class="flex flex-wrap gap-2 mb-10">
        {post.tags.map(t => <span class="badge-neutral border border-[#2C2C2C] text-xs">#{t}</span>)}
      </div>
      <!-- Author card -->
      <div class="card p-6 flex items-start gap-5 mb-10">
        <div class="avatar-lg avatar-base text-lg">{post.author.initials}</div>
        <div>
          <div class="font-bold text-lg text-[#F0F0F0]">{post.author.name}</div>
          <div class="text-sm text-[#8A8A8A] mb-2">{post.author.role} · Forge CI</div>
          <p class="text-sm text-[#B0B0B0]">Member of the Forge CI engineering team. Writes about CI/CD, developer productivity, and distributed systems.</p>
        </div>
      </div>
      <!-- Related -->
      {related.length > 0 && (
        <div>
          <h3 class="font-bold text-xl text-[#F0F0F0] mb-5">Related posts</h3>
          <div class="grid sm:grid-cols-2 gap-4">
            {related.map(p => (
              <a href={`/blog/${p.slug}`} class="card-hover p-5 group">
                <div class="text-3xl mb-3">{p.image_emoji}</div>
                <div class="text-sm font-bold text-[#F0F0F0] group-hover:text-[#FFEE00] transition-colors mb-1 leading-snug">{p.title}</div>
                <div class="text-xs text-[#8A8A8A]">{p.read_time_min} min read</div>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </div>
</MarketingLayout>
