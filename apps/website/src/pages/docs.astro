---
import MarketingLayout from '../layouts/MarketingLayout.astro';

const docCategories = [
  {
    icon: '🚀',
    title: 'Getting started',
    color: 'accent',
    docs: [
      { title: 'Quick start guide',            href: '/docs/quickstart',        time: '5 min' },
      { title: 'Connect your first repo',       href: '/docs/connect-repo',      time: '3 min' },
      { title: 'Your first pipeline',           href: '/docs/first-pipeline',    time: '8 min' },
      { title: 'Understanding build minutes',   href: '/docs/build-minutes',     time: '4 min' },
      { title: 'Migrating from GitHub Actions', href: '/docs/migrate/gha',       time: '12 min' },
      { title: 'Migrating from CircleCI',       href: '/docs/migrate/circleci',  time: '10 min' },
    ],
  },
  {
    icon: '📋',
    title: 'Pipeline YAML',
    color: 'cyan',
    docs: [
      { title: 'Pipeline YAML reference',       href: '/docs/yaml',              time: '15 min' },
      { title: 'Steps and parallel jobs',        href: '/docs/yaml/steps',        time: '8 min' },
      { title: 'Matrix builds',                  href: '/docs/yaml/matrix',       time: '6 min' },
      { title: 'Conditional steps',              href: '/docs/yaml/conditions',   time: '5 min' },
      { title: 'Reusable components',            href: '/docs/yaml/components',   time: '7 min' },
      { title: 'Triggers and schedules',         href: '/docs/yaml/triggers',     time: '6 min' },
    ],
  },
  {
    icon: '⚡',
    title: 'Caching',
    color: 'accent',
    docs: [
      { title: 'Cache overview',                 href: '/docs/cache',             time: '5 min' },
      { title: 'Node.js caching',                href: '/docs/cache/node',        time: '4 min' },
      { title: 'Docker layer caching',           href: '/docs/cache/docker',      time: '6 min' },
      { title: 'Custom cache keys',              href: '/docs/cache/keys',        time: '5 min' },
      { title: 'Remote build cache',             href: '/docs/cache/remote',      time: '8 min' },
      { title: 'Cache invalidation',             href: '/docs/cache/invalidation',time: '4 min' },
    ],
  },
  {
    icon: '🔒',
    title: 'Security',
    color: 'cyan',
    docs: [
      { title: 'Secrets management',             href: '/docs/secrets',           time: '6 min' },
      { title: 'OIDC authentication',            href: '/docs/auth/oidc',         time: '10 min' },
      { title: 'SAML SSO setup',                 href: '/docs/sso/saml',          time: '8 min' },
      { title: 'Network egress rules',           href: '/docs/network/egress',    time: '5 min' },
      { title: 'Audit logs',                     href: '/docs/audit-logs',        time: '4 min' },
      { title: 'SCIM provisioning',              href: '/docs/sso/scim',          time: '7 min' },
    ],
  },
  {
    icon: '☁',
    title: 'Runners & BYOC',
    color: 'accent',
    docs: [
      { title: 'Runner types overview',          href: '/docs/runners',           time: '5 min' },
      { title: 'BYOC on AWS',                    href: '/docs/byoc/aws',          time: '15 min' },
      { title: 'BYOC on GCP',                    href: '/docs/byoc/gcp',          time: '15 min' },
      { title: 'BYOC on Azure',                  href: '/docs/byoc/azure',        time: '15 min' },
      { title: 'Tailnet private networking',     href: '/docs/network/tailnet',   time: '10 min' },
      { title: 'Self-hosted runner agent',       href: '/docs/runners/self-hosted',time: '12 min' },
    ],
  },
  {
    icon: '🔌',
    title: 'Integrations',
    color: 'cyan',
    docs: [
      { title: 'GitHub integration',             href: '/docs/integrations/github',    time: '5 min' },
      { title: 'Slack notifications',            href: '/docs/integrations/slack',     time: '4 min' },
      { title: 'Datadog metrics',                href: '/docs/integrations/datadog',   time: '6 min' },
      { title: 'Kubernetes deploy',              href: '/docs/integrations/k8s',       time: '8 min' },
      { title: 'Terraform Cloud',                href: '/docs/integrations/terraform', time: '7 min' },
      { title: 'Plugin SDK',                     href: '/docs/plugins/sdk',            time: '20 min' },
    ],
  },
];

const apiEndpoints = [
  { method: 'GET',    path: '/v2/builds',                    desc: 'List builds' },
  { method: 'POST',   path: '/v2/builds',                    desc: 'Trigger a build' },
  { method: 'GET',    path: '/v2/builds/{id}',               desc: 'Get build details' },
  { method: 'DELETE', path: '/v2/builds/{id}',               desc: 'Cancel a build' },
  { method: 'GET',    path: '/v2/builds/{id}/logs',          desc: 'Stream build logs' },
  { method: 'GET',    path: '/v2/artifacts',                 desc: 'List artifacts' },
  { method: 'GET',    path: '/v2/projects',                  desc: 'List projects' },
  { method: 'GET',    path: '/v2/metrics',                   desc: 'Usage metrics' },
];

const methodColor: Record<string, string> = {
  GET:    'text-[#00FF88]  border-[rgba(0,255,136,0.3)]',
  POST:   'text-[#33AAFF]  border-[rgba(51,170,255,0.3)]',
  DELETE: 'text-[#FF3333]  border-[rgba(255,51,51,0.3)]',
  PUT:    'text-[#FF7700]  border-[rgba(255,119,0,0.3)]',
  PATCH:  'text-[#FF7700]  border-[rgba(255,119,0,0.3)]',
};
---

<MarketingLayout
  title="Documentation — Forge CI"
  description="Everything you need to build faster with Forge CI. Guides, API reference, tutorials, and examples."
>
  <!-- Hero search -->
  <section class="relative pt-28 pb-16 overflow-hidden">
    <div class="absolute inset-0 bg-grid opacity-25 pointer-events-none" aria-hidden="true"></div>
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 800px 400px at 50% 0, rgba(255,238,0,0.06), transparent 60%)" aria-hidden="true"></div>

    <div class="container-forge relative z-10 text-center">
      <div class="section-label mb-6">Documentation</div>
      <h1 class="font-bold text-5xl sm:text-6xl tracking-tight text-[#F0F0F0] mb-6">
        How can we help?
      </h1>
      <p class="text-lg text-[#F0F0F0]-2 mb-10 max-w-xl mx-auto">
        Guides, tutorials, and reference docs for Forge CI.
      </p>

      <!-- Search bar -->
      <div class="max-w-2xl mx-auto relative">
        <svg class="absolute left-5 top-1/2 -translate-y-1/2 w-5 h-5 text-[#F0F0F0]-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <input
          type="search"
          id="docs-search"
          placeholder="Search docs… (try 'cache', 'SAML', 'matrix builds')"
          class="input !pl-14 !py-4 !text-base w-full"
          autocomplete="off"
        />
        <kbd class="absolute right-4 top-1/2 -translate-y-1/2 hidden sm:flex items-center gap-1 text-2xs border border-[#2C2C2C] rounded px-1.5 py-1 text-[#F0F0F0]-3 font-mono">⌘K</kbd>
      </div>

      <!-- Popular searches -->
      <div class="flex flex-wrap justify-center gap-2 mt-5">
        <span class="text-sm text-[#F0F0F0]-3">Popular:</span>
        {['Getting started', 'Docker caching', 'SAML SSO', 'BYOC runners', 'Matrix builds', 'OIDC secrets'].map(t => (
          <button class="text-sm text-[#F0F0F0]-2 hover:text-[#FFEE00] transition-colors border border-[#2C2C2C] hover:border-forge-accent/40 rounded-full px-3 py-1">
            {t}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Quick start cards -->
  <section class="py-12 border-t border-[#2C2C2C]">
    <div class="container-forge">
      <h2 class="font-bold text-2xl text-[#F0F0F0] mb-6">Quick starts</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {[
          { icon:'🟢', title:'Node.js', href:'/docs/quickstart/node',    desc:'npm, Jest, Docker' },
          { icon:'🐍', title:'Python',  href:'/docs/quickstart/python',  desc:'pytest, pip, poetry' },
          { icon:'🐹', title:'Go',      href:'/docs/quickstart/go',      desc:'go test, Docker' },
          { icon:'🦀', title:'Rust',    href:'/docs/quickstart/rust',    desc:'cargo, sccache' },
          { icon:'📱', title:'React Native', href:'/docs/quickstart/react-native', desc:'iOS + Android' },
          { icon:'☸', title:'Kubernetes',  href:'/docs/quickstart/k8s',  desc:'Helm, kubectl' },
          { icon:'🏗', title:'Terraform',  href:'/docs/quickstart/terraform', desc:'Plan, apply' },
          { icon:'🐳', title:'Docker',     href:'/docs/quickstart/docker', desc:'BuildKit, push' },
        ].map(({ icon, title, href, desc }) => (
          <a href={href} class="card-hover p-5 flex items-center gap-4 group">
            <span class="text-2xl flex-shrink-0" aria-hidden="true">{icon}</span>
            <div>
              <div class="text-sm font-medium text-[#F0F0F0] group-hover:text-[#FFEE00] transition-colors">{title}</div>
              <div class="text-xs text-[#F0F0F0]-3 mt-0.5">{desc}</div>
            </div>
            <svg class="w-4 h-4 text-[#F0F0F0]-3 ml-auto flex-shrink-0 group-hover:text-[#FFEE00] transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Doc categories -->
  <section class="py-12 border-t border-[#2C2C2C] bg-[#111111]/20">
    <div class="container-forge">
      <h2 class="font-bold text-2xl text-[#F0F0F0] mb-8">All documentation</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {docCategories.map((cat) => (
          <div class="space-y-1">
            <div class="flex items-center gap-2.5 mb-4">
              <span class="text-xl" aria-hidden="true">{cat.icon}</span>
              <h3 class={`font-bold text-base ${cat.color === 'accent' ? 'text-[#FFEE00]' : 'text-forge-cyan'}`}>
                {cat.title}
              </h3>
            </div>
            {cat.docs.map(({ title, href, time }) => (
              <a
                href={href}
                class="flex items-center justify-between px-3 py-2.5 rounded-none hover:bg-[#111111]2 transition-colors group"
              >
                <div class="flex items-center gap-2.5">
                  <svg class="w-3.5 h-3.5 text-[#F0F0F0]-3 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                  </svg>
                  <span class="text-sm text-[#F0F0F0]-2 group-hover:text-[#F0F0F0] transition-colors">{title}</span>
                </div>
                <span class="text-2xs text-[#F0F0F0]-3 font-mono flex-shrink-0">{time}</span>
              </a>
            ))}
            <a href={`/docs/${cat.title.toLowerCase().replace(/\s+/g,'-')}`} class="flex items-center gap-1.5 px-3 py-2 text-xs text-[#FFEE00] hover:text-[#FFEE00]-dim transition-colors">
              View all {cat.title.toLowerCase()} docs
              <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- API reference preview -->
  <section class="py-12 border-t border-[#2C2C2C]">
    <div class="container-forge">
      <div class="grid lg:grid-cols-2 gap-12 items-start">

        <!-- Left: copy -->
        <div>
          <div class="section-label mb-5">API Reference</div>
          <h2 class="font-bold text-4xl text-[#F0F0F0] mb-5">
            Everything is an API.
          </h2>
          <p class="text-[#F0F0F0]-2 leading-relaxed mb-6">
            The full Forge CI platform is accessible via a REST API. Trigger builds,
            stream logs, download artifacts, and manage your organization — all programmatically.
          </p>
          <div class="flex gap-3">
            <a href="/docs/api" class="btn-primary btn-md">Explore API docs</a>
            <a href="/docs/api/openapi.yaml" class="btn-secondary btn-md">Download OpenAPI spec</a>
          </div>

          <!-- Code snippet -->
          <div class="terminal mt-8">
            <div class="terminal-header">
              <div class="terminal-dot bg-[#FF5F57]"></div>
              <div class="terminal-dot bg-[#FFBD2E]"></div>
              <div class="terminal-dot bg-[#28C840]"></div>
              <span class="text-xs font-mono text-[#F0F0F0]-3 ml-2">Trigger a build</span>
            </div>
            <pre class="p-5 text-xs font-mono text-[#F0F0F0]-2 overflow-x-auto leading-relaxed"><code><span class="text-[#F0F0F0]-3">curl -X POST https://api.forge-ci.dev/v2/builds \</span>
  <span class="text-[#F0F0F0]-3">  -H "Authorization: Bearer $FORGE_TOKEN" \</span>
  <span class="text-[#F0F0F0]-3">  -H "Content-Type: application/json" \</span>
  <span class="text-[#F0F0F0]-3">  -d '</span><span class="text-[#FFEE00]">{'{'}
    "project": "acme-corp/api-service",
    "branch": "main",
    "variables": {'{'}
      "DEPLOY_ENV": "staging"
    {'}'}
  {'}'}</span><span class="text-[#F0F0F0]-3">'</span></code></pre>
          </div>
        </div>

        <!-- Right: endpoint list -->
        <div class="card overflow-hidden">
          <div class="px-4 py-3 border-b border-[#2C2C2C] bg-[#111111]2/40">
            <div class="text-xs font-mono text-[#F0F0F0]-3">API v2 endpoints — preview</div>
          </div>
          <div class="divide-y divide-forge-border/50">
            {apiEndpoints.map(({ method, path, desc }) => (
              <a href="/docs/api" class="flex items-center gap-3 px-4 py-3 hover:bg-[#111111]2/50 transition-colors group">
                <span class={`badge border text-2xs font-mono flex-shrink-0 w-14 justify-center ${methodColor[method]}`}>
                  {method}
                </span>
                <code class="text-xs font-mono text-[#FFEE00] flex-1 truncate group-hover:text-[#FFEE00]-dim transition-colors">
                  {path}
                </code>
                <span class="text-xs text-[#F0F0F0]-3 flex-shrink-0 hidden sm:inline">{desc}</span>
              </a>
            ))}
          </div>
          <div class="px-4 py-3 border-t border-[#2C2C2C] text-center">
            <a href="/docs/api" class="text-xs text-[#FFEE00] hover:text-[#FFEE00]-dim transition-colors">
              View all 48 endpoints →
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Help section -->
  <section class="py-16 border-t border-[#2C2C2C]">
    <div class="container-forge">
      <div class="grid sm:grid-cols-3 gap-4">
        {[
          {
            icon: '💬',
            title: 'Community forum',
            desc: 'Ask questions, share pipelines, and get help from the Forge CI community.',
            cta: 'Join the forum →',
            href: 'https://community.forge-ci.dev',
          },
          {
            icon: '🎮',
            title: 'Discord',
            desc: 'Real-time help from the team and fellow engineers in our Discord server.',
            cta: 'Join Discord →',
            href: 'https://discord.gg/forgeci',
          },
          {
            icon: '📧',
            title: 'Email support',
            desc: 'Pro and Team customers get priority email support with < 4h response times.',
            cta: 'Contact support →',
            href: '/contact/support',
          },
        ].map(({ icon, title, desc, cta, href }) => (
          <div class="card-hover p-6 text-center">
            <div class="text-3xl mb-4" aria-hidden="true">{icon}</div>
            <h3 class="font-bold text-lg text-[#F0F0F0] mb-2">{title}</h3>
            <p class="text-sm text-[#F0F0F0]-2 mb-5 leading-relaxed">{desc}</p>
            <a href={href} class="text-sm text-[#FFEE00] hover:text-[#FFEE00]-dim transition-colors font-medium">{cta}</a>
          </div>
        ))}
      </div>
    </div>
  </section>
</MarketingLayout>

<script>
  // Cmd+K focuses search
  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      (document.getElementById('docs-search') as HTMLInputElement)?.focus();
    }
  });
</script>
