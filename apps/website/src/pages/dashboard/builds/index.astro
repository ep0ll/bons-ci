---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import { MOCK_BUILDS, formatDuration, relativeTime } from '../../../data/mock.ts';

const allBuilds = MOCK_BUILDS;
const projects  = [...new Set(allBuilds.map(b => b.project_name))];

const statusStyle: Record<string,{dot:string;cls:string;label:string}> = {
  success:   {dot:'background:#00FF88',                            cls:'badge-success', label:'Passed'},
  running:   {dot:'background:#00EEFF;animation:pulse 1s ease-in-out infinite', cls:'badge-running', label:'Running'},
  failed:    {dot:'background:#FF3333',                            cls:'badge-danger',  label:'Failed'},
  cancelled: {dot:'background:#3C3C3C',                            cls:'badge-neutral', label:'Cancelled'},
  queued:    {dot:'background:#3C3C3C;animation:pulse 1s ease-in-out infinite', cls:'badge-neutral', label:'Queued'},
};

const triggerLabel: Record<string,string> = { push:'Push', pr:'PR', manual:'Manual', schedule:'Scheduled', api:'API' };
const tabs = [{k:'all',l:'All'},{k:'running',l:'Running'},{k:'failed',l:'Failed'},{k:'cancelled',l:'Cancelled'}];
---

<DashboardLayout title="Builds" activeNav="builds" breadcrumbs={[{label:'Builds'}]}>
<div class="p-4 sm:p-6 lg:p-8 max-w-[1400px] mx-auto space-y-5">

  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold tracking-tight" style="font-family:'Space Grotesk';color:#F0F0F0">Builds</h1>
      <p class="text-xs font-mono mt-0.5" style="color:#8A8A8A">{allBuilds.length.toLocaleString()} total · all projects · last 30 days</p>
    </div>
    <div class="flex gap-2">
      <button class="btn-secondary btn-sm text-xs">
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="square" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
        Export CSV
      </button>
      <button class="btn-primary btn-sm">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd"/></svg>
        Trigger build
      </button>
    </div>
  </div>

  <!-- Filters -->
  <div class="flex flex-col sm:flex-row gap-3">
    <!-- Status tabs -->
    <div class="flex gap-0 border-2 flex-shrink-0" style="border-color:#2C2C2C;background:#111111">
      {tabs.map((tab, i) => {
        const cnt = tab.k==='all' ? allBuilds.length : allBuilds.filter(b=>b.status===tab.k).length;
        return (
          <button class="tab-btn flex items-center gap-1.5 px-3 py-2 text-xs font-semibold font-mono transition-all border-r-2 last:border-r-0"
                  style={i===0 ? 'background:#FFEE00;color:#0A0A0A;border-color:#2C2C2C' : 'background:transparent;color:#8A8A8A;border-color:#2C2C2C'}
                  data-tab={tab.k} onclick="switchTab(this)">
            {tab.l}
            <span class="px-1.5 py-0.5 text-xs font-mono border"
                  style={tab.k==='failed'?'background:rgba(255,51,51,0.1);color:#FF3333;border-color:rgba(255,51,51,0.3)':tab.k==='running'?'background:rgba(0,238,255,0.1);color:#00EEFF;border-color:rgba(0,238,255,0.3)':'background:#1A1A1A;color:#8A8A8A;border-color:#2C2C2C'}>
              {cnt}
            </span>
          </button>
        );
      })}
    </div>

    <!-- Search + filters -->
    <div class="flex flex-1 gap-2 flex-wrap">
      <div class="relative flex-1 min-w-[180px]">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color:#8A8A8A"><path stroke-linecap="square" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        <input type="search" id="build-search" placeholder="Search commit, branch, message…" class="input !pl-9 !py-2 !text-xs w-full"/>
      </div>
      <select id="proj-filter" class="input !py-2 !text-xs w-36">
        <option value="">All projects</option>
        {projects.map(p => <option value={p}>{p}</option>)}
      </select>
      <select id="trigger-filter" class="input !py-2 !text-xs w-32">
        <option value="">All triggers</option>
        <option value="push">Push</option><option value="pr">Pull Request</option>
        <option value="manual">Manual</option><option value="schedule">Scheduled</option>
      </select>
      <select class="input !py-2 !text-xs w-32">
        <option>Last 7 days</option><option>Last 30 days</option><option>All time</option>
      </select>
    </div>
  </div>

  <!-- Builds table -->
  <div class="border-2" style="border-color:#2C2C2C;background:#060606">
    <table class="table-brut" id="builds-table">
      <thead>
        <tr>
          <th class="w-6"><input type="checkbox" id="select-all" class="border border-[#3C3C3C]" style="background:#1A1A1A"/></th>
          <th>Build</th><th>Project / Branch</th><th class="hidden md:table-cell">Commit</th>
          <th>Status</th><th class="hidden sm:table-cell">Duration</th>
          <th class="hidden lg:table-cell">Credits</th><th class="hidden xl:table-cell">Trigger</th>
          <th>Author</th><th></th>
        </tr>
      </thead>
      <tbody id="builds-tbody">
        {allBuilds.map(b => {
          const s = statusStyle[b.status] ?? statusStyle.queued;
          const txt = `${b.number} ${b.branch} ${b.commit_short} ${b.commit_message} ${b.project_name}`.toLowerCase();
          return (
            <tr class="build-row group cursor-pointer" data-status={b.status} data-project={b.project_name} data-trigger={b.trigger} data-text={txt} onclick={`location.href='/dashboard/builds/${b.id}'`}>
              <td onclick="event.stopPropagation()"><input type="checkbox" class="build-check border border-[#3C3C3C]" style="background:#1A1A1A"/></td>
              <td>
                <div class="flex items-center gap-2">
                  <div class="w-2 h-2 rounded-full flex-shrink-0" style={s.dot}></div>
                  <span class="font-mono text-xs font-bold" style="color:#B0B0B0">#{b.number}</span>
                </div>
              </td>
              <td>
                <div class="text-xs font-semibold" style="color:#F0F0F0">{b.project_name}</div>
                <div class="text-xs font-mono truncate max-w-[130px]" style="color:#8A8A8A">{b.branch}</div>
              </td>
              <td class="hidden md:table-cell">
                <code class="text-xs font-mono" style="color:#8A8A8A">{b.commit_short}</code>
                <div class="text-xs truncate max-w-[180px]" style="color:#8A8A8A">{b.commit_message}</div>
              </td>
              <td><span class={s.cls}>{s.label}</span></td>
              <td class="hidden sm:table-cell">
                <div class="text-xs font-mono" style="color:#B0B0B0">{b.duration_ms ? formatDuration(b.duration_ms) : '—'}</div>
                <div class="text-xs font-mono" style="color:#8A8A8A">{b.started_at ? relativeTime(b.started_at) : ''}</div>
              </td>
              <td class="hidden lg:table-cell"><span class="text-xs font-mono" style="color:#8A8A8A">{b.credits_used > 0 ? b.credits_used : '—'}</span></td>
              <td class="hidden xl:table-cell"><span class="text-xs font-mono" style="color:#8A8A8A">{triggerLabel[b.trigger] ?? b.trigger}</span></td>
              <td>
                <div class="flex items-center gap-2">
                  <div class="avatar-sm">{b.author.name.split(' ').map((n:string)=>n[0]).join('')}</div>
                  {b.status === 'failed' && (
                    <button class="text-xs font-mono border px-1.5 py-0.5 transition-all opacity-0 group-hover:opacity-100"
                            style="border-color:rgba(0,238,255,0.3);background:rgba(0,238,255,0.08);color:#00EEFF"
                            onclick={`event.stopPropagation();location.href='/dashboard/ai-agents?build=${b.id}'`} title="Ask Sherlock">
                      ◎ Sherlock
                    </button>
                  )}
                </div>
              </td>
              <td onclick="event.stopPropagation()">
                <div class="flex gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                  <button class="btn-ghost btn-xs text-xs" style="color:#8A8A8A" title="Retry">
                    <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="square" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                  </button>
                </div>
              </td>
            </tr>
          );
        })}
      </tbody>
    </table>

    <div id="builds-empty" class="hidden py-14 text-center" style="background:#060606">
      <div class="text-4xl mb-3" style="color:#2C2C2C">◎</div>
      <h3 class="font-bold text-lg mb-1" style="font-family:'Space Grotesk';color:#F0F0F0">No builds found</h3>
      <p class="text-xs font-mono" style="color:#8A8A8A">Try adjusting your filters or search query.</p>
    </div>

    <!-- Pagination -->
    <div class="flex items-center justify-between px-5 py-3.5 border-t-2" style="border-color:#2C2C2C">
      <p class="text-xs font-mono" style="color:#8A8A8A">
        Showing <span style="color:#F0F0F0">{allBuilds.length}</span> of <span style="color:#F0F0F0">1,847</span>
      </p>
      <div class="flex gap-1">
        <button class="btn-ghost btn-xs font-mono" style="color:#8A8A8A" disabled>← Prev</button>
        {[1,2,3,'…',154,155].map(p => (
          <button class="btn-xs font-mono" style={p===1?'background:#FFEE00;color:#0A0A0A;border:none':'background:transparent;border:1px solid #2C2C2C;color:#8A8A8A'}>{p}</button>
        ))}
        <button class="btn-ghost btn-xs font-mono" style="color:#FFEE00">Next →</button>
      </div>
    </div>
  </div>
</div>
</DashboardLayout>

<script>
  const rows  = document.querySelectorAll<HTMLElement>('.build-row');
  const empty = document.getElementById('builds-empty')!;
  const tbody = document.getElementById('builds-tbody')!;

  function applyFilters() {
    const q    = (document.getElementById('build-search')   as HTMLInputElement).value.toLowerCase();
    const proj = (document.getElementById('proj-filter')    as HTMLSelectElement).value;
    const trig = (document.getElementById('trigger-filter') as HTMLSelectElement).value;
    const tab  = document.querySelector<HTMLElement>('.tab-btn[data-active]')?.dataset.tab ?? 'all';
    let v = 0;
    rows.forEach(row => {
      const ok = (!q    || row.dataset.text!.includes(q))
              && (!proj  || row.dataset.project === proj)
              && (!trig  || row.dataset.trigger === trig)
              && (tab==='all' || row.dataset.status === tab);
      row.style.display = ok ? '' : 'none';
      if (ok) v++;
    });
    empty.classList.toggle('hidden', v > 0);
    tbody.classList.toggle('hidden', v === 0);
  }

  ['build-search','proj-filter','trigger-filter'].forEach(id =>
    document.getElementById(id)?.addEventListener(id==='build-search'?'input':'change', applyFilters)
  );

  function switchTab(btn: HTMLButtonElement) {
    document.querySelectorAll<HTMLElement>('.tab-btn').forEach(b => {
      b.style.background = 'transparent'; b.style.color = '#8A8A8A';
      delete b.dataset.active;
    });
    btn.style.background = '#FFEE00'; btn.style.color = '#0A0A0A';
    btn.dataset.active = '1';
    applyFilters();
  }
  (window as any).switchTab = switchTab;

  document.getElementById('select-all')?.addEventListener('change', e => {
    const chk = (e.target as HTMLInputElement).checked;
    rows.forEach(row => { if(row.style.display!=='none') (row.querySelector('.build-check') as HTMLInputElement).checked = chk; });
  });
</script>
