---
import DashboardLayout from '../../layouts/DashboardLayout.astro';

const plugins = [
  { id:'slack-notify',    name:'Slack Notifications',  author:'Forge CI',     cat:'Notifications',   rating:4.9, installs:42000, installed:true,  official:true,  icon:'💬', price:'Free',   desc:'Rich Slack notifications for build events with actionable buttons — retry, view logs, or open PR.' },
  { id:'datadog-metrics', name:'Datadog',               author:'Datadog Inc',  cat:'Observability',   rating:4.8, installs:28400, installed:true,  official:true,  icon:'🐶', price:'Free',   desc:'Stream build metrics, traces, and logs to your Datadog account. Pre-built ForgeCI dashboard included.' },
  { id:'snyk-scan',       name:'Snyk Security',         author:'Snyk',         cat:'Security',        rating:4.7, installs:21800, installed:false, official:true,  icon:'🔐', price:'Free',   desc:'Scan dependencies, containers, and IaC for vulnerabilities on every build. Block on critical CVEs.' },
  { id:'jira-connect',    name:'Jira Integration',      author:'Atlassian',    cat:'Project Mgmt',    rating:4.5, installs:19200, installed:false, official:true,  icon:'📋', price:'Free',   desc:'Automatically transition Jira issues on build events. Link commits to issues via smart commit syntax.' },
  { id:'linear-sync',     name:'Linear',                author:'Linear',       cat:'Project Mgmt',    rating:4.9, installs:14400, installed:true,  official:true,  icon:'📐', price:'Free',   desc:'Auto-close Linear issues on merge. Add build status to issues. Bidirectional sync.' },
  { id:'pagerduty',       name:'PagerDuty',             author:'PagerDuty',    cat:'Notifications',   rating:4.6, installs:12800, installed:false, official:true,  icon:'🚨', price:'Free',   desc:'Trigger PagerDuty incidents on production deploy failures. Auto-resolve on successful deploy.' },
  { id:'terraform-cloud', name:'Terraform Cloud',       author:'HashiCorp',    cat:'Infrastructure',  rating:4.7, installs:11200, installed:false, official:true,  icon:'🏗', price:'Free',   desc:'Trigger Terraform Cloud runs from your pipeline. Post plan output as PR comments.' },
  { id:'sentry-deploy',   name:'Sentry Releases',       author:'Sentry',       cat:'Observability',   rating:4.8, installs:10400, installed:true,  official:true,  icon:'🛡', price:'Free',   desc:'Create Sentry releases on deploy. Associate commits, set environments, and track error rates.' },
  { id:'grafana-cloud',   name:'Grafana Cloud',         author:'Grafana Labs', cat:'Observability',   rating:4.5, installs:8800,  installed:false, official:true,  icon:'📈', price:'Free',   desc:'Export build metrics to Grafana Cloud via OpenTelemetry. Pre-built ForgeCI dashboard for Grafana.' },
  { id:'github-deployments',name:'GitHub Deployments', author:'Forge CI',     cat:'VCS',             rating:4.8, installs:8400,  installed:true,  official:true,  icon:'🐙', price:'Free',   desc:'Update GitHub deployment status in real-time. Shows environment URLs in PR checks.' },
  { id:'vault-secrets',   name:'HashiCorp Vault',       author:'HashiCorp',    cat:'Security',        rating:4.9, installs:7600,  installed:false, official:true,  icon:'🔑', price:'Free',   desc:'Inject dynamic secrets from Vault into pipeline steps. Short-lived creds, no secrets stored.' },
  { id:'playwright-test', name:'Playwright Reporter',   author:'Community',    cat:'Testing',         rating:4.4, installs:6200,  installed:false, official:false, icon:'🎭', price:'Free',   desc:'Beautiful HTML reports for Playwright test runs. Upload traces and screenshots as artifacts.' },
  { id:'chromatic',       name:'Chromatic',             author:'Chromatic',    cat:'Testing',         rating:4.7, installs:5800,  installed:false, official:false, icon:'🎨', price:'Free',   desc:'Publish Storybook to Chromatic and run visual regression tests on every PR.' },
  { id:'codecov',         name:'Codecov',               author:'Codecov',      cat:'Testing',         rating:4.6, installs:5400,  installed:false, official:false, icon:'📉', price:'Free',   desc:'Upload coverage reports to Codecov. Post coverage diffs as PR comments.' },
  { id:'aws-oidc',        name:'AWS OIDC Auth',         author:'Forge CI',     cat:'Security',        rating:4.9, installs:4800,  installed:true,  official:true,  icon:'☁', price:'Free',   desc:'Authenticate to AWS using OpenID Connect. No long-lived credentials stored anywhere.' },
  { id:'byoc-runner',     name:'BYOC Runner Agent',     author:'Forge CI',     cat:'Runners',         rating:4.8, installs:3400,  installed:false, official:true,  icon:'🖥', price:'Team+',  desc:'Install the Forge CI runner agent on your own cloud VMs. Full BYOC support for AWS, GCP, and Azure.' },
  { id:'anyscale',        name:'Anyscale',              author:'Anyscale',     cat:'Runners',         rating:4.7, installs:1200,  installed:false, official:true,  icon:'⚡', price:'Team+',  desc:'Run Ray distributed ML workloads on Anyscale clusters directly from your pipeline.' },
  { id:'tailscale',       name:'Tailscale Tailnet',     author:'Tailscale',    cat:'Networking',      rating:4.9, installs:2800,  installed:false, official:true,  icon:'🔗', price:'Team+',  desc:'Connect BYOC runners to private networks via Tailscale. No VPN, no public IPs needed.' },
];

const cats = ['All', ...new Set(plugins.map(p => p.cat))];

const featured = plugins.filter(p => p.installed);
const topRated = [...plugins].sort((a,b) => b.rating - a.rating).slice(0,4);
---

<DashboardLayout
  title="Marketplace"
  activeNav="marketplace"
  breadcrumbs={[{ label: 'Marketplace' }]}
>
  <div class="p-4 sm:p-6 lg:p-8 max-w-[1400px] mx-auto space-y-6">

    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
      <div>
        <h1 class="font-display font-bold text-2xl text-forge-text">Marketplace</h1>
        <p class="text-forge-text-3 text-sm mt-0.5">{plugins.length} plugins · {featured.length} installed</p>
      </div>
      <a href="/docs/plugins/sdk" class="btn-secondary btn-sm">
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
        </svg>
        Publish a plugin
      </a>
    </div>

    <!-- Installed plugins strip -->
    <div class="card p-5">
      <div class="flex items-center justify-between mb-4">
        <h2 class="font-display font-bold text-base text-forge-text">Installed ({featured.length})</h2>
        <span class="text-xs text-forge-text-3">All plugins up to date</span>
      </div>
      <div class="flex flex-wrap gap-3">
        {featured.map(p => (
          <div class="flex items-center gap-2.5 px-3 py-2 rounded-lg border border-forge-border bg-forge-surface2/40 hover:border-forge-border-2 transition-colors cursor-pointer group">
            <span class="text-base" aria-hidden="true">{p.icon}</span>
            <div>
              <div class="text-xs font-medium text-forge-text">{p.name}</div>
              <div class="text-2xs text-forge-success font-mono">v2.4.1 · active</div>
            </div>
            <button class="ml-1 text-forge-text-3 hover:text-forge-danger transition-colors opacity-0 group-hover:opacity-100 text-xs" title="Uninstall">×</button>
          </div>
        ))}
      </div>
    </div>

    <!-- Search + filters -->
    <div class="flex flex-col sm:flex-row gap-3">
      <div class="relative flex-1">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-forge-text-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <input type="search" id="plugin-search" placeholder="Search plugins, categories, authors…" class="input !pl-9 !py-2 !text-xs w-full"/>
      </div>
      <div class="flex flex-wrap gap-1.5">
        {cats.map((cat, i) => (
          <button
            class={`cat-btn text-xs font-medium px-3 py-1.5 rounded-full border transition-all ${i===0 ? 'border-forge-accent/40 bg-forge-accent-muted text-forge-accent' : 'border-forge-border text-forge-text-3 hover:border-forge-border-2 hover:text-forge-text'}`}
            data-cat={cat}
            onclick="filterPluginCat(this)"
          >
            {cat}
          </button>
        ))}
      </div>
    </div>

    <!-- Plugin grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4" id="plugin-grid">
      {plugins.map((p) => (
        <div
          class="card p-5 flex flex-col gap-3 plugin-card cursor-pointer group hover:border-forge-border-2 hover:-translate-y-0.5 transition-all duration-200"
          data-cat={p.cat}
          data-text={`${p.name} ${p.cat} ${p.author} ${p.desc}`.toLowerCase()}
          onclick={`openPlugin('${p.id}')`}
        >
          <div class="flex items-start justify-between gap-3">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-xl bg-forge-surface3 border border-forge-border flex items-center justify-center text-xl flex-shrink-0">
                {p.icon}
              </div>
              <div>
                <div class="flex items-center gap-1.5 flex-wrap">
                  <span class="text-sm font-medium text-forge-text group-hover:text-forge-accent transition-colors">{p.name}</span>
                  {p.official && <span class="badge-success border border-forge-success/20 text-2xs">Official</span>}
                </div>
                <div class="text-2xs text-forge-text-3">{p.author}</div>
              </div>
            </div>
            {p.installed ? (
              <span class="badge-accent border border-forge-accent/20 text-2xs flex-shrink-0">Installed</span>
            ) : (
              <span class={`text-2xs flex-shrink-0 font-mono ${p.price === 'Free' ? 'text-forge-text-3' : 'text-forge-warning'}`}>{p.price}</span>
            )}
          </div>

          <p class="text-xs text-forge-text-3 leading-relaxed flex-1 line-clamp-2">{p.desc}</p>

          <div class="flex items-center justify-between pt-2 border-t border-forge-border/50">
            <div class="flex items-center gap-3 text-2xs text-forge-text-3">
              <!-- Stars -->
              <div class="flex items-center gap-1">
                <svg class="w-3 h-3 text-forge-warning" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
                <span class="font-mono">{p.rating}</span>
              </div>
              <span>{(p.installs/1000).toFixed(1)}k installs</span>
              <span class="badge-neutral border border-forge-border text-2xs">{p.cat}</span>
            </div>

            <button
              onclick={`event.stopPropagation(); toggleInstall('${p.id}', this)`}
              class={`text-xs font-medium px-2.5 py-1 rounded-md transition-all border ${
                p.installed
                  ? 'border-forge-border text-forge-text-3 hover:border-forge-danger/40 hover:text-forge-danger'
                  : 'border-forge-accent/40 text-forge-accent bg-forge-accent-muted hover:bg-forge-accent hover:text-forge-bg'
              }`}
              data-installed={p.installed}
            >
              {p.installed ? 'Remove' : 'Install'}
            </button>
          </div>
        </div>
      ))}
    </div>

    <div id="plugin-empty" class="hidden py-14 text-center">
      <div class="text-3xl mb-3">🔌</div>
      <p class="text-forge-text-2">No plugins found. Try a different search.</p>
    </div>

    <!-- Build your own CTA -->
    <div class="card p-6 sm:p-8 text-center max-w-2xl mx-auto border-dashed">
      <div class="text-3xl mb-3">🛠</div>
      <h3 class="font-display font-bold text-xl text-forge-text mb-2">Build your own plugin</h3>
      <p class="text-forge-text-2 text-sm mb-6 leading-relaxed">
        Our Plugin SDK lets you hook into any pipeline event, add custom steps,
        and publish to the marketplace. Earn revenue when teams install your plugin.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/docs/plugins/sdk" class="btn-primary btn-md">Read the Plugin SDK docs</a>
        <a href="/docs/plugins/examples" class="btn-secondary btn-md">View example plugins</a>
      </div>
    </div>

  </div>
</DashboardLayout>

<script>
  const pluginCards = document.querySelectorAll<HTMLElement>('.plugin-card');
  const pluginEmpty = document.getElementById('plugin-empty')!;

  function applyPluginFilters() {
    const q = (document.getElementById('plugin-search') as HTMLInputElement).value.toLowerCase();
    const activeCat = document.querySelector<HTMLButtonElement>('.cat-btn.border-forge-accent\\/40')?.dataset.cat ?? 'All';
    let visible = 0;
    pluginCards.forEach(card => {
      const show = (!q || card.dataset.text!.includes(q)) && (activeCat === 'All' || card.dataset.cat === activeCat);
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    pluginEmpty.classList.toggle('hidden', visible > 0);
  }

  document.getElementById('plugin-search')?.addEventListener('input', applyPluginFilters);

  function filterPluginCat(btn: HTMLButtonElement) {
    document.querySelectorAll('.cat-btn').forEach(b => {
      b.className = 'cat-btn text-xs font-medium px-3 py-1.5 rounded-full border transition-all border-forge-border text-forge-text-3 hover:border-forge-border-2 hover:text-forge-text';
    });
    btn.className = 'cat-btn text-xs font-medium px-3 py-1.5 rounded-full border transition-all border-forge-accent/40 bg-forge-accent-muted text-forge-accent';
    applyPluginFilters();
  }

  function toggleInstall(id: string, btn: HTMLButtonElement) {
    const installed = btn.dataset.installed === 'true';
    if (installed) {
      btn.textContent = 'Install';
      btn.dataset.installed = 'false';
      btn.className = 'text-xs font-medium px-2.5 py-1 rounded-md transition-all border border-forge-accent/40 text-forge-accent bg-forge-accent-muted hover:bg-forge-accent hover:text-forge-bg';
    } else {
      btn.textContent = 'Remove';
      btn.dataset.installed = 'true';
      btn.className = 'text-xs font-medium px-2.5 py-1 rounded-md transition-all border border-forge-border text-forge-text-3 hover:border-forge-danger/40 hover:text-forge-danger';
    }
  }

  function openPlugin(id: string) {
    // In production: open plugin detail modal/page
    console.log('Open plugin:', id);
  }

  (window as any).filterPluginCat = filterPluginCat;
  (window as any).toggleInstall = toggleInstall;
  (window as any).openPlugin = openPlugin;
</script>
