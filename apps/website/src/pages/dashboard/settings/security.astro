---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import { MOCK_AUDIT_LOG, MOCK_ORG } from '../../../data/mock.ts';
const log = MOCK_AUDIT_LOG;
const org = MOCK_ORG;
---
<DashboardLayout title="Security" activeNav="settings" breadcrumbs={[{label:'Settings',href:'/dashboard/settings'},{label:'Security'}]}>
  <div class="p-4 sm:p-6 lg:p-8 max-w-[900px] mx-auto space-y-6">
    <div><h1 class="font-bold text-2xl text-[#F0F0F0]">Security</h1><p class="text-[#8A8A8A] text-sm mt-0.5">SSO status, MFA enforcement, active sessions, and audit logs.</p></div>

    <!-- SSO status -->
    <div class="card p-6">
      <div class="flex items-start justify-between gap-4 mb-5">
        <div><h2 class="font-bold text-base text-[#F0F0F0]">Single Sign-On</h2><p class="text-xs text-[#8A8A8A] mt-0.5">SAML 2.0 via Okta — configured Jan 12, 2024</p></div>
        <div class="flex items-center gap-2"><span class="badge-success border border-[rgba(0,255,136,0.2)] text-xs">Active</span><a href="/auth/sso" class="btn-secondary btn-sm text-xs">Configure</a></div>
      </div>
      <div class="grid sm:grid-cols-2 gap-4 mb-5">
        {[['Identity provider','Okta'],['SSO URL','https://acme.okta.com/app/forge/sso/saml'],['Entity ID','http://www.okta.com/exk8a2z3r...'],['Certificate expires','Aug 1, 2026']].map(([k,v])=>(
          <div><div class="text-xs text-[#8A8A8A] mb-0.5">{k}</div><code class="text-xs font-mono text-[#B0B0B0] truncate block">{v}</code></div>
        ))}
      </div>
      <div class="space-y-3 border-t border-[#2C2C2C] pt-4">
        {[{l:'Enforce SSO for all members',d:'Members must sign in via Okta. Password login disabled.',on:true},{l:'Auto-provision new members',d:'New Okta users automatically added to Forge CI (SCIM).',on:true},{l:'Auto-deprovision on removal',d:'Removing from Okta immediately revokes Forge CI access.',on:true}].map(s=>(
          <div class="flex items-center justify-between gap-4">
            <div><div class="text-sm font-medium text-[#F0F0F0]">{s.l}</div><div class="text-xs text-[#8A8A8A] mt-0.5">{s.d}</div></div>
            <label class="relative inline-flex items-center cursor-pointer flex-shrink-0">
              <input type="checkbox" checked={s.on} class="sr-only peer"/>
              <div class="w-9 h-5 bg-[#1A1A1A] border border-[#2C2C2C] rounded-full peer peer-checked:border-[#FFEE00] peer-checked:bg-[rgba(255,238,0,0.08)] after:content-[''] after:absolute after:top-[3px] after:left-[3px] after:w-[14px] after:h-[14px] after:bg-[#8A8A8A] after:rounded-full after:transition-all peer-checked:after:translate-x-4 peer-checked:after:bg-[#FFEE00] relative"></div>
            </label>
          </div>
        ))}
      </div>
    </div>

    <!-- MFA -->
    <div class="card p-6">
      <div class="flex items-center justify-between mb-4">
        <div><h2 class="font-bold text-base text-[#F0F0F0]">Multi-factor Authentication</h2><p class="text-xs text-[#8A8A8A] mt-0.5">4 of 7 members have MFA enabled</p></div>
        <button class="btn-primary btn-sm text-xs">Enforce MFA org-wide</button>
      </div>
      <div class="progress mb-2"><div class="progress-bar" style="width:57%"></div></div>
      <div class="flex justify-between text-xs text-[#8A8A8A] mb-5"><span>4 members with MFA</span><span>3 without</span></div>
      <div class="space-y-2">
        <div class="text-xs font-medium text-[#FF7700] mb-2">Members without MFA:</div>
        {['sara@acme-corp.io','dpark@acme-corp.io','kim@acme-corp.io'].map(e=>(
          <div class="flex items-center justify-between py-2 border-b border-[rgba(30,45,66,0.5)]">
            <span class="text-sm text-[#B0B0B0] font-mono">{e}</span>
            <button class="text-xs text-[#FFEE00] hover:text-[#FFD700] transition-colors">Send reminder</button>
          </div>
        ))}
      </div>
    </div>

    <!-- Sessions -->
    <div class="card overflow-hidden">
      <div class="flex items-center justify-between px-5 py-4 border-b border-[#2C2C2C]">
        <div><h2 class="font-bold text-base text-[#F0F0F0]">Your active sessions</h2></div>
        <button class="btn-danger btn-sm text-xs">Revoke all other</button>
      </div>
      <div class="divide-y divide-[rgba(30,45,66,0.5)]">
        {[{d:'Chrome on macOS',ip:'203.0.113.1',loc:'San Francisco, CA',t:'now',cur:true},{d:'VS Code extension',ip:'203.0.113.1',loc:'San Francisco, CA',t:'2h ago',cur:false},{d:'Forge CLI v2.4.1',ip:'203.0.113.1',loc:'San Francisco, CA',t:'5d ago',cur:false}].map(s=>(
          <div class="flex items-center gap-4 px-5 py-4">
            <div class="w-9 h-9 rounded-none bg-[#1A1A1A] border border-[#2C2C2C] flex items-center justify-center flex-shrink-0"><svg class="w-4 h-4 text-[#8A8A8A]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg></div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2"><span class="text-sm font-medium text-[#F0F0F0]">{s.d}</span>{s.cur&&<span class="badge-success border border-[rgba(0,255,136,0.2)] text-xs">Current</span>}</div>
              <div class="text-xs text-[#8A8A8A] mt-0.5">{s.ip} · {s.loc} · {s.t}</div>
            </div>
            {!s.cur && <button class="btn-ghost btn-sm text-xs text-[#FF3333] flex-shrink-0">Revoke</button>}
          </div>
        ))}
      </div>
    </div>

    <!-- Audit log -->
    <div class="card overflow-hidden">
      <div class="flex items-center justify-between px-5 py-4 border-b border-[#2C2C2C]">
        <div><h2 class="font-bold text-base text-[#F0F0F0]">Audit log</h2><p class="text-xs text-[#8A8A8A] mt-0.5">90-day retention</p></div>
        <div class="flex gap-2">
          <select class="input !py-1.5 !text-xs w-32"><option>All actions</option><option>Member events</option><option>Secret events</option><option>SSO events</option></select>
          <button class="btn-secondary btn-sm text-xs">Export</button>
        </div>
      </div>
      <table class="table-forge">
        <thead><tr><th>Actor</th><th>Action</th><th class="hidden md:table-cell">Resource</th><th class="hidden lg:table-cell">IP</th><th>Time</th></tr></thead>
        <tbody>
          {log.map(e=>(
            <tr>
              <td><span class="text-xs text-[#B0B0B0]">{e.actor}</span></td>
              <td><code class:list={['text-xs font-mono', e.severity==='warning'?'text-[#FF7700]':e.severity==='danger'?'text-[#FF3333]':'text-[#8A8A8A]']}>{e.action}</code></td>
              <td class="hidden md:table-cell"><span class="text-xs text-[#8A8A8A] truncate max-w-[200px] block">{e.resource}</span></td>
              <td class="hidden lg:table-cell"><span class="text-xs font-mono text-[#8A8A8A]">{e.ip}</span></td>
              <td><span class="text-xs text-[#8A8A8A]">{e.timestamp.slice(11,16)} UTC</span></td>
            </tr>
          ))}
        </tbody>
      </table>
      <div class="px-5 py-3 border-t border-[#2C2C2C] text-center"><a href="#" class="text-xs text-[#FFEE00] hover:underline">Load more →</a></div>
    </div>
  </div>
</DashboardLayout>
