---
import DashboardLayout from '../../layouts/DashboardLayout.astro';

const secrets = [
  { id:'s1', name:'NPM_TOKEN',             scope:'org',  env:null,          created:'Jan 12',  updated:'Mar 28', lastUsed:'2 min ago',  rotationDue:null,        usedIn:8 },
  { id:'s2', name:'DOCKER_PASSWORD',       scope:'org',  env:null,          created:'Jan 12',  updated:'Mar 28', lastUsed:'2 min ago',  rotationDue:null,        usedIn:5 },
  { id:'s3', name:'DATABASE_URL',          scope:'proj', env:'production',   created:'Feb 3',   updated:'Apr 10', lastUsed:'14 min ago', rotationDue:'May 1',     usedIn:2 },
  { id:'s4', name:'STRIPE_SECRET_KEY',     scope:'proj', env:'production',   created:'Feb 8',   updated:'Feb 8',  lastUsed:'1h ago',     rotationDue:'Apr 20',    usedIn:1 },
  { id:'s5', name:'SLACK_WEBHOOK_URL',     scope:'org',  env:null,          created:'Feb 12',  updated:'Feb 12', lastUsed:'3h ago',     rotationDue:null,        usedIn:12 },
  { id:'s6', name:'AWS_ACCESS_KEY_ID',     scope:'org',  env:null,          created:'Mar 1',   updated:'Mar 1',  lastUsed:'5h ago',     rotationDue:'May 15',    usedIn:4 },
  { id:'s7', name:'AWS_SECRET_ACCESS_KEY', scope:'org',  env:null,          created:'Mar 1',   updated:'Mar 1',  lastUsed:'5h ago',     rotationDue:'May 15',    usedIn:4 },
  { id:'s8', name:'SENTRY_AUTH_TOKEN',     scope:'proj', env:'staging',      created:'Mar 14',  updated:'Mar 14', lastUsed:'2d ago',     rotationDue:null,        usedIn:2 },
];

const tokens = [
  { id:'t1', name:'CI deployment token',    prefix:'fci_live_',  scopes:['builds:read','builds:write','artifacts:read'], created:'Jan 12', lastUsed:'2 min ago',  expires:null,       creator:'Ada Lovelace' },
  { id:'t2', name:'Monitoring read-only',   prefix:'fci_live_',  scopes:['builds:read','metrics:read'],                  created:'Feb 8',  lastUsed:'10 min ago', expires:null,       creator:'Tomás Reyes' },
  { id:'t3', name:'Release automation',     prefix:'fci_live_',  scopes:['builds:write','secrets:read','tokens:read'],   created:'Mar 1',  lastUsed:'1h ago',     expires:'2025-06-01',creator:'Ada Lovelace' },
  { id:'t4', name:'Terraform integration',  prefix:'fci_live_',  scopes:['builds:read'],                                 created:'Mar 14', lastUsed:'3d ago',     expires:null,       creator:'Olu Adeyemi' },
];

const scopeColor: Record<string, string> = {
  'builds:read':    'badge-info border border-[rgba(51,170,255,0.3)]',
  'builds:write':   'badge-warning border border-[rgba(255,119,0,0.3)]',
  'artifacts:read': 'badge-neutral border border-[#2C2C2C]',
  'metrics:read':   'badge-neutral border border-[#2C2C2C]',
  'secrets:read':   'badge-danger border border-[rgba(255,51,51,0.3)]',
  'tokens:read':    'badge-neutral border border-[#2C2C2C]',
};
---

<DashboardLayout
  title="Secrets & Tokens"
  activeNav="secrets"
  breadcrumbs={[{ label: 'Settings', href: '/dashboard/settings' }, { label: 'Secrets & API Tokens' }]}
>
  <div class="p-4 sm:p-6 lg:p-8 max-w-[1000px] mx-auto space-y-6">

    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
      <div>
        <h1 class="font-bold text-2xl text-[#F0F0F0]">Secrets & API Tokens</h1>
        <p class="text-[#F0F0F0]-3 text-sm mt-0.5">Encrypted at rest · never logged · masked in build output</p>
      </div>
    </div>

    <!-- ── Secrets section ─────────────────────── -->
    <div class="card overflow-hidden">
      <div class="flex items-center justify-between px-5 py-4 border-b border-[#2C2C2C]">
        <div>
          <h2 class="font-bold text-base text-[#F0F0F0]">Environment secrets</h2>
          <p class="text-xs text-[#F0F0F0]-3 mt-0.5">{secrets.length} secrets · encrypted with AES-256</p>
        </div>
        <div class="flex gap-2">
          <select class="input !py-1.5 !text-xs w-36">
            <option>All scopes</option>
            <option>Organization</option>
            <option>Project</option>
          </select>
          <button id="add-secret-btn" class="btn-primary btn-sm">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd"/>
            </svg>
            New secret
          </button>
        </div>
      </div>

      <table class="table-forge">
        <thead>
          <tr>
            <th>Name</th>
            <th>Scope</th>
            <th class="hidden md:table-cell">Last used</th>
            <th class="hidden lg:table-cell">Updated</th>
            <th class="hidden xl:table-cell">Rotation due</th>
            <th class="hidden sm:table-cell">Used in</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {secrets.map(s => (
            <tr class="group">
              <td>
                <div class="flex items-center gap-2.5">
                  <svg class="w-3.5 h-3.5 text-[#FF7700] flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/>
                  </svg>
                  <div>
                    <code class="text-xs font-mono text-[#FFEE00]">{s.name}</code>
                    <div class="text-2xs font-mono text-[#F0F0F0]-3">••••••••••••••••</div>
                  </div>
                </div>
              </td>
              <td>
                <div class="flex flex-col gap-1">
                  <span class={`badge border text-2xs ${s.scope === 'org' ? 'badge-info border-[rgba(51,170,255,0.3)]' : 'badge-neutral border-[#2C2C2C]'}`}>
                    {s.scope === 'org' ? 'Organization' : 'Project'}
                  </span>
                  {s.env && <span class="text-2xs text-[#F0F0F0]-3 font-mono">{s.env}</span>}
                </div>
              </td>
              <td class="hidden md:table-cell">
                <span class={`text-xs font-mono ${s.lastUsed.includes('min') || s.lastUsed.includes('h') ? 'text-[#F0F0F0]-2' : 'text-[#F0F0F0]-3'}`}>
                  {s.lastUsed}
                </span>
              </td>
              <td class="hidden lg:table-cell">
                <span class="text-xs text-[#F0F0F0]-3">{s.updated}</span>
              </td>
              <td class="hidden xl:table-cell">
                {s.rotationDue ? (
                  <span class={`text-xs font-mono ${new Date(s.rotationDue) < new Date(Date.now() + 7*86400000) ? 'text-[#FF3333]' : 'text-[#FF7700]'}`}>
                    {s.rotationDue}
                  </span>
                ) : (
                  <span class="text-xs text-[#F0F0F0]-3">—</span>
                )}
              </td>
              <td class="hidden sm:table-cell">
                <span class="text-xs text-[#F0F0F0]-3">{s.usedIn} pipelines</span>
              </td>
              <td>
                <div class="flex gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                  <button class="btn-ghost btn-sm !p-1.5 text-[#F0F0F0]-3 hover:text-[#F0F0F0]" title="Edit">
                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                    </svg>
                  </button>
                  <button class="btn-ghost btn-sm !p-1.5 text-[#F0F0F0]-3 hover:text-[#FF7700]" title="Rotate">
                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                    </svg>
                  </button>
                  <button class="btn-ghost btn-sm !p-1.5 text-[#FF3333]" title="Delete">
                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                    </svg>
                  </button>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- ── API Tokens section ──────────────────── -->
    <div class="card overflow-hidden">
      <div class="flex items-center justify-between px-5 py-4 border-b border-[#2C2C2C]">
        <div>
          <h2 class="font-bold text-base text-[#F0F0F0]">API Tokens</h2>
          <p class="text-xs text-[#F0F0F0]-3 mt-0.5">For programmatic access to the Forge CI API</p>
        </div>
        <button id="create-token-btn" class="btn-primary btn-sm">
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd"/>
          </svg>
          Create token
        </button>
      </div>

      <table class="table-forge">
        <thead>
          <tr>
            <th>Name</th>
            <th>Prefix</th>
            <th>Scopes</th>
            <th class="hidden md:table-cell">Created by</th>
            <th class="hidden lg:table-cell">Created</th>
            <th class="hidden xl:table-cell">Expires</th>
            <th>Last used</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {tokens.map(t => (
            <tr class="group">
              <td>
                <div class="flex items-center gap-2">
                  <svg class="w-3.5 h-3.5 text-[#FFEE00] flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/>
                  </svg>
                  <span class="text-sm font-medium text-[#F0F0F0]">{t.name}</span>
                </div>
              </td>
              <td>
                <code class="text-xs font-mono text-[#F0F0F0]-3">{t.prefix}••••••</code>
              </td>
              <td>
                <div class="flex flex-wrap gap-1">
                  {t.scopes.map(s => (
                    <span class={`badge text-2xs ${scopeColor[s] ?? 'badge-neutral border border-[#2C2C2C]'}`}>
                      {s}
                    </span>
                  ))}
                </div>
              </td>
              <td class="hidden md:table-cell">
                <span class="text-xs text-[#F0F0F0]-3">{t.creator}</span>
              </td>
              <td class="hidden lg:table-cell">
                <span class="text-xs text-[#F0F0F0]-3">{t.created}</span>
              </td>
              <td class="hidden xl:table-cell">
                {t.expires ? (
                  <span class="text-xs font-mono text-[#FF7700]">{t.expires}</span>
                ) : (
                  <span class="text-xs text-[#F0F0F0]-3">Never</span>
                )}
              </td>
              <td>
                <span class="text-xs font-mono text-[#F0F0F0]-2">{t.lastUsed}</span>
              </td>
              <td>
                <div class="flex gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                  <button class="btn-ghost btn-sm !p-1.5 text-[#F0F0F0]-3 hover:text-[#F0F0F0]" title="Copy token prefix">
                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
                    </svg>
                  </button>
                  <button class="btn-ghost btn-sm !p-1.5 text-[#FF3333]" title="Revoke">
                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                    </svg>
                  </button>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- Info box -->
    <div class="card p-5 border-[rgba(51,170,255,0.3)] /20">
      <div class="flex items-start gap-3">
        <svg class="w-5 h-5 text-[#33AAFF] flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
        </svg>
        <div class="text-sm text-[#F0F0F0]-2 leading-relaxed">
          <strong class="text-[#F0F0F0]">OIDC authentication is recommended</strong> over long-lived API tokens for cloud provider access (AWS, GCP, Azure). 
          Use tokens only for Forge CI API calls. <a href="/docs/auth/oidc" class="text-[#FFEE00] hover:underline">Learn about OIDC →</a>
        </div>
      </div>
    </div>

  </div>

  <!-- Create token modal -->
  <div id="token-modal" class="fixed inset-0 z-50 hidden" role="dialog" aria-modal="true">
    <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" id="token-backdrop"></div>
    <div class="relative flex items-center justify-center min-h-screen p-4">
      <div class="w-full max-w-md bg-[#111111] border border-[#2C2C2C] rounded-none shadow-modal animate-scale-in overflow-hidden">
        <div class="flex items-center justify-between px-6 py-5 border-b border-[#2C2C2C]">
          <h2 class="font-bold text-lg text-[#F0F0F0]">Create API token</h2>
          <button id="token-close" class="text-[#F0F0F0]-3 hover:text-[#F0F0F0]">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>
        <div class="px-6 py-5 space-y-4">
          <div>
            <label class="input-label">Token name</label>
            <input type="text" class="input" placeholder="e.g. GitHub Actions integration"/>
          </div>
          <div>
            <label class="input-label">Expiration</label>
            <select class="input">
              <option>No expiration</option>
              <option>30 days</option>
              <option>90 days</option>
              <option>1 year</option>
              <option>Custom date…</option>
            </select>
          </div>
          <div>
            <label class="input-label mb-3">Scopes</label>
            <div class="space-y-2">
              {[
                { scope:'builds:read',    desc:'Read builds, logs, and status' },
                { scope:'builds:write',   desc:'Trigger and cancel builds' },
                { scope:'artifacts:read', desc:'Download build artifacts' },
                { scope:'secrets:read',   desc:'Read secret names (not values)' },
                { scope:'metrics:read',   desc:'Read usage metrics and analytics' },
                { scope:'tokens:read',    desc:'List API tokens' },
              ].map(({ scope, desc }) => (
                <label class="flex items-center gap-3 cursor-pointer">
                  <input type="checkbox" class="rounded border-[#2C2C2C]"/>
                  <div>
                    <code class="text-xs font-mono text-[#FFEE00]">{scope}</code>
                    <span class="text-xs text-[#F0F0F0]-3 ml-2">{desc}</span>
                  </div>
                </label>
              ))}
            </div>
          </div>
        </div>
        <div class="flex gap-3 px-6 py-4 border-t border-[#2C2C2C] bg-[#111111]2/30">
          <button id="token-cancel" class="btn-secondary btn-md flex-1 justify-center">Cancel</button>
          <button onclick="generateToken()" class="btn-primary btn-md flex-1 justify-center">Generate token</button>
        </div>

        <!-- Token reveal (shown after generation) -->
        <div id="token-reveal" class="hidden px-6 pb-5 space-y-3">
          <div class="p-3 rounded-none  border border-forge-success/30 text-xs text-[#00FF88] font-medium">
            ✓ Token generated — copy it now, you won't see it again.
          </div>
          <div class="flex items-center gap-2">
            <code class="flex-1 font-mono text-xs bg-[#111111]2 border border-[#2C2C2C] rounded-none px-3 py-2.5 text-[#FFEE00] break-all">
              fci_live_1a2b3c4d5e6f7g8h9i0j1k2l3m4n5o6p
            </code>
            <button class="btn-primary btn-sm flex-shrink-0">Copy</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Add secret modal -->
  <div id="secret-modal" class="fixed inset-0 z-50 hidden" role="dialog" aria-modal="true">
    <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" id="secret-backdrop"></div>
    <div class="relative flex items-center justify-center min-h-screen p-4">
      <div class="w-full max-w-md bg-[#111111] border border-[#2C2C2C] rounded-none shadow-modal animate-scale-in overflow-hidden">
        <div class="flex items-center justify-between px-6 py-5 border-b border-[#2C2C2C]">
          <h2 class="font-bold text-lg text-[#F0F0F0]">Add environment secret</h2>
          <button id="secret-close" class="text-[#F0F0F0]-3 hover:text-[#F0F0F0]">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>
        <div class="px-6 py-5 space-y-4">
          <div>
            <label class="input-label">Secret name</label>
            <input type="text" class="input font-mono uppercase" placeholder="MY_SECRET_VALUE"/>
          </div>
          <div>
            <label class="input-label">Secret value</label>
            <textarea rows={3} class="input font-mono text-xs resize-none" placeholder="Paste your secret value here…"></textarea>
            <p class="text-2xs text-[#F0F0F0]-3 mt-1">Encrypted with AES-256 · never logged · masked in build output</p>
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="input-label">Scope</label>
              <select class="input">
                <option>Organization</option>
                <option>Project</option>
              </select>
            </div>
            <div>
              <label class="input-label">Environment</label>
              <select class="input">
                <option value="">All environments</option>
                <option>production</option>
                <option>staging</option>
                <option>development</option>
              </select>
            </div>
          </div>
          <div>
            <label class="input-label">Rotation reminder (optional)</label>
            <input type="date" class="input"/>
            <p class="text-2xs text-[#F0F0F0]-3 mt-1">You'll be reminded to rotate this secret before this date.</p>
          </div>
        </div>
        <div class="flex gap-3 px-6 py-4 border-t border-[#2C2C2C] bg-[#111111]2/30">
          <button id="secret-cancel" class="btn-secondary btn-md flex-1 justify-center">Cancel</button>
          <button class="btn-primary btn-md flex-1 justify-center">Add secret</button>
        </div>
      </div>
    </div>
  </div>
</DashboardLayout>

<script>
  function setupModal(openId: string, modalId: string, closeIds: string[]) {
    const modal = document.getElementById(modalId)!;
    document.getElementById(openId)?.addEventListener('click', () => modal.classList.remove('hidden'));
    closeIds.forEach(id => document.getElementById(id)?.addEventListener('click', () => modal.classList.add('hidden')));
    modal.querySelector('[id$="-backdrop"]')?.addEventListener('click', () => modal.classList.add('hidden'));
  }

  setupModal('create-token-btn', 'token-modal', ['token-close','token-cancel']);
  setupModal('add-secret-btn',   'secret-modal', ['secret-close','secret-cancel']);

  function generateToken() {
    document.getElementById('token-reveal')?.classList.remove('hidden');
  }
  (window as any).generateToken = generateToken;

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') {
      ['token-modal','secret-modal'].forEach(id => document.getElementById(id)?.classList.add('hidden'));
    }
  });
</script>
