---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { MOCK_SHERLOCK_ANALYSES, MOCK_SHERLOCK_PATTERNS } from '../../data/mock.ts';
const analyses = MOCK_SHERLOCK_ANALYSES;
const patterns = MOCK_SHERLOCK_PATTERNS;
---
<DashboardLayout title="Sherlock AI" activeNav="ai-agents" breadcrumbs={[{label:'Sherlock AI'}]}>
<div class="p-4 sm:p-6 lg:p-8 max-w-[1400px] mx-auto space-y-5">

  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-4">
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 border-2 flex items-center justify-center" style="border-color:#00EEFF;background:rgba(0,238,255,0.08)">
        <span class="text-lg font-mono font-bold" style="color:#00EEFF">◎</span>
      </div>
      <div>
        <h1 class="text-2xl font-bold tracking-tight" style="font-family:'Space Grotesk';color:#F0F0F0">Sherlock</h1>
        <p class="text-xs font-mono mt-0.5" style="color:#00EEFF">AI Build Intelligence · Active</p>
      </div>
    </div>
    <button id="ask-btn" class="btn-primary btn-sm">
      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="square" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
      Ask Sherlock
    </button>
  </div>

  <!-- Stats -->
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-0 border-l-2 border-t-2" style="border-color:#2C2C2C">
    {[{l:'Failures diagnosed',v:'847',c:'#00EEFF'},{l:'Avg confidence',v:'93.4%',c:'#00FF88'},{l:'Fixes applied',v:'612',c:'#FFEE00'},{l:'MTTR reduction',v:'74%',c:'#00FF88'}].map(s=>(
      <div class="border-r-2 border-b-2 p-5" style="border-color:#2C2C2C;background:#060606">
        <div class="text-xs font-mono mb-1" style="color:#666666">{s.l}</div>
        <div class="text-2xl font-bold" style={`font-family:'Space Grotesk';color:${s.c};letter-spacing:-0.04em`}>{s.v}</div>
      </div>
    ))}
  </div>

  <div class="grid lg:grid-cols-[1fr_360px] gap-5">
    <div class="space-y-5">

      <!-- Active patterns -->
      <div class="card p-5">
        <div class="flex items-center justify-between mb-4">
          <div class="text-xs font-mono font-bold uppercase tracking-widest" style="color:#FFEE00">Active patterns</div>
          <span class="badge-warning">{patterns.length} detected</span>
        </div>
        <div class="space-y-3">
          {patterns.map(p => (
            <div class="p-4 border-2 border-l-4" style={`border-color:${p.severity==='warning'?'rgba(255,119,0,0.3)':'rgba(0,238,255,0.3)'};border-left-color:${p.severity==='warning'?'#FF7700':'#00EEFF'};background:${p.severity==='warning'?'rgba(255,119,0,0.04)':'rgba(0,238,255,0.04)'}`}>
              <div class="flex items-start gap-3">
                <span class="text-sm flex-shrink-0" style={`color:${p.severity==='warning'?'#FF7700':'#00EEFF'}`}>{p.severity==='warning'?'⚠':'ℹ'}</span>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 flex-wrap mb-1">
                    <span class="text-sm font-semibold" style="color:#F0F0F0">{p.title}</span>
                    <span class="badge-neutral">{p.project_name}</span>
                    {p.occurrence_count && <span class="text-xs font-mono" style="color:#FF7700">{p.occurrence_count}×</span>}
                  </div>
                  <p class="text-xs mb-2" style="color:#666666">{p.description}</p>
                  <div class="flex items-start gap-2 text-xs" style="color:#3C3C3C">
                    <span style="color:#00EEFF;flex-shrink:0">→</span><span style="color:#666666">{p.suggestion}</span>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Recent analyses with confidence rings -->
      <div class="card overflow-hidden">
        <div class="px-5 py-4 border-b-2 text-xs font-mono font-bold uppercase tracking-widest" style="border-color:#2C2C2C;color:#FFEE00">Recent analyses</div>
        <div class="divide-y-2" style="border-color:#2C2C2C">
          {analyses.map(a => (
            <div class="px-5 py-4" style="border-top:2px solid #2C2C2C">
              <div class="flex items-start gap-4">
                <!-- Confidence ring (SVG donut) -->
                <div class="relative flex-shrink-0 w-12 h-12">
                  <svg class="w-12 h-12 -rotate-90" viewBox="0 0 40 40">
                    <circle cx="20" cy="20" r="16" fill="none" stroke="#2C2C2C" stroke-width="4"/>
                    <circle cx="20" cy="20" r="16" fill="none"
                            stroke={a.confidence>94?'#00FF88':a.confidence>84?'#FF7700':'#33AAFF'}
                            stroke-width="4"
                            stroke-dasharray={`${(a.confidence/100)*100.53} 100.53`}
                            stroke-linecap="square"/>
                  </svg>
                  <span class="absolute inset-0 flex items-center justify-center text-xs font-mono font-bold" style="color:#F0F0F0">{a.confidence}</span>
                </div>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 flex-wrap mb-1">
                    <a href={`/dashboard/builds/${a.build_id}`} class="text-sm font-semibold transition-colors" style="color:#F0F0F0" onmouseover="this.style.color='#FFEE00'" onmouseout="this.style.color='#F0F0F0'">
                      #{a.build_id.replace('b','')} — {a.project_name}
                    </a>
                    <span class="text-xs font-mono" style="color:#666666">{a.branch}</span>
                  </div>
                  <div class="text-xs font-mono mb-1" style="color:#666666">Failed: <span style="color:#FF3333">{a.failed_step}</span></div>
                  <p class="text-xs mb-2" style="color:#AAAAAA">{a.root_cause}</p>
                  {a.fix_diff && (
                    <pre class="text-xs font-mono border-2 p-2 overflow-x-auto" style="border-color:#2C2C2C;background:#050505"><code class="code-remove">{a.fix_diff.split('\n')[0]}</code>{'\n'}<code class="code-add">{a.fix_diff.split('\n')[1]}</code></pre>
                  )}
                </div>
                <div class="flex flex-col items-end gap-2 flex-shrink-0">
                  <span class="text-xs font-mono" style="color:#3C3C3C">{a.analyzed_at.slice(11,16)} UTC</span>
                  <button class="text-xs font-mono border-2 px-2 py-0.5 transition-all"
                          style="border-color:rgba(0,255,136,0.3);color:#00FF88"
                          onmouseover="this.style.background='#00FF88';this.style.color='#0A0A0A'"
                          onmouseout="this.style.background='transparent';this.style.color='#00FF88'">Apply fix</button>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Live chat -->
    <div class="card flex flex-col overflow-hidden" style="height:600px">
      <!-- Chat header -->
      <div class="flex items-center gap-3 px-4 py-3.5 border-b-2 flex-shrink-0" style="border-color:#2C2C2C;background:#111111">
        <div class="w-7 h-7 border-2 flex items-center justify-center flex-shrink-0" style="border-color:#00EEFF;background:rgba(0,238,255,0.08)">
          <span class="text-xs font-mono font-bold" style="color:#00EEFF">S</span>
        </div>
        <div>
          <div class="text-sm font-semibold" style="color:#F0F0F0">Sherlock</div>
          <div class="flex items-center gap-1.5 text-xs font-mono" style="color:#00FF88">
            <span class="w-1.5 h-1.5 rounded-full bg-[#00FF88] animate-pulse"></span>Ready
          </div>
        </div>
      </div>

      <!-- Messages -->
      <div class="flex-1 overflow-y-auto p-4 space-y-4 no-scrollbar" id="chat-msgs">
        <div class="flex gap-2.5">
          <div class="w-6 h-6 border-2 flex items-center justify-center flex-shrink-0 mt-0.5" style="border-color:#00EEFF;background:rgba(0,238,255,0.08)">
            <span class="text-xs font-mono font-bold" style="color:#00EEFF">S</span>
          </div>
          <div class="px-4 py-3 border-2 max-w-[88%]" style="border-color:#2C2C2C;background:#111111">
            <p class="text-sm leading-relaxed" style="color:#AAAAAA">Hi! I can analyze build failures, detect patterns, and suggest fixes. Try asking: "Why did the last build fail?" or "What's causing the flaky tests?"</p>
          </div>
        </div>
        <!-- Quick prompts -->
        <div class="flex flex-wrap gap-1.5 pl-9">
          {['Diagnose last failure','Why is sccache slow?','Show flaky tests','What broke main?'].map(p => (
            <button class="text-xs font-mono border-2 px-2.5 py-1 transition-all"
                    style="border-color:#2C2C2C;color:#666666"
                    onmouseover="this.style.borderColor='#FFEE00';this.style.color='#FFEE00'"
                    onmouseout="this.style.borderColor='#2C2C2C';this.style.color='#666666'"
                    onclick={`sendMsg('${p}')`}>{p}</button>
          ))}
        </div>
      </div>

      <!-- Input -->
      <div class="border-t-2 p-3 flex-shrink-0" style="border-color:#2C2C2C">
        <div class="flex items-end gap-2">
          <textarea id="sherlock-input" rows={1} placeholder="Ask Sherlock about any build failure…"
                    class="input resize-none flex-1 text-sm input-mono" style="min-height:42px;max-height:120px"
                    onkeydown="handleKey(event)"></textarea>
          <button onclick="sendSherlockMsg()" class="btn-primary btn-md flex-shrink-0 !px-3">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="square" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Sherlock settings -->
  <div class="card p-5">
    <div class="text-xs font-mono font-bold uppercase tracking-widest mb-4" style="color:#FFEE00">Sherlock settings</div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {[
        {l:'Auto-analyze failures',   d:'Run Sherlock on every failed build',               on:true},
        {l:'Auto-open PRs (>95%)',    d:'Open PRs for high-confidence fixes',               on:false},
        {l:'Flaky test detection',    d:'Learn from history to identify non-deterministic', on:true},
        {l:'Pattern notifications',   d:'Notify Slack when recurring patterns detected',     on:true},
      ].map(s => (
        <div class="flex items-start gap-3">
          <div class={`toggle-switch flex-shrink-0 mt-0.5 ${s.on ? 'on' : ''}`} onclick="this.classList.toggle('on')">
            <div class="toggle-thumb"></div>
          </div>
          <div><div class="text-sm font-semibold" style="color:#F0F0F0">{s.l}</div><div class="text-xs mt-0.5" style="color:#666666">{s.d}</div></div>
        </div>
      ))}
    </div>
  </div>

</div>
</DashboardLayout>

<script>
  const msgs  = document.getElementById('chat-msgs')!;
  const input = document.getElementById('sherlock-input') as HTMLTextAreaElement;

  function append(text: string, role: 'user'|'s', loading = false): HTMLElement {
    const div = document.createElement('div');
    div.className = `flex gap-2.5 ${role==='user'?'justify-end':''}`;
    if (role === 's') {
      div.innerHTML = `<div class="w-6 h-6 border-2 flex items-center justify-center flex-shrink-0 mt-0.5" style="border-color:#00EEFF;background:rgba(0,238,255,0.08)"><span class="text-xs font-mono font-bold" style="color:#00EEFF">S</span></div><div class="px-4 py-3 border-2 max-w-[88%]" style="border-color:#2C2C2C;background:#111111">${loading?'<div class="flex gap-1"><span class="w-1.5 h-1.5 rounded-full animate-bounce" style="background:#00EEFF"></span><span class="w-1.5 h-1.5 rounded-full animate-bounce" style="background:#00EEFF;animation-delay:0.15s"></span><span class="w-1.5 h-1.5 rounded-full animate-bounce" style="background:#00EEFF;animation-delay:0.3s"></span></div>':`<p class="text-sm leading-relaxed whitespace-pre-line" style="color:#AAAAAA">${text}</p>`}</div>`;
    } else {
      div.innerHTML = `<div class="px-4 py-3 border-2 max-w-[88%]" style="border-color:rgba(255,238,0,0.3);background:rgba(255,238,0,0.06)"><p class="text-sm" style="color:#F0F0F0">${text}</p></div>`;
    }
    msgs.appendChild(div); msgs.scrollTop = msgs.scrollHeight; return div;
  }

  async function sendSherlockMsg() {
    const val = input.value.trim(); if (!val) return;
    append(val, 'user'); input.value = ''; input.style.height = 'auto';
    const ld = append('', 's', true);
    await new Promise(r => setTimeout(r, 1400)); ld.remove();
    const reply = val.toLowerCase().includes('fail') || val.toLowerCase().includes('diagn')
      ? "I analyzed build #1845.\n\nRoot cause: AuthMiddleware.ts:34 calls user.id without checking if user is null. The new test exposes this path.\n\n**Fix:** Add `if (!user || ...)` before the property access.\n\nConfidence: 97%. Want me to open a PR?"
      : val.toLowerCase().includes('flak') || val.toLowerCase().includes('test')
      ? "Reviewing 30 runs of AuthMiddleware.test.ts — it fails 4 times, always in 'should handle concurrent session invalidation'.\n\nThe issue is a race condition without proper await. I can generate a patch."
      : "I've reviewed your recent builds and configuration. Everything looks healthy across main pipelines. Is there a specific build or project you'd like me to dig into?";
    append(reply, 's');
  }

  function sendMsg(text: string) { input.value = text; sendSherlockMsg(); }
  function handleKey(e: KeyboardEvent) {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendSherlockMsg(); }
    const ta = e.target as HTMLTextAreaElement;
    ta.style.height = 'auto'; ta.style.height = Math.min(ta.scrollHeight, 120) + 'px';
  }

  document.getElementById('ask-btn')?.addEventListener('click', () => input.focus());
  (window as any).sendSherlockMsg = sendSherlockMsg;
  (window as any).sendMsg = sendMsg;
  (window as any).handleKey = handleKey;
</script>
