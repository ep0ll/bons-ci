---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { MOCK_METRICS, MOCK_MEMBERS, formatDuration } from '../../data/mock.ts';
import { seriesToSmoothPath, seriesToAreaPath, generateHeatmapData } from '../../lib/charts.ts';

const metrics = MOCK_METRICS;
const heatmap = generateHeatmapData(7, 24, 42);
const days = ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];

function spark(data: {ts:string;value:number}[], w=240, h=44) {
  return {path:seriesToSmoothPath(data,{width:w,height:h,paddingTop:4,paddingBottom:4}),area:seriesToAreaPath(data,{width:w,height:h,paddingTop:4,paddingBottom:4})};
}
const s1 = spark(metrics.series.success_rate);
const s2 = spark(metrics.series.avg_duration);
const s3 = spark(metrics.series.cache_hit_rate);
const s4 = spark(metrics.series.egress_gb);
const bv  = seriesToSmoothPath(metrics.series.build_count,{width:560,height:120,paddingTop:6,paddingBottom:6});
const bva = seriesToAreaPath (metrics.series.build_count,{width:560,height:120,paddingTop:6,paddingBottom:6});

const anomalies = [
  {type:'warning',title:'Build duration spike — api-service',body:'Avg duration +2.3× vs 7-day baseline on Apr 12. Likely ESLint rule added.',time:'2 days ago'},
  {type:'danger', title:'Failure rate spike — mobile/release', body:'Success rate fell to 72% for 3h before recovering. Correlated with Xcode 15.4 agent update.',time:'3 days ago'},
  {type:'success',title:'Cache efficiency improved — web-app',  body:'Cache hit rate 91% → 97% after adding node_modules to restore-keys.',time:'5 days ago'},
];
---

<DashboardLayout title="Insights" activeNav="insights" breadcrumbs={[{label:'Insights'}]}>
<div class="p-4 sm:p-6 lg:p-8 max-w-[1400px] mx-auto space-y-5">

  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold tracking-tight" style="font-family:'Space Grotesk';color:#F0F0F0">Insights</h1>
      <p class="text-xs font-mono mt-0.5" style="color:#666666">Deep analytics across builds, teams, and costs.</p>
    </div>
    <div class="flex gap-2">
      <select class="input !py-2 !text-xs w-36"><option>Last 30 days</option><option>Last 7 days</option><option>Last 90 days</option></select>
      <button class="btn-secondary btn-sm text-xs">Export</button>
    </div>
  </div>

  <!-- KPI sparklines -->
  <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-0 border-l-2 border-t-2" style="border-color:#2C2C2C">
    {([
      {label:'Success rate',   value:`${metrics.success_rate}%`,  delta:'+0.8%',up:true, ...s1,color:'#00FF88'},
      {label:'Avg build time', value:formatDuration(metrics.avg_duration_ms), delta:'-22%',up:true, ...s2,color:'#FFEE00'},
      {label:'Cache hit rate', value:`${metrics.cache_hit_rate}%`,delta:'+3.1%',up:true, ...s3,color:'#00EEFF'},
      {label:'Egress/day',     value:`${metrics.series.egress_gb[metrics.series.egress_gb.length-1].value.toFixed(1)} GB`,delta:'+8%',up:false,...s4,color:'#FF7700'},
    ] as {label:string;value:string;delta:string;up:boolean;path:string;area:string;color:string}[]).map(s => (
      <div class="border-r-2 border-b-2 p-4" style="border-color:#2C2C2C;background:#060606">
        <div class="text-xs font-mono mb-1" style="color:#666666">{s.label}</div>
        <div class="text-xl font-bold" style={`font-family:'Space Grotesk';color:${s.color};letter-spacing:-0.03em`}>{s.value}</div>
        <div class="text-xs font-mono my-2" style={`color:${s.up?'#00FF88':'#FF3333'}`}>{s.up?'↑':'↓'} {s.delta} vs prev period</div>
        <svg class="w-full" height="44" viewBox="0 0 240 44" preserveAspectRatio="none">
          <defs><linearGradient id={`ig-${s.label}`} x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color={s.color} stop-opacity="0.2"/><stop offset="100%" stop-color={s.color} stop-opacity="0"/></linearGradient></defs>
          <path d={s.area} fill={`url(#ig-${s.label})`}/><path d={s.path} fill="none" stroke={s.color} stroke-width="1.5" stroke-linejoin="round" stroke-linecap="round"/>
        </svg>
      </div>
    ))}
  </div>

  <!-- Build volume + heatmap -->
  <div class="grid lg:grid-cols-[1fr_auto] gap-0 border-l-2 border-t-2" style="border-color:#2C2C2C">
    <!-- Volume chart -->
    <div class="border-r-2 border-b-2 p-5" style="border-color:#2C2C2C;background:#060606">
      <div class="flex items-center justify-between mb-5">
        <div>
          <div class="text-xs font-mono font-bold uppercase tracking-widest mb-0.5" style="color:#FFEE00">Build volume</div>
          <div class="text-xs font-mono" style="color:#666666">Daily builds over 30 days</div>
        </div>
        <div class="badge-success">Trending up</div>
      </div>
      <div class="relative" style="height:140px">
        <svg class="w-full h-full" viewBox="0 0 560 120" preserveAspectRatio="none">
          <defs><linearGradient id="bvg2" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#FFEE00" stop-opacity="0.12"/><stop offset="100%" stop-color="#FFEE00" stop-opacity="0"/></linearGradient></defs>
          {[0,30,60,90,120].map(y=><line x1="0" y1={y} x2="560" y2={y} stroke="#2C2C2C" stroke-width="0.5"/>)}
          <path d={bva} fill="url(#bvg2)"/>
          <path d={bv}  fill="none" stroke="#FFEE00" stroke-width="1.5" stroke-linejoin="round" stroke-linecap="round"/>
        </svg>
        <div class="absolute bottom-0 left-0 right-4 flex justify-between -mb-5 text-xs font-mono" style="color:#3C3C3C">
          <span>Mar 16</span><span>Mar 23</span><span>Mar 30</span><span>Apr 7</span><span>Today</span>
        </div>
      </div>
    </div>

    <!-- Heatmap -->
    <div class="border-r-2 border-b-2 p-5 flex-shrink-0" style="border-color:#2C2C2C;background:#060606;width:300px">
      <div class="text-xs font-mono font-bold uppercase tracking-widest mb-4" style="color:#FFEE00">Build heatmap</div>
      <div class="text-xs font-mono mb-3" style="color:#3C3C3C">Activity by day × hour (UTC)</div>
      <div class="space-y-1.5">
        {days.map((day, di) => (
          <div class="flex items-center gap-1.5">
            <span class="text-xs font-mono w-6 flex-shrink-0" style="color:#3C3C3C">{day}</span>
            <div class="flex gap-0.5">
              {Array.from({length:24},(_,hi) => {
                const cell = heatmap.find(c=>c.day===di&&c.hour===hi);
                return <div class="w-2.5 h-2.5" style={`background:rgba(255,238,0,${cell?cell.value:0})`} title={`${day} ${hi}:00 · ~${cell?.raw??0} builds`}></div>;
              })}
            </div>
          </div>
        ))}
        <div class="flex items-center gap-1.5 mt-2 pt-2 border-t" style="border-color:#2C2C2C">
          <span class="text-xs font-mono w-6" style="color:#3C3C3C">UTC</span>
          <div class="flex justify-between flex-1 text-xs font-mono" style="color:#3C3C3C"><span>0</span><span>6h</span><span>12h</span><span>18h</span><span>23h</span></div>
        </div>
        <div class="flex items-center gap-2 mt-1 text-xs font-mono" style="color:#3C3C3C">
          <span>Low</span>{[0.1,0.3,0.5,0.7,0.9].map(o=><div class="w-2.5 h-2.5" style={`background:rgba(255,238,0,${o})`}></div>)}<span>High</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Project breakdown + team activity -->
  <div class="grid lg:grid-cols-2 gap-0 border-l-2 border-t-2" style="border-color:#2C2C2C">
    <!-- Project performance -->
    <div class="border-r-2 border-b-2" style="border-color:#2C2C2C;background:#060606">
      <div class="px-5 py-4 border-b-2 text-xs font-mono font-bold uppercase tracking-widest" style="border-color:#2C2C2C;color:#FFEE00">Project performance</div>
      <table class="table-brut">
        <thead><tr><th>Project</th><th>Builds</th><th>Success</th><th>Avg</th><th>Cache</th><th>Cost %</th></tr></thead>
        <tbody>
          {metrics.by_project.map(p => (
            <tr>
              <td><span class="text-xs font-semibold" style="color:#F0F0F0">{p.project_name}</span></td>
              <td><span class="text-xs font-mono">{p.build_count}</span></td>
              <td><span class="text-xs font-mono font-bold" style={`color:${p.success_rate>=98?'#00FF88':p.success_rate>=95?'#FF7700':'#FF3333'}`}>{p.success_rate}%</span></td>
              <td><span class="text-xs font-mono" style="color:#AAAAAA">{formatDuration(p.avg_duration_ms)}</span></td>
              <td><span class="text-xs font-mono" style={`color:${p.cache_hit_rate>90?'#00FF88':'#666666'}`}>{p.cache_hit_rate>0?`${p.cache_hit_rate}%`:'N/A'}</span></td>
              <td>
                <div class="flex items-center gap-1.5">
                  <div class="w-12 h-1" style="background:#111111;border:1px solid #2C2C2C">
                    <div class="h-full" style={`width:${p.cost_pct}%;background:#FFEE00`}></div>
                  </div>
                  <span class="text-xs font-mono" style="color:#666666">{p.cost_pct}%</span>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- Team activity -->
    <div class="border-r-2 border-b-2" style="border-color:#2C2C2C;background:#060606">
      <div class="px-5 py-4 border-b-2 text-xs font-mono font-bold uppercase tracking-widest" style="border-color:#2C2C2C;color:#FFEE00">Team activity</div>
      <div class="divide-y-2" style="--tw-divide-opacity:1;border-color:#2C2C2C">
        {metrics.by_member.map(m => (
          <div class="flex items-center gap-3 px-5 py-3.5" style="border-top:2px solid #2C2C2C">
            <div class="avatar-md">{m.initials}</div>
            <div class="flex-1 min-w-0">
              <div class="text-xs font-semibold" style="color:#F0F0F0">{m.user_name}</div>
              <div class="flex items-center gap-2 mt-1">
                <div class="flex-1 h-1 max-w-[80px]" style="background:#111111;border:1px solid #2C2C2C">
                  <div class="h-full" style={`width:${(m.build_count/312)*100}%;background:#FFEE00`}></div>
                </div>
                <span class="text-xs font-mono" style="color:#666666">{m.build_count}</span>
              </div>
            </div>
            <div class="text-right">
              <div class="text-xs font-mono font-bold" style={`color:${m.success_rate>=98?'#00FF88':m.success_rate>=95?'#FF7700':'#FF3333'}`}>{m.success_rate}%</div>
              <div class="text-xs font-mono" style="color:#666666">{formatDuration(m.avg_duration_ms)} avg</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Anomaly detection -->
  <div class="card p-5">
    <div class="flex items-center justify-between mb-4">
      <div class="text-xs font-mono font-bold uppercase tracking-widest" style="color:#FFEE00">Anomaly detection</div>
      <span class="badge-warning">ML-powered</span>
    </div>
    <div class="grid sm:grid-cols-3 gap-0 border-l-2 border-t-2" style="border-color:#2C2C2C">
      {anomalies.map(a => (
        <div class="border-r-2 border-b-2 p-4" style={`border-color:#2C2C2C;border-left-width:3px;border-left-color:${a.type==='danger'?'#FF3333':a.type==='warning'?'#FF7700':'#00FF88'}`}>
          <div class="text-xs font-semibold mb-1" style={`color:${a.type==='danger'?'#FF3333':a.type==='warning'?'#FF7700':'#00FF88'}`}>{a.title}</div>
          <p class="text-xs leading-relaxed mb-2" style="color:#666666">{a.body}</p>
          <div class="text-xs font-mono" style="color:#3C3C3C">{a.time}</div>
        </div>
      ))}
    </div>
  </div>

</div>
</DashboardLayout>
