---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import { PRICING_TIERS } from '../data/mock.ts';
const tiers = PRICING_TIERS;

const matrix = [
  { cat:'Builds',       rows:[['Build minutes / month',['2,000','20,000','100,000','Unlimited']],['Concurrent jobs',['1','10','50','Unlimited']],['Build timeout',['30 min','60 min','120 min','Custom']],['Matrix builds',[false,true,true,true]],['Auto-cancel redundant',[false,true,true,true]]] },
  { cat:'Identity',     rows:[['Ory Kratos authn',[true,true,true,true]],['Email + password',[true,true,true,true]],['Magic link',[true,true,true,true]],['WebAuthn / Passkeys',[false,true,true,true]],['TOTP (Authenticator app)',[false,true,true,true]],['SMS OTP',[false,false,true,true]],['OAuth (GitHub/Google/GitLab)',[true,true,true,true]],['SAML 2.0 SSO',[false,false,true,true]],['SCIM provisioning',[false,false,false,true]],['Ory Keto RBAC',[true,true,true,true]]] },
  { cat:'Security',     rows:[['Encrypted secrets',[true,true,true,true]],['OIDC token exchange',[false,true,true,true]],['Network egress rules',[false,false,true,true]],['IP allowlisting',[false,false,true,true]],['Tailnet / VPC peering',[false,false,false,true]],['Audit logs',['7 days','30 days','90 days','Unlimited']]] },
  { cat:'Runners',      rows:[['Linux x64',[true,true,true,true]],['Linux ARM64',[false,true,true,true]],['macOS M2',[false,true,true,true]],['Windows',[false,false,true,true]],['BYOC runners',[false,false,true,true]],['Dedicated fleet',[false,false,false,true]]] },
  { cat:'Caching',      rows:[['Cache storage',['500 MB','10 GB','100 GB','Custom']],['Cache TTL',['7 days','14 days','30 days','Custom']],['Remote build cache',[false,true,true,true]],['Cross-branch cache',[false,true,true,true]]] },
  { cat:'Observability',rows:[['Build analytics',[true,true,true,true]],['Heatmaps & flame graphs',[false,true,true,true]],['DAG pipeline view',[false,true,true,true]],['Span waterfall (traces)',[false,false,true,true]],['Custom dashboards',[false,false,true,true]]] },
  { cat:'AI',           rows:[['Sherlock AI (failure analysis)',[false,'50/mo','Unlimited','Unlimited']],['Flaky test detection',[false,false,true,true]],['Auto-fix PRs',[false,false,true,true]],['Anomaly detection',[false,false,true,true]]] },
  { cat:'Support',      rows:[['Community forum',[true,true,true,true]],['Email support',[false,true,true,true]],['Priority SLA',[false,false,true,true]],['Slack / Teams channel',[false,false,true,true]],['Dedicated CSM',[false,false,false,true]],['Uptime SLA',['—','99.9%','99.9%','99.99%']]] },
];
---

<MarketingLayout title="Pricing — Forge CI" description="Simple, transparent pricing for every engineering team. Ory identity stack included on all plans.">

  <!-- Hero -->
  <section class="relative pt-32 pb-16 overflow-hidden">
    <div class="absolute inset-0 bg-grid-brut opacity-30 pointer-events-none"></div>
    <div class="container-forge relative z-10 text-center">
      <div class="section-label mb-5 justify-center">Pricing</div>
      <h1 class="section-title mb-5">Simple pricing.<br/><span class="text-gradient-brut">No surprises.</span></h1>
      <p class="section-subtitle mx-auto text-center mb-8">Start free. Scale as you grow. Cancel any time.</p>
    </div>
  </section>

  <!-- Tier cards -->
  <section class="pb-16">
    <div class="container-forge">
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-0 border-l-2 border-t-2 mb-8" style="border-color:#2C2C2C">
        {tiers.map(tier => (
          <div class:list={['border-r-2 border-b-2 p-6 flex flex-col relative', tier.featured ? 'bg-[rgba(255,238,0,0.03)]' : '']} style="border-color:#2C2C2C">
            {tier.badge && <div class="badge-accent mb-3 self-start">{tier.badge}</div>}
            <div class="text-xs font-mono uppercase tracking-widest mb-1" style="color:#8A8A8A">{tier.name}</div>
            <div class="flex items-baseline gap-1 mb-0.5">
              <span class="text-3xl font-bold" style={`font-family:'Space Grotesk';letter-spacing:-0.04em;color:${tier.featured?'#FFEE00':'#F0F0F0'}`}>
                {tier.custom ? 'Custom' : tier.monthly_price === 0 ? 'Free' : `$${tier.monthly_price}`}
              </span>
              {!tier.custom && tier.monthly_price! > 0 && <span class="text-sm" style="color:#8A8A8A">/user/mo</span>}
            </div>
            <p class="text-xs font-mono mb-5" style="color:#8A8A8A">{tier.tagline}</p>
            <div class="p-3 border-2 mb-5" style="border-color:#2C2C2C;background:#111111">
              {[['Build mins', tier.build_minutes],['Parallelism', tier.parallelism],['Cache', tier.cache_gb],['Runners', tier.runners]].map(([k,v]) => (
                <div class="flex justify-between text-xs py-1 border-b last:border-0" style="border-color:#222222">
                  <span style="color:#8A8A8A">{k}</span>
                  <span class="font-mono font-semibold" style="color:#F0F0F0">{v}</span>
                </div>
              ))}
            </div>
            <ul class="space-y-2 mb-5 flex-1">
              {tier.features.map(f => (
                <li class="flex items-start gap-2 text-xs" style="color:#B0B0B0">
                  <span style="color:#00FF88;flex-shrink:0">✓</span>{f}
                </li>
              ))}
            </ul>
            <a href={tier.cta_href} class={tier.featured ? 'btn-primary btn-md w-full justify-center' : 'btn-secondary btn-md w-full justify-center'}>
              {tier.cta}
            </a>
          </div>
        ))}
      </div>

      <!-- Comparison matrix -->
      <div class="card overflow-hidden">
        <div class="px-6 py-4 border-b-2" style="border-color:#2C2C2C;background:#111111">
          <h2 class="font-bold" style="font-family:'Space Grotesk';color:#F0F0F0">Full feature comparison</h2>
        </div>
        <div class="overflow-x-auto">
          <table class="table-brut" style="min-width:640px">
            <thead>
              <tr>
                <th style="width:40%">Feature</th>
                {tiers.map(t => <th class="text-center" style={t.featured?'color:#FFEE00':''}>{ t.name}</th>)}
              </tr>
            </thead>
            <tbody>
              {matrix.map(section => (
                <>
                  <tr style="background:#111111">
                    <td colspan={5} class="text-xs font-mono uppercase tracking-widest" style="color:#8A8A8A;padding:8px 16px">{section.cat}</td>
                  </tr>
                  {section.rows.map(([feat, vals]) => (
                    <tr>
                      <td class="text-xs" style="color:#B0B0B0">{feat}</td>
                      {(vals as (boolean|string)[]).map((val, vi) => (
                        <td class="text-center" style={tiers[vi]?.featured ? 'background:rgba(255,238,0,0.02)' : ''}>
                          {val === true  ? <span style="color:#00FF88;font-size:14px">✓</span>
                          : val === false ? <span style="color:#2C2C2C">—</span>
                          : <span class="text-xs font-mono" style={tiers[vi]?.featured?'color:#FFEE00;font-weight:600':'color:#B0B0B0'}>{val}</span>}
                        </td>
                      ))}
                    </tr>
                  ))}
                </>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section border-t-2" style="border-color:#2C2C2C;background:#060606">
    <div class="container-forge max-w-3xl">
      <h2 class="font-bold text-3xl tracking-tight text-center mb-12" style="font-family:'Space Grotesk';color:#F0F0F0">Frequently asked</h2>
      <div class="space-y-0 border-t-2" style="border-color:#2C2C2C">
        {[
          ['What counts as a build minute?','A minute of compute on a standard Linux x64 small runner (2 vCPU, 4 GB RAM). Larger runners consume minutes at a multiplier (large = 4×). macOS = 10× due to Apple licensing.'],
          ['Is there a free trial for Team?','Yes — all paid plans include a 14-day free trial. No credit card required. Downgrade to Hobby any time.'],
          ['What happens if I exceed my minutes?','We never stop your builds. You\'re charged per-minute overage at a discounted rate. Set hard spending limits in billing settings.'],
          ['Is the Ory identity stack included?','Yes. Ory Kratos, Hydra, and Keto are included on all plans. WebAuthn and TOTP on Pro+, SAML on Team+.'],
          ['Can I bring my own cloud runners?','Yes. BYOC is available on Team and Enterprise. Register any Linux or macOS host with the runner agent v2.'],
          ['Do you offer discounts for annual billing?','Yes — 20% off on Pro and Team. Enterprise contracts are negotiated annually and include volume discounts.'],
        ].map(([q,a],i) => (
          <div class="border-b-2" style="border-color:#2C2C2C">
            <button class="w-full flex items-center justify-between gap-4 px-0 py-5 text-left" onclick={`toggleFaq(${i})`}>
              <span class="text-sm font-semibold" style="color:#F0F0F0">{q}</span>
              <svg class={`faq-icon-${i} w-4 h-4 flex-shrink-0 transition-transform`} fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color:#FFEE00"><path stroke-linecap="square" stroke-width="2.5" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div class={`faq-body-${i} hidden pb-5`}>
              <p class="text-sm" style="color:#8A8A8A">{a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Enterprise CTA -->
  <section class="section border-t-2 text-center" style="border-color:#2C2C2C">
    <div class="container-forge max-w-2xl">
      <div class="text-4xl mb-4">▣</div>
      <h2 class="text-3xl font-bold tracking-tight mb-4" style="font-family:'Space Grotesk';color:#F0F0F0">Need a custom enterprise contract?</h2>
      <p class="section-subtitle mx-auto mb-8">Custom pricing, dedicated infra, SAML, SCIM, BAA, 99.99% SLA, and a dedicated CSM.</p>
      <a href="/enterprise" class="btn-primary btn-xl">Talk to enterprise sales →</a>
    </div>
  </section>
</MarketingLayout>

<script>
  function toggleFaq(i: number) {
    const body = document.querySelector<HTMLElement>(`.faq-body-${i}`)!;
    const icon = document.querySelector<SVGElement>(`.faq-icon-${i}`)!;
    const open = !body.classList.contains('hidden');
    body.classList.toggle('hidden', open);
    icon.style.transform = open ? '' : 'rotate(180deg)';
  }
  (window as any).toggleFaq = toggleFaq;
</script>
