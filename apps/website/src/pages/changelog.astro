---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import { CHANGELOG } from '../data/changelog.ts';
import type { ChangelogEntryType } from '../types/index.ts';

const typeConfig: Record<ChangelogEntryType, { cls: string; icon: string; label: string }> = {
  feature:     { cls: 'badge-accent',   icon: '⚡', label: 'Feature' },
  improvement: { cls: 'badge-info',     icon: '↑',  label: 'Improvement' },
  fix:         { cls: 'badge-success',  icon: '✓',  label: 'Fix' },
  breaking:    { cls: 'badge-danger',   icon: '⚠',  label: 'Breaking' },
};
---
<MarketingLayout
  title="Changelog — Forge CI"
  description="Every new feature, improvement, fix, and breaking change across every release of Forge CI."
>
  <!-- Hero -->
  <section class="relative pt-32 pb-12 overflow-hidden">
    <div class="absolute inset-0 bg-grid-brut opacity-20 pointer-events-none"></div>
    <div class="container-forge relative z-10">
      <div class="section-label mb-5">Changelog</div>
      <h1 class="section-title mb-4">Every change, documented.</h1>
      <p class="section-subtitle max-w-xl">
        New features, performance improvements, bug fixes, and breaking changes — indexed for every release.
      </p>
    </div>
  </section>

  <div class="container-forge max-w-3xl pb-24">
    <!-- Version legend -->
    <div class="flex flex-wrap gap-3 mb-12 pb-8 border-b-2" style="border-color:#2C2C2C">
      {Object.entries(typeConfig).map(([, cfg]) => (
        <div class="flex items-center gap-2 text-xs font-mono" style="color:#AAAAAA">
          <span class={`badge ${cfg.cls}`}>{cfg.icon} {cfg.label}</span>
        </div>
      ))}
    </div>

    <!-- Entries -->
    <div class="space-y-0">
      {CHANGELOG.map((release, ri) => (
        <div id={release.version} class="relative">
          <!-- Timeline connector -->
          {ri < CHANGELOG.length - 1 && (
            <div class="absolute left-[103px] top-0 bottom-0 w-px" style="background:#2C2C2C;transform:translateX(-50%)"></div>
          )}

          <div class="grid grid-cols-[96px_1fr] gap-8 pb-14">
            <!-- Date column -->
            <div class="pt-3 text-right">
              <div class="text-xs font-mono leading-relaxed" style="color:#666666">
                {release.date.slice(0, 7)}
              </div>
            </div>

            <!-- Content column -->
            <div class="relative">
              <!-- Version bullet -->
              <div class="absolute -left-[42px] top-3 w-4 h-4 flex items-center justify-center"
                   style={`background:${release.highlight ? '#FFEE00' : '#1A1A1A'};border:2px solid ${release.highlight ? '#FFEE00' : '#2C2C2C'}`}>
              </div>

              <!-- Header -->
              <div class="flex items-center gap-3 mb-5">
                <div class="text-xl font-bold" style="font-family:'Space Grotesk';color:#F0F0F0;letter-spacing:-0.03em">
                  {release.version}
                </div>
                {release.highlight && <span class="badge-accent">Highlight</span>}
              </div>

              <!-- Entry cards -->
              <div class="space-y-3">
                {release.entries.map(entry => {
                  const cfg = typeConfig[entry.type];
                  return (
                    <div class="card p-5" style={entry.breaking ? 'border-color:rgba(255,51,51,0.4)' : ''}>
                      <div class="flex items-start gap-3 mb-2">
                        <span class={`badge ${cfg.cls} flex-shrink-0`}>{cfg.icon} {cfg.label}</span>
                        {entry.breaking && <span class="badge-danger flex-shrink-0">Breaking</span>}
                        {entry.tags.slice(0, 2).map(t => <span class="badge-neutral flex-shrink-0">{t}</span>)}
                      </div>
                      <div class="text-sm font-semibold mb-2" style="color:#F0F0F0;font-family:'Space Grotesk'">{entry.title}</div>
                      <p class="text-xs leading-relaxed" style="color:#AAAAAA">{entry.body}</p>
                    </div>
                  );
                })}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Subscribe to updates -->
    <div class="card p-8 text-center mt-8 border-t-2" style="border-color:#2C2C2C">
      <div class="section-label mb-4 justify-center">Stay updated</div>
      <h2 class="text-xl font-bold mb-3" style="font-family:'Space Grotesk';color:#F0F0F0">Get release notifications</h2>
      <p class="text-sm mb-5" style="color:#666666">Subscribe to the RSS feed or follow us on Twitter.</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/rss/changelog.xml" class="btn-secondary btn-md">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
            <path d="M5 3a1 1 0 000 2c5.523 0 10 4.477 10 10a1 1 0 102 0C17 8.373 11.627 3 5 3zm.001 5.924a1 1 0 10-.002 2 5.076 5.076 0 015.077 5.077 1 1 0 102 0 7.077 7.077 0 00-7.075-7.077zM4 15a2 2 0 114 0 2 2 0 01-4 0z"/>
          </svg>
          RSS feed
        </a>
        <a href="/auth/signup" class="btn-primary btn-md">Start free →</a>
      </div>
    </div>
  </div>
</MarketingLayout>
