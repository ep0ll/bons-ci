---
import MarketingLayout from '../layouts/MarketingLayout.astro';

const certifications = [
  { name:'SOC 2 Type II',    icon:'🛡', status:'Current', detail:'Annual audit by Prescient Assurance. Report available under NDA.' },
  { name:'ISO 27001',        icon:'📋', status:'Current', detail:'Information security management system. Certified by BSI.' },
  { name:'GDPR',             icon:'🇪🇺', status:'Compliant', detail:'DPA available. EU-US Data Privacy Framework participant.' },
  { name:'HIPAA',            icon:'🏥', status:'Ready', detail:'BAA available. Architecture reviewed by healthcare compliance counsel.' },
  { name:'FedRAMP',          icon:'🏛', status:'In progress', detail:'Targeting Moderate authorization in H2 2025.' },
  { name:'Penetration test', icon:'🔍', status:'Annual', detail:'External pentest by NCC Group. Last completed Feb 2025.' },
];

const controls = [
  { title:'Encryption at rest',        desc:'All data encrypted with AES-256-GCM. Key management via AWS KMS with automatic rotation.' },
  { title:'Encryption in transit',     desc:'TLS 1.3 enforced everywhere. HSTS with preloading. Certificate pinning for runner auth.' },
  { title:'Zero-trust network',        desc:'Runners are ephemeral VMs. No persistent network state between builds. mTLS for all internal communication.' },
  { title:'Secret isolation',          desc:'Secrets injected via memory-mapped files. Never written to disk, never logged. Masked in all log output.' },
  { title:'OIDC token exchange',       desc:'OIDC replaces long-lived cloud credentials. Short-lived tokens scoped per job, auto-expired.' },
  { title:'Dependency scanning',       desc:'All third-party dependencies scanned by Snyk and Dependabot with automatic PR creation for CVEs.' },
  { title:'Access control',            desc:'Role-based access with least privilege. Every access reviewed quarterly. Departures trigger immediate revocation.' },
  { title:'Vulnerability disclosure',  desc:'Responsible disclosure program on HackerOne. 90-day coordinated disclosure. Bug bounty available.' },
];
---

<MarketingLayout
  title="Security — Forge CI"
  description="Forge CI's security architecture, compliance certifications, and responsible disclosure program."
>
  <!-- Hero -->
  <section class="relative pt-32 pb-20 overflow-hidden">
    <div class="absolute inset-0 bg-grid opacity-25 pointer-events-none" aria-hidden="true"></div>
    <div class="container-forge relative z-10 text-center max-w-3xl mx-auto">
      <div class="section-label mb-6">Security</div>
      <h1 class="section-title mb-6">
        Security isn't a feature.
        <span class="text-gradient"> It's the foundation.</span>
      </h1>
      <p class="text-lg text-forge-text-2 leading-relaxed mb-10 mx-auto">
        Every build runs in an ephemeral, isolated environment. Secrets never touch disk.
        And every action is audited. Here's how we protect your code and your team.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/docs/security" class="btn-primary btn-lg">Read security docs</a>
        <a href="mailto:security@forge-ci.dev" class="btn-secondary btn-lg">Report a vulnerability</a>
      </div>
    </div>
  </section>

  <!-- Certifications -->
  <section class="section border-t border-forge-border bg-forge-surface/20">
    <div class="container-forge">
      <h2 class="font-display font-bold text-3xl text-forge-text text-center mb-10">Certifications & compliance</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {certifications.map(({ name, icon, status, detail }) => (
          <div class="card p-5">
            <div class="flex items-start gap-3">
              <span class="text-2xl flex-shrink-0">{icon}</span>
              <div>
                <div class="flex items-center gap-2 mb-1 flex-wrap">
                  <span class="text-sm font-medium text-forge-text">{name}</span>
                  <span class={`badge text-2xs border ${
                    status === 'Current' || status === 'Compliant' || status === 'Annual'
                      ? 'badge-success border-forge-success/20'
                      : status === 'Ready'
                      ? 'badge-info border-forge-info/20'
                      : 'badge-warning border-forge-warning/20'
                  }`}>{status}</span>
                </div>
                <p class="text-xs text-forge-text-3 leading-relaxed">{detail}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Security controls -->
  <section class="section border-t border-forge-border">
    <div class="container-forge">
      <div class="text-center mb-12">
        <h2 class="font-display font-bold text-3xl text-forge-text">Security controls</h2>
        <p class="text-forge-text-2 mt-3">How we protect every build, every secret, every byte.</p>
      </div>
      <div class="grid sm:grid-cols-2 gap-4">
        {controls.map(({ title, desc }) => (
          <div class="flex gap-4 p-5 card hover:border-forge-accent/20 transition-colors">
            <svg class="w-5 h-5 text-forge-success flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 1.944A11.954 11.954 0 012.166 5C2.056 5.649 2 6.319 2 7c0 5.225 3.34 9.67 8 11.317C14.66 16.67 18 12.225 18 7c0-.682-.057-1.35-.166-2.001A11.954 11.954 0 0110 1.944zM11 14a1 1 0 11-2 0 1 1 0 012 0zm0-7a1 1 0 10-2 0v3a1 1 0 102 0V7z" clip-rule="evenodd"/>
            </svg>
            <div>
              <h3 class="text-sm font-medium text-forge-text mb-1">{title}</h3>
              <p class="text-xs text-forge-text-2 leading-relaxed">{desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Disclosure + contact -->
  <section class="section border-t border-forge-border bg-forge-surface/20">
    <div class="container-forge max-w-2xl text-center">
      <div class="text-3xl mb-4">🔍</div>
      <h2 class="font-display font-bold text-3xl text-forge-text mb-4">Found a vulnerability?</h2>
      <p class="text-forge-text-2 mb-6 leading-relaxed">
        We run a responsible disclosure program on HackerOne. We target a 90-day coordinated disclosure timeline and offer bug bounties for qualifying reports. We will never pursue legal action against researchers acting in good faith.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="https://hackerone.com/forge-ci" class="btn-primary btn-lg" target="_blank" rel="noopener noreferrer">Report on HackerOne</a>
        <a href="mailto:security@forge-ci.dev" class="btn-secondary btn-lg">Email security team</a>
      </div>
      <p class="text-xs text-forge-text-3 mt-5">
        PGP key available at <code class="font-mono text-forge-accent">forge-ci.dev/.well-known/pgp-key.asc</code>
      </p>
    </div>
  </section>
</MarketingLayout>
