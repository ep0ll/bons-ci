{
  "name": "forge-ci",
  "type": "module",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev":       "astro dev",
    "start":     "astro dev",
    "build":     "astro build",
    "preview":   "astro preview",
    "check":     "astro check",
    "test":      "node --experimental-vm-modules node_modules/.bin/jest --passWithNoTests",
    "test:unit": "jest src/tests/unit --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint":      "eslint src --ext .ts,.tsx,.astro",
    "format":    "prettier --write src"
  },
  "dependencies": {
    "astro":                          "^4.8.0",
    "@astrojs/react":                 "^3.3.0",
    "@astrojs/tailwind":              "^5.1.0",
    "@astrojs/sitemap":               "^3.1.0",
    "@astrojs/check":                 "^0.7.0",
    "react":                          "^18.3.0",
    "react-dom":                      "^18.3.0",
    "recharts":                       "^2.12.0",
    "d3":                             "^7.9.0",
    "@xyflow/react":                  "^12.0.0",
    "cytoscape":                      "^3.30.0",
    "@ory/client":                    "^1.13.0",
    "@ory/kratos-client":             "^1.2.0",
    "@ory/hydra-client":              "^2.2.0",
    "@ory/keto-client":               "^0.11.0",
    "tailwindcss":                    "^3.4.0",
    "clsx":                           "^2.1.1",
    "date-fns":                       "^3.6.0",
    "zod":                            "^3.23.0",
    "jose":                           "^5.4.0",
    "nanoid":                         "^5.0.0",
    "@tanstack/react-table":          "^8.17.0",
    "@tanstack/react-query":          "^5.45.0",
    "react-hot-toast":                "^2.4.1",
    "framer-motion":                  "^11.2.0",
    "prism-react-renderer":           "^2.3.0",
    "ansi-to-html":                   "^0.7.2"
  },
  "devDependencies": {
    "@types/react":                   "^18.3.0",
    "@types/react-dom":               "^18.3.0",
    "@types/node":                    "^20.0.0",
    "@types/d3":                      "^7.4.0",
    "@types/cytoscape":               "^3.21.0",
    "typescript":                     "^5.4.0",
    "autoprefixer":                   "^10.4.0",
    "jest":                           "^29.0.0",
    "@jest/globals":                  "^29.0.0",
    "ts-jest":                        "^29.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "extensionsToTreatAsEsm": [".ts"],
    "moduleNameMapper": { "^@/(.*)$": "<rootDir>/src/$1" }
  }
}
