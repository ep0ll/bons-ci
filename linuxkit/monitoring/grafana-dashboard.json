{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "bonnie-cicd Prometheus datasource",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "stat",      "name": "Stat",       "version": "" },
    { "type": "panel", "id": "timeseries","name": "Time series", "version": "" },
    { "type": "panel", "id": "gauge",     "name": "Gauge",       "version": "" },
    { "type": "panel", "id": "table",     "name": "Table",       "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "bonnie-cicd LinuxKit — build system, lazy pull, and host metrics",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100, "title": "Build System", "type": "row" },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 10 },
            { "color": "red",    "value": 50 }
          ]}
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1, "title": "Build Queue Depth", "type": "stat",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "bonnie_build_queue_depth", "legendFormat": "queue" }]
    },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "red",    "value": null },
            { "color": "yellow", "value": 0.5 },
            { "color": "green",  "value": 0.8 }
          ]}
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2, "title": "Cache Hit Rate", "type": "gauge",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "bonnie_cache_hit_ratio", "legendFormat": "hit rate" }]
    },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "unit": "s" } },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3, "title": "Boot Time", "type": "stat",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background",
        "fieldConfig": { "defaults": { "thresholds": { "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 5 },
          { "color": "red",    "value": 10 }
        ]}}}
      },
      "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "bonnie_boot_seconds", "legendFormat": "boot time" }]
    },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "unit": "s" } },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4, "title": "Build p99 Duration", "type": "stat",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "datasource": "${DS_PROMETHEUS}",
        "expr": "histogram_quantile(0.99, rate(bonnie_build_duration_seconds_bucket[5m]))",
        "legendFormat": "p99" }]
    },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 5, "title": "Builds / min", "type": "stat",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "datasource": "${DS_PROMETHEUS}",
        "expr": "rate(bonnie_builds_completed_total[1m]) * 60",
        "legendFormat": "builds/min" }]
    },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "id": 6, "title": "OOM Kills", "type": "stat",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background",
        "fieldConfig": { "defaults": { "thresholds": { "steps": [
          { "color": "green", "value": null },
          { "color": "red",   "value": 1 }
        ]}}}
      },
      "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "node_vmstat_oom_kill", "legendFormat": "OOM kills" }]
    },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "unit": "s" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "id": 7, "title": "Build Duration Percentiles", "type": "timeseries",
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "histogram_quantile(0.50, rate(bonnie_build_duration_seconds_bucket[5m]))", "legendFormat": "p50" },
        { "datasource": "${DS_PROMETHEUS}", "expr": "histogram_quantile(0.95, rate(bonnie_build_duration_seconds_bucket[5m]))", "legendFormat": "p95" },
        { "datasource": "${DS_PROMETHEUS}", "expr": "histogram_quantile(0.99, rate(bonnie_build_duration_seconds_bucket[5m]))", "legendFormat": "p99" }
      ]
    },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "id": 8, "title": "Build Throughput", "type": "timeseries",
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "rate(bonnie_builds_completed_total[5m]) * 60", "legendFormat": "completed/min" },
        { "datasource": "${DS_PROMETHEUS}", "expr": "rate(bonnie_builds_failed_total[5m]) * 60",    "legendFormat": "failed/min" },
        { "datasource": "${DS_PROMETHEUS}", "expr": "bonnie_build_queue_depth",                      "legendFormat": "queue depth" }
      ]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "id": 101, "title": "Lazy Pull (Nydus + Stargz)", "type": "row" },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "unit": "s" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "id": 9, "title": "Nydus Chunk Fetch Latency", "type": "timeseries",
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "histogram_quantile(0.50, rate(nydus_chunk_fetch_duration_seconds_bucket[5m]))", "legendFormat": "p50" },
        { "datasource": "${DS_PROMETHEUS}", "expr": "histogram_quantile(0.99, rate(nydus_chunk_fetch_duration_seconds_bucket[5m]))", "legendFormat": "p99" }
      ]
    },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "id": 10, "title": "Nydus Blob Cache Size", "type": "timeseries",
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "nydus_cache_size_gib * 1073741824", "legendFormat": "cache size" }
      ],
      "options": { "tooltip": { "mode": "single" } }
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 102, "title": "Host Resources", "type": "row" },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 23 },
      "id": 11, "title": "CPU Usage by Mode", "type": "timeseries",
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "rate(node_cpu_seconds_total{mode='user'}[5m])",   "legendFormat": "user" },
        { "datasource": "${DS_PROMETHEUS}", "expr": "rate(node_cpu_seconds_total{mode='system'}[5m])", "legendFormat": "system" },
        { "datasource": "${DS_PROMETHEUS}", "expr": "rate(node_cpu_seconds_total{mode='steal'}[5m])",  "legendFormat": "steal" },
        { "datasource": "${DS_PROMETHEUS}", "expr": "rate(node_cpu_seconds_total{mode='iowait'}[5m])", "legendFormat": "iowait" }
      ]
    },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 23 },
      "id": 12, "title": "Memory Usage", "type": "timeseries",
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes", "legendFormat": "used" },
        { "datasource": "${DS_PROMETHEUS}", "expr": "node_memory_MemAvailable_bytes",                              "legendFormat": "available" },
        { "datasource": "${DS_PROMETHEUS}", "expr": "node_memory_HugePages_Total * node_memory_Hugepagesize_bytes","legendFormat": "huge pages" }
      ]
    },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "unit": "Bps" } },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 23 },
      "id": 13, "title": "Network I/O", "type": "timeseries",
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "rate(node_network_receive_bytes_total{device!~'lo'}[5m])",  "legendFormat": "rx {{device}}" },
        { "datasource": "${DS_PROMETHEUS}", "expr": "rate(node_network_transmit_bytes_total{device!~'lo'}[5m])", "legendFormat": "tx {{device}}" }
      ]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "id": 103, "title": "Disk & PSI", "type": "row" },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "unit": "Bps" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "id": 14, "title": "Disk I/O", "type": "timeseries",
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "rate(node_disk_read_bytes_total[5m])",            "legendFormat": "read {{device}}" },
        { "datasource": "${DS_PROMETHEUS}", "expr": "rate(node_disk_written_bytes_total[5m])",         "legendFormat": "write {{device}}" }
      ]
    },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "id": 15, "title": "PSI Pressure (CPU / Memory / IO)", "type": "timeseries",
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "rate(node_pressure_cpu_waiting_seconds_total[5m])",    "legendFormat": "CPU waiting" },
        { "datasource": "${DS_PROMETHEUS}", "expr": "rate(node_pressure_memory_waiting_seconds_total[5m])", "legendFormat": "Memory waiting" },
        { "datasource": "${DS_PROMETHEUS}", "expr": "rate(node_pressure_io_waiting_seconds_total[5m])",     "legendFormat": "IO waiting" }
      ]
    }
  ],

  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["bonnie", "linuxkit", "cicd", "nydus"],
  "templating": {
    "list": [
      { "current": {}, "hide": 0, "includeAll": false, "label": "Instance",
        "multi": false, "name": "instance", "options": [],
        "query": { "query": "label_values(up{job='bonnie-cicd'}, instance)", "refId": "A" },
        "refresh": 1, "sort": 0, "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "bonnie-cicd",
  "uid": "bonnie-cicd-v1",
  "version": 1
}
