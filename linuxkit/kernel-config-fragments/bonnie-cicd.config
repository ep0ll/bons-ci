# =============================================================================
# bonnie-cicd.config — Kconfig fragment for Linux 6.6 LTS
#
# Apply with:
#   scripts/kconfig/merge_config.sh arch/x86/configs/x86_64_defconfig \
#     kernel-config-fragments/bonnie-cicd.config
#
# Themes: BOOT-SPEED | THROUGHPUT | SECURITY | MINIMAL-SIZE
# =============================================================================

# ── Architecture ──────────────────────────────────────────────────────────────
CONFIG_64BIT=y
CONFIG_SMP=y
CONFIG_X86_64=y
CONFIG_NR_CPUS=512
CONFIG_NUMA=y

# ── Preemption: NONE for max batch throughput (CI, not interactive) ───────────
CONFIG_PREEMPT_NONE=y
CONFIG_PREEMPT_VOLUNTARY=n
CONFIG_PREEMPT=n

# ── Timer: 100 Hz tick; NO_HZ_FULL for isolated worker CPUs ──────────────────
CONFIG_HZ_100=y
CONFIG_HZ=100
CONFIG_NO_HZ_IDLE=y
CONFIG_NO_HZ_FULL=y
CONFIG_RCU_NOCB_CPU=y
CONFIG_HIGH_RES_TIMERS=y

# ── CPU / frequency ───────────────────────────────────────────────────────────
CONFIG_CPU_FREQ=y
CONFIG_CPU_FREQ_DEFAULT_GOV_PERFORMANCE=y
CONFIG_CPU_FREQ_GOV_PERFORMANCE=y
CONFIG_CPU_FREQ_GOV_POWERSAVE=n
CONFIG_CPU_FREQ_GOV_ONDEMAND=n
CONFIG_CPU_FREQ_GOV_SCHEDUTIL=n
CONFIG_CPU_IDLE=y
CONFIG_INTEL_IDLE=y
CONFIG_X86_INTEL_PSTATE=y
CONFIG_SCHED_MC=y
CONFIG_SCHED_SMT=y
CONFIG_NUMA_BALANCING=n

# ── Memory ────────────────────────────────────────────────────────────────────
CONFIG_SLUB=y
CONFIG_SLUB_CPU_PARTIAL=y
CONFIG_SLAB_FREELIST_RANDOM=y
CONFIG_SLAB_FREELIST_HARDENED=y
CONFIG_SHUFFLE_PAGE_ALLOCATOR=y
CONFIG_TRANSPARENT_HUGEPAGE=y
CONFIG_TRANSPARENT_HUGEPAGE_MADVISE=y
CONFIG_TRANSPARENT_HUGEPAGE_ALWAYS=n
CONFIG_HUGETLBFS=y
CONFIG_HUGETLB_PAGE=y
CONFIG_MIGRATION=y
CONFIG_COMPACTION=y
CONFIG_KSM=n
CONFIG_SWAP=n
CONFIG_ZSWAP=n
CONFIG_ZRAM=n

# ── Scheduler / cgroups ───────────────────────────────────────────────────────
CONFIG_CGROUPS=y
CONFIG_CGROUP_SCHED=y
CONFIG_FAIR_GROUP_SCHED=y
CONFIG_CFS_BANDWIDTH=y
CONFIG_RT_GROUP_SCHED=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_BLK_CGROUP=y
CONFIG_BLK_CGROUP_IOLATENCY=y
CONFIG_BLK_CGROUP_IOCOST=y
CONFIG_CGROUP_BPF=y
CONFIG_CGROUP_NET_PRIO=y
CONFIG_MEMCG=y
CONFIG_MEMCG_SWAP=y
CONFIG_CGROUP_PIDS=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_HUGETLB=y
CONFIG_CGROUP_PERF=y

# ── Namespaces ────────────────────────────────────────────────────────────────
CONFIG_NAMESPACES=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y
CONFIG_USER_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y
CONFIG_TIME_NS=y

# ── Block / IO — io_uring critical for layer extraction throughput ────────────
CONFIG_IO_URING=y
CONFIG_BLOCK=y
CONFIG_BLK_DEV_NVME=y
CONFIG_NVME_CORE=y
CONFIG_BLK_DEV_THROTTLING=y
CONFIG_BLK_WBT=y
CONFIG_BLK_WBT_MQ=y
CONFIG_BLK_DEV_DM=y
CONFIG_DM_THIN_PROVISIONING=y
CONFIG_DM_SNAPSHOT=y
CONFIG_DM_VERITY=y
CONFIG_DM_VERITY_VERIFY_ROOTHASH_SIG=y
CONFIG_IOSCHED_MQ_DEADLINE=y
CONFIG_MQ_IOSCHED_KYBER=y

# ── Filesystems ───────────────────────────────────────────────────────────────
CONFIG_OVERLAY_FS=y
CONFIG_OVERLAY_FS_REDIRECT_DIR=y
CONFIG_OVERLAY_FS_INDEX=y
CONFIG_OVERLAY_FS_XINO_AUTO=y
CONFIG_OVERLAY_FS_METACOPY=y
CONFIG_FUSE_FS=y
CONFIG_VIRTIO_FS=y
CONFIG_EXT4_FS=y
CONFIG_EXT4_FS_POSIX_ACL=y
CONFIG_TMPFS=y
CONFIG_TMPFS_XATTR=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_SECURITYFS=y
CONFIG_9P_FS=y
CONFIG_9P_FS_POSIX_ACL=y
# zstd is fastest initrd decompressor — critical for boot time
CONFIG_RD_ZSTD=y
CONFIG_RD_LZ4=y
CONFIG_RD_GZIP=n
CONFIG_RD_BZIP2=n
CONFIG_RD_XZ=n
CONFIG_KERNEL_ZSTD=y
# Remove unused filesystems (attack surface reduction)
CONFIG_BTRFS_FS=n
CONFIG_XFS_FS=n
CONFIG_JFS_FS=n
CONFIG_REISERFS_FS=n
CONFIG_NFS_FS=n
CONFIG_CIFS=n
CONFIG_FAT_FS=n
CONFIG_ISO9660_FS=n

# ── Networking ────────────────────────────────────────────────────────────────
CONFIG_NET=y
CONFIG_INET=y
CONFIG_IPV6=y
CONFIG_TCP_CONG_BBR=y
CONFIG_DEFAULT_TCP_CONG="bbr"
CONFIG_NET_SCH_FQ=y
CONFIG_NET_SCH_FQ_CODEL=y
CONFIG_DEFAULT_FQ=y
CONFIG_NETFILTER=y
CONFIG_NF_TABLES=y
CONFIG_NFT_NAT=y
CONFIG_NFT_MASQ=y
CONFIG_NF_CONNTRACK=y
CONFIG_NF_CONNTRACK_EVENTS=y
CONFIG_IP_VS=y
CONFIG_VETH=y
CONFIG_BRIDGE=y
CONFIG_BRIDGE_NETFILTER=y
CONFIG_TUN=y
CONFIG_VSOCK=y
CONFIG_VIRTIO_VSOCKETS=y
CONFIG_VIRTIO_NET=y
CONFIG_NET_9P=y
CONFIG_NET_9P_VIRTIO=y
CONFIG_PACKET=y
CONFIG_UNIX=y
CONFIG_INET_DIAG=y
CONFIG_WIRELESS=n
CONFIG_WLAN=n
CONFIG_BLUETOOTH=n
CONFIG_RFKILL=n

# ── BPF — JIT always on, CO-RE BTF ───────────────────────────────────────────
CONFIG_BPF=y
CONFIG_BPF_SYSCALL=y
CONFIG_BPF_JIT=y
CONFIG_BPF_JIT_ALWAYS_ON=y
CONFIG_BPF_JIT_DEFAULT_ON=y
CONFIG_HAVE_EBPF_JIT=y
CONFIG_BPF_EVENTS=y
CONFIG_BPF_STREAM_PARSER=y
CONFIG_NET_CLS_BPF=y
CONFIG_NET_ACT_BPF=y
CONFIG_DEBUG_INFO_BTF=y
CONFIG_DEBUG_INFO_BTF_MODULES=y

# ── Security — every mitigation enabled ───────────────────────────────────────
CONFIG_SECURITY=y
CONFIG_SECURITY_APPARMOR=y
CONFIG_DEFAULT_SECURITY_APPARMOR=y
CONFIG_SECURITY_YAMA=y
CONFIG_SECURITY_LANDLOCK=y
CONFIG_BPF_LSM=y
CONFIG_SECURITY_LOCKDOWN_LSM=y
CONFIG_SECURITY_LOCKDOWN_LSM_EARLY=y
CONFIG_IMA=y
CONFIG_IMA_DEFAULT_HASH_SHA256=y
CONFIG_IMA_WRITE_POLICY=n
CONFIG_IMA_READ_POLICY=y
CONFIG_EVM=y
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y
CONFIG_SECCOMP_CACHE_DEFAULT_ACTION=y
CONFIG_STRICT_KERNEL_RWX=y
CONFIG_STRICT_MODULE_RWX=y
CONFIG_RANDOMIZE_BASE=y
CONFIG_RANDOMIZE_MEMORY=y
CONFIG_STACKPROTECTOR_STRONG=y
CONFIG_SHADOW_CALL_STACK=y
CONFIG_FORTIFY_SOURCE=y
CONFIG_INIT_ON_ALLOC_DEFAULT_ON=y
CONFIG_INIT_ON_FREE_DEFAULT_ON=y
CONFIG_PAGE_TABLE_ISOLATION=y
CONFIG_RETPOLINE=y
CONFIG_SPECULATION_MITIGATIONS=y
CONFIG_HARDENED_USERCOPY=y
CONFIG_HARDENED_USERCOPY_FALLBACK=n
CONFIG_ZERO_CALL_USED_REGS=y
CONFIG_GCC_PLUGIN_STACKLEAK=y
CONFIG_GCC_PLUGIN_RANDSTRUCT=y
CONFIG_GCC_PLUGIN_LATENT_ENTROPY=y
CONFIG_CFI_CLANG=y
CONFIG_RESET_ATTACK_MITIGATION=y
CONFIG_PANIC_ON_OOPS=y
CONFIG_PANIC_TIMEOUT=-1
CONFIG_MODULE_SIG=y
CONFIG_MODULE_SIG_FORCE=y
CONFIG_MODULE_SIG_ALL=y
CONFIG_MODULE_SIG_SHA512=y
CONFIG_STRICT_DEVMEM=y
CONFIG_IO_STRICT_DEVMEM=y
CONFIG_DEVMEM=n
CONFIG_LEGACY_VSYSCALL_NONE=y
CONFIG_COMPAT_VDSO=n
CONFIG_KEXEC=n
CONFIG_KEXEC_FILE=n
CONFIG_HIBERNATION=n

# ── KVM / QEMU (multi-arch builds, hardware emulation) ───────────────────────
CONFIG_KVM=y
CONFIG_KVM_INTEL=y
CONFIG_KVM_AMD=y
CONFIG_VFIO=y
CONFIG_VFIO_PCI=y
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_PCI_LEGACY=n
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_SCSI=y
CONFIG_VIRTIO_BALLOON=n
CONFIG_VIRTIO_CONSOLE=y
CONFIG_VIRTIO_MEM=y
CONFIG_HW_RANDOM_VIRTIO=y
CONFIG_DRM_VIRTIO_GPU=n

# ── Tracing / observability (minimal; enough for BPF + perf) ─────────────────
CONFIG_FTRACE=y
CONFIG_FUNCTION_TRACER=n
CONFIG_KPROBES=y
CONFIG_KRETPROBES=y
CONFIG_UPROBE_EVENTS=y
CONFIG_PERF_EVENTS=y
CONFIG_DEBUG_INFO=n
CONFIG_STRIP_ASM_SYMS=y

# ── Dead weight — off (smaller image, smaller attack surface) ─────────────────
CONFIG_SOUND=n
CONFIG_USB=n
CONFIG_USB_SUPPORT=n
CONFIG_BLUETOOTH=n
CONFIG_WIRELESS=n
CONFIG_INFINIBAND=n
CONFIG_HAMRADIO=n
CONFIG_STAGING=n
CONFIG_MEDIA_SUPPORT=n
CONFIG_DRM=n
CONFIG_AGP=n
CONFIG_INPUT=n
CONFIG_HID=n
CONFIG_HID_SUPPORT=n
CONFIG_NEW_LEDS=n
CONFIG_DEBUG_KERNEL=n
CONFIG_KGDB=n
CONFIG_MAGIC_SYSRQ=n
CONFIG_EFI_VARS=n
CONFIG_ACPI_TABLE_UPGRADE=n
CONFIG_PARPORT=n
CONFIG_GAMEPORT=n
CONFIG_VT=n
CONFIG_LEGACY_PTYS=n
CONFIG_IPMI_HANDLER=n
CONFIG_SERIO=n
CONFIG_EDAC=n
