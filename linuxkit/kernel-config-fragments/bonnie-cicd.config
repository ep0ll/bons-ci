# =============================================================================
# kernel-config-fragments/bonnie-cicd.config
#
# Drop-in fragment for linuxkit/kernel custom builds.
# Applied on top of the linuxkit defconfig via scripts/kconfig/merge_config.sh
#
# Theme: minimal attack surface + max CI/CD throughput + QEMU/nydus/fuse ready
# =============================================================================

# ── Core ─────────────────────────────────────────────────────────────────────
CONFIG_64BIT=y
CONFIG_SMP=y
CONFIG_PREEMPT_VOLUNTARY=y          # better latency than PREEMPT_NONE; lower than PREEMPT
CONFIG_HZ_1000=y                    # 1 kHz tick → snappy scheduling
CONFIG_NO_HZ_IDLE=y
CONFIG_NO_HZ_FULL=n                 # leave off; we do have kernel threads

# ── CPU / NUMA ────────────────────────────────────────────────────────────────
CONFIG_CPU_FREQ=y
CONFIG_CPU_FREQ_GOV_PERFORMANCE=y
CONFIG_CPU_FREQ_DEFAULT_GOV_PERFORMANCE=y
CONFIG_CPU_IDLE=y
CONFIG_PROCESSOR_SELECT=y
CONFIG_X86_PKG_TEMP_THERMAL=y
CONFIG_NUMA=y
CONFIG_NUMA_BALANCING=n             # disabled via cmdline too; avoid migrations

# ── Memory ────────────────────────────────────────────────────────────────────
CONFIG_TRANSPARENT_HUGEPAGE=y
CONFIG_TRANSPARENT_HUGEPAGE_MADVISE=y  # only on request
CONFIG_COMPACTION=y
CONFIG_KSM=n                        # KSM is a timing side-channel; keep off
CONFIG_ZSWAP=n
CONFIG_ZRAM=n                       # no swap in CI

# ── Scheduler / cgroups ───────────────────────────────────────────────────────
CONFIG_CGROUPS=y
CONFIG_CGROUP_SCHED=y
CONFIG_FAIR_GROUP_SCHED=y
CONFIG_CFS_BANDWIDTH=y
CONFIG_RT_GROUP_SCHED=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_BLK_CGROUP=y
CONFIG_CGROUP_BPF=y
CONFIG_CGROUP_NET_PRIO=y
CONFIG_MEMCG=y
CONFIG_MEMCG_SWAP=y
CONFIG_CGROUP_PIDS=y
CONFIG_CGROUP_RDMA=n

# ── Namespaces ────────────────────────────────────────────────────────────────
CONFIG_NAMESPACES=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y
CONFIG_USER_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y
CONFIG_CLONE_BACKWARDS=y

# ── IO ────────────────────────────────────────────────────────────────────────
CONFIG_IO_URING=y
CONFIG_BLK_DEV_NVME=y
CONFIG_BLK_DEV_THROTTLING=y
CONFIG_IOSCHED_MQ_DEADLINE=y
CONFIG_MQ_IOSCHED_KYBER=y
CONFIG_BLK_WBT=y
CONFIG_BLK_WBT_MQ=y
CONFIG_BLK_DEV_DM=y
CONFIG_DM_THIN_PROVISIONING=y       # overlay on thin-pool
CONFIG_DM_SNAPSHOT=y

# ── Filesystems ───────────────────────────────────────────────────────────────
CONFIG_OVERLAY_FS=y
CONFIG_OVERLAY_FS_REDIRECT_DIR=y
CONFIG_OVERLAY_FS_INDEX=y
CONFIG_OVERLAY_FS_XINO_AUTO=y
CONFIG_FUSE_FS=y                    # nydus FUSE
CONFIG_VIRTIO_FS=y                  # virtiofs for QEMU shared dirs
CONFIG_EXT4_FS=y
CONFIG_BTRFS_FS=n                   # not needed; smaller kernel
CONFIG_XFS_FS=n
CONFIG_TMPFS=y
CONFIG_TMPFS_XATTR=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# ── Networking ────────────────────────────────────────────────────────────────
CONFIG_NET=y
CONFIG_INET=y
CONFIG_IPV6=y
CONFIG_TCP_CONG_BBR=y
CONFIG_NET_SCH_FQ=y
CONFIG_NETFILTER=y
CONFIG_NF_TABLES=y
CONFIG_NFT_NAT=y
CONFIG_NFT_MASQ=y
CONFIG_IP_VS=y
CONFIG_VETH=y
CONFIG_BRIDGE=y
CONFIG_BRIDGE_NETFILTER=y
CONFIG_TUN=y                        # needed for QEMU + VPN
CONFIG_VSOCK=y                      # VM<->host comms
CONFIG_VIRTIO_NET=y
CONFIG_NET_9P=y
CONFIG_NET_9P_VIRTIO=y
CONFIG_PACKET=y
CONFIG_UNIX=y
CONFIG_INET_DIAG=y

# ── BPF ───────────────────────────────────────────────────────────────────────
CONFIG_BPF=y
CONFIG_BPF_SYSCALL=y
CONFIG_BPF_JIT=y
CONFIG_BPF_JIT_ALWAYS_ON=y
CONFIG_BPF_JIT_DEFAULT_ON=y
CONFIG_NET_CLS_BPF=y
CONFIG_NET_ACT_BPF=y
CONFIG_BPF_STREAM_PARSER=y
CONFIG_LWTUNNEL_BPF=y
CONFIG_HAVE_EBPF_JIT=y
CONFIG_BPF_EVENTS=y
CONFIG_BPF_LIRC_MODE2=n

# ── Security ──────────────────────────────────────────────────────────────────
CONFIG_SECURITY=y
CONFIG_SECURITY_APPARMOR=y
CONFIG_DEFAULT_SECURITY_APPARMOR=y
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y
CONFIG_STRICT_KERNEL_RWX=y
CONFIG_STRICT_MODULE_RWX=y
CONFIG_RANDOMIZE_BASE=y
CONFIG_RANDOMIZE_MEMORY=y
CONFIG_STACKPROTECTOR_STRONG=y
CONFIG_SHADOW_CALL_STACK=y
CONFIG_CFI_CLANG=y
CONFIG_FORTIFY_SOURCE=y
CONFIG_INIT_ON_ALLOC_DEFAULT_ON=y
CONFIG_INIT_ON_FREE_DEFAULT_ON=y    # zero freed memory (mitigates use-after-free)
CONFIG_PAGE_TABLE_ISOLATION=y
CONFIG_RETPOLINE=y
CONFIG_SPECULATION_MITIGATIONS=y
CONFIG_LOCK_DOWN_KERNEL_FORCE_CONFIDENTIALITY=y
CONFIG_MODULE_SIG=y
CONFIG_MODULE_SIG_FORCE=y
CONFIG_MODULE_SIG_SHA512=y
CONFIG_SECURITY_DMESG_RESTRICT=y
CONFIG_HARDENED_USERCOPY=y
CONFIG_SLAB_FREELIST_RANDOM=y
CONFIG_SLAB_FREELIST_HARDENED=y
CONFIG_SHUFFLE_PAGE_ALLOCATOR=y
CONFIG_GCC_PLUGIN_STACKLEAK=y
CONFIG_ZERO_CALL_USED_REGS=y
CONFIG_RESET_ATTACK_MITIGATION=y

# ── KVM / QEMU ────────────────────────────────────────────────────────────────
CONFIG_KVM=y
CONFIG_KVM_INTEL=y
CONFIG_KVM_AMD=y
CONFIG_KVM_COMPAT=n
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_SCSI=y
CONFIG_VIRTIO_BALLOON=n
CONFIG_VIRTIO_INPUT=n
CONFIG_HW_RANDOM_VIRTIO=y
CONFIG_DRM_VIRTIO_GPU=n             # headless CI

# ── Tracing (minimal; enough for BPF tools in CI) ────────────────────────────
CONFIG_FTRACE=y
CONFIG_FUNCTION_TRACER=n            # keep off in prod; enable per-node if needed
CONFIG_KPROBES=y
CONFIG_UPROBE_EVENTS=y
CONFIG_PERF_EVENTS=y

# ── Disable dead weight ───────────────────────────────────────────────────────
CONFIG_SOUND=n
CONFIG_USB=n
CONFIG_BLUETOOTH=n
CONFIG_WIRELESS=n
CONFIG_INFINIBAND=n
CONFIG_HAMRADIO=n
CONFIG_STAGING=n
CONFIG_MEDIA_SUPPORT=n
CONFIG_DRM=n
CONFIG_AGP=n
CONFIG_INPUT=n
CONFIG_HID=n
CONFIG_NEW_LEDS=n
CONFIG_DEBUG_KERNEL=n
CONFIG_KGDB=n
CONFIG_MAGIC_SYSRQ=n
CONFIG_EFI_VARS=n
CONFIG_ACPI_TABLE_UPGRADE=n
